<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Chorus Ontology — v0.2.0</title>
<style nonce="<%= locals.cspNonce %>">
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'SF Pro Text', -apple-system, system-ui, sans-serif; background: #0a0a0f; color: #e0e0e8; }
  h1 { font-size: 24px; font-weight: 300; color: #fff; margin-bottom: 6px; }
  .subtitle { font-size: 13px; color: #888; margin-bottom: 40px; }
  .subtitle span { color: #c084fc; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; max-width: 1100px; }
  .section { background: #13131a; border: 1px solid #2a2a3a; border-radius: 12px; padding: 24px; }
  .section h2 { font-size: 15px; font-weight: 600; color: #aab; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 20px; }
  .class-tree { list-style: none; }
  .class-tree li { position: relative; padding: 10px 0 10px 28px; border-left: 2px solid #2a2a3a; }
  .class-tree li:last-child { border-left-color: transparent; }
  .class-tree li::before { content: ''; position: absolute; left: -1px; top: 22px; width: 20px; height: 2px; background: #2a2a3a; }
  .class-name { font-weight: 600; font-size: 15px; color: #fff; }
  .class-parent { font-size: 12px; color: #666; margin-left: 8px; }
  .class-count { display: inline-block; background: #1a2a1a; color: #6d6; border: 1px solid #2a4a2a; border-radius: 6px; padding: 2px 10px; font-size: 13px; font-weight: 500; margin-left: 10px; }
  .class-count.purple { background: #2a1a3a; color: #c084fc; border-color: #4a2a5a; }
  .class-count.blue { background: #1a1a3a; color: #60a5fa; border-color: #2a2a5a; }
  .class-count.amber { background: #2a2a1a; color: #fbbf24; border-color: #4a4a2a; }
  .class-count.gray { background: #1a1a1a; color: #9ca3af; border-color: #3a3a3a; }
  .class-desc { font-size: 12px; color: #777; margin-top: 3px; }
  .prop-table { width: 100%; border-collapse: collapse; }
  .prop-table th { text-align: left; font-size: 11px; color: #666; text-transform: uppercase; letter-spacing: 1px; padding: 6px 0; border-bottom: 1px solid #2a2a3a; }
  .prop-table td { padding: 8px 0; border-bottom: 1px solid #1a1a2a; font-size: 13px; }
  .prop-name { color: #c084fc; font-family: 'SF Mono', monospace; font-size: 12px; }
  .prop-range { color: #a8a; font-size: 12px; }
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; max-width: 1100px; }
  .stat { background: #1a1a24; border: 1px solid #2a2a3a; border-radius: 8px; padding: 16px; text-align: center; }
  .stat-value { font-size: 28px; font-weight: 300; color: #fff; }
  .stat-label { font-size: 11px; color: #777; text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }
  .full-width { grid-column: 1 / -1; }
  .back-link { color: #c084fc; text-decoration: none; font-size: 13px; }
  .back-link:hover { text-decoration: underline; }

  /* Value stream spine */
  .spine { display: flex; align-items: center; justify-content: center; gap: 0; margin: 16px 0 8px; flex-wrap: wrap; }
  .spine-node { padding: 10px 16px; font-size: 13px; font-weight: 600; border-radius: 8px; text-align: center; min-width: 90px; }
  .spine-arrow { color: #666; font-size: 16px; padding: 0 4px; }
  .spine-node.capturing { background: #ede9fe; color: #6d28d9; }
  .spine-node.directing { background: #fef3c7; color: #92400e; }
  .spine-node.designing { background: #e0e7ff; color: #3730a3; }
  .spine-node.building { background: #d1fae5; color: #065f46; }
  .spine-node.proving { background: #fce7f3; color: #9d174d; }
  .spine-feedback { display: flex; align-items: center; justify-content: center; margin: 6px 0 12px; font-size: 11px; color: #666; gap: 6px; }
  .spine-feedback .arrow { color: #9d174d; }
  .operating-bar { display: flex; align-items: center; justify-content: center; background: #f3f4f6; color: #6b7280; border-radius: 6px; padding: 6px 20px; font-size: 12px; font-weight: 600; margin: 0 auto; max-width: 600px; }
  .operating-label { font-size: 10px; color: #888; text-align: center; margin-top: 4px; }

  /* Role cards */
  .role-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .role-card { background: #1a1a24; border: 1px solid #2a2a3a; border-radius: 8px; padding: 12px; display: flex; align-items: center; gap: 10px; }
  .role-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .role-info { flex: 1; }
  .role-name { font-weight: 600; font-size: 14px; color: #fff; }
  .role-type { font-size: 11px; color: #666; }
  .role-domain { font-size: 11px; color: #888; font-style: italic; }

  /* Tool cards */
  .tool-grid { display: grid; grid-template-columns: 1fr; gap: 8px; }
  .tool-row { display: flex; align-items: center; gap: 10px; padding: 8px 12px; background: #1a1a24; border: 1px solid #2a2a3a; border-radius: 6px; }
  .tool-cmd { font-family: 'SF Mono', monospace; font-size: 13px; color: #c084fc; font-weight: 600; min-width: 70px; }
  .tool-desc { font-size: 12px; color: #999; flex: 1; }
  .tool-type { font-size: 10px; padding: 2px 8px; border-radius: 4px; font-weight: 600; }
  .tool-type.sense { background: #0e7490; color: #cffafe; }
  .tool-type.interaction { background: #374151; color: #e5e7eb; }
  .tool-type.memory { background: #6b21a8; color: #f3e8ff; }
  .tool-type.orchestration { background: #92400e; color: #fef3c7; }
  .tool-type.analysis { background: #991b1b; color: #fee2e2; }
  .tool-status { font-size: 10px; padding: 2px 6px; border-radius: 4px; }
  .tool-status.live { background: #1a2a1a; color: #6d6; }
  .tool-status.planned { background: #2a2a1a; color: #a8a; }

  /* Gate flow */
  .gate-flow { display: flex; flex-direction: column; gap: 8px; }
  .gate-row { display: flex; align-items: center; gap: 8px; font-size: 12px; padding: 6px 10px; background: #1a1a24; border-radius: 6px; }
  .gate-name { font-weight: 600; color: #fff; min-width: 110px; }
  .gate-stages { color: #888; flex: 1; }
  .gate-keeper { font-size: 11px; color: #c084fc; }

  /* Rel diagram */
  .rel-diagram { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 16px 0; flex-wrap: wrap; }
  .rel-node { background: #1a1a2a; border: 2px solid #4a4a6a; border-radius: 8px; padding: 8px 16px; font-size: 13px; font-weight: 600; color: #fff; }
  .rel-node.role { border-color: #6ad68a; background: #1a3a2a; }
  .rel-node.vertebra { border-color: #d6a66a; background: #2a2a1a; }
  .rel-node.tool { border-color: #c084fc; background: #2a1a3a; }
  .rel-node.artifact { border-color: #6a8ad6; background: #1a1a3a; }
  .rel-node.gate { border-color: #d66a8a; background: #3a1a2a; }
  .rel-arrow { color: #666; font-size: 12px; display: flex; flex-direction: column; align-items: center; }
  .rel-arrow .label { font-size: 10px; color: #c084fc; margin-bottom: 2px; }
</style>
</head>
<body>
<div class="page-container">

<div style="background:#fef3c7;color:#92400e;padding:12px 20px;border-radius:8px;margin-bottom:20px;font-size:13px;border:1px solid #fcd34d;">
  <strong>Deprecated:</strong> This view is being replaced by the Athena CMDB.
  <a href="/gathering-docs/domain-detail.html?id=chorus-domain" style="color:#92400e;font-weight:600;">View in Athena &rarr;</a>
</div>

