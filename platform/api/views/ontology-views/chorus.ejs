<%- include('partials/content-actions', { title: 'Chorus Ontology' }) %>

<h1>Chorus Ontology</h1>
<p class="subtitle">chorus.ttl <span>v0.2.0</span> &middot; Shared awareness &mdash; human+AI team coordination</p>

<div class="stats">
  <div class="stat"><div class="stat-value"><%= stats.classes || 23 %></div><div class="stat-label">Classes</div></div>
  <div class="stat"><div class="stat-value"><%= stats.objProps || 29 %></div><div class="stat-label">Object Properties</div></div>
  <div class="stat"><div class="stat-value"><%= stats.dtProps || 10 %></div><div class="stat-label">Datatype Properties</div></div>
  <div class="stat"><div class="stat-value">50</div><div class="stat-label">Instances</div></div>
</div>

<div class="grid">

  <!-- VALUE STREAM -->
  <div class="section full-width">
    <h2>Value Stream (The Spine)</h2>
    <div class="spine">
      <div class="spine-node capturing">Capturing</div>
      <div class="spine-arrow">&rarr;</div>
      <div class="spine-node directing">Directing</div>
      <div class="spine-arrow">&rarr;</div>
      <div class="spine-node designing">Designing</div>
      <div class="spine-arrow">&rarr;</div>
      <div class="spine-node building">Building</div>
      <div class="spine-arrow">&rarr;</div>
      <div class="spine-node proving">Proving</div>
    </div>
    <div class="spine-feedback">
      <span class="arrow">&larr;</span> Proving feeds back into Directing <span class="arrow">&larr;</span>
    </div>
    <div class="operating-bar">Operating</div>
    <div class="operating-label">crosscuts all vertebrae &mdash; infrastructure substrate</div>
  </div>

  <!-- ROLES -->
  <div class="section">
    <h2>Roles (4)</h2>
    <div class="role-grid">
      <div class="role-card">
        <div class="role-dot" style="background: #e6edf3;"></div>
        <div class="role-info">
          <div class="role-name">Jeff</div>
          <div class="role-type">Human Role</div>
          <div class="role-domain">Directing, Capturing, Proving</div>
        </div>
      </div>
      <div class="role-card">
        <div class="role-dot" style="background: #4ade80;"></div>
        <div class="role-info">
          <div class="role-name">Wren</div>
          <div class="role-type">Agent Role &middot; Product</div>
          <div class="role-domain">Directing, Designing, Capturing</div>
        </div>
      </div>
      <div class="role-card">
        <div class="role-dot" style="background: #60a5fa;"></div>
        <div class="role-info">
          <div class="role-name">Silas</div>
          <div class="role-type">Agent Role &middot; Architecture</div>
          <div class="role-domain">Designing, Building, Proving</div>
        </div>
      </div>
      <div class="role-card">
        <div class="role-dot" style="background: #fb923c;"></div>
        <div class="role-info">
          <div class="role-name">Kade</div>
          <div class="role-type">Agent Role &middot; Engineering</div>
          <div class="role-domain">Building, Proving, Designing</div>
        </div>
      </div>
    </div>
  </div>

  <!-- GATES -->
  <div class="section">
    <h2>Quality Gates (4)</h2>
    <div class="gate-flow">
      <div class="gate-row">
        <span class="gate-name">Direction Gate</span>
        <span class="gate-stages">Directing &rarr; Designing</span>
        <span class="gate-keeper">Jeff</span>
      </div>
      <div class="gate-row">
        <span class="gate-name">Design Gate</span>
        <span class="gate-stages">Designing &rarr; Building</span>
        <span class="gate-keeper">Silas</span>
      </div>
      <div class="gate-row">
        <span class="gate-name">Build Gate</span>
        <span class="gate-stages">Building &rarr; Proving</span>
        <span class="gate-keeper">Kade</span>
      </div>
      <div class="gate-row">
        <span class="gate-name">Proving Gate</span>
        <span class="gate-stages">Proving &rarr; (feedback)</span>
        <span class="gate-keeper">Jeff</span>
      </div>
    </div>
    <p style="font-size: 11px; color: #666; margin-top: 12px;">Results: Pass | Fail | Override (tracked for trust metrics)</p>
  </div>

  <!-- TOOLS -->
  <div class="section">
    <h2>Tools (7)</h2>
    <div class="tool-grid">
      <div class="tool-row">
        <span class="tool-cmd">/look</span>
        <span class="tool-desc">Screen capture &mdash; Jeff shows, Chorus sees</span>
        <span class="tool-type sense">Sense</span>
        <span class="tool-status live">live</span>
      </div>
      <div class="tool-row">
        <span class="tool-cmd">/listen</span>
        <span class="tool-desc">Voice transcription via whisper.cpp</span>
        <span class="tool-type sense">Sense</span>
        <span class="tool-status live">live</span>
      </div>
      <div class="tool-row">
        <span class="tool-cmd">/talk</span>
        <span class="tool-desc">Voice output &mdash; text to speech</span>
        <span class="tool-type sense">Sense</span>
        <span class="tool-status planned">planned</span>
      </div>
      <div class="tool-row">
        <span class="tool-cmd">/clearing</span>
        <span class="tool-desc">Multi-party chat &mdash; real-time alignment</span>
        <span class="tool-type interaction">Interaction</span>
        <span class="tool-status live">live</span>
      </div>
      <div class="tool-row">
        <span class="tool-cmd">/chorus</span>
        <span class="tool-desc">Shared memory index &mdash; 34k+ messages</span>
        <span class="tool-type memory">Memory</span>
        <span class="tool-status live">live</span>
      </div>
      <div class="tool-row">
        <span class="tool-cmd">/werk</span>
        <span class="tool-desc">Workflow engine &mdash; IS the spine</span>
        <span class="tool-type orchestration">Orchestration</span>
        <span class="tool-status live">live</span>
      </div>
      <div class="tool-row">
        <span class="tool-cmd">Borg</span>
        <span class="tool-desc">Codebase decomposition &amp; assessment</span>
        <span class="tool-type analysis">Analysis</span>
        <span class="tool-status planned">planned</span>
      </div>
    </div>
  </div>

  <!-- ARTIFACTS -->
  <div class="section">
    <h2>Artifact Types (7)</h2>
    <ul class="class-tree">
      <li>
        <span class="class-name">Card</span>
        <span class="class-count amber">Directing exit</span>
        <div class="class-desc">Kanban board item &mdash; entry point for pipeline work</div>
      </li>
      <li>
        <span class="class-name">Brief</span>
        <span class="class-count amber">Designing exit</span>
        <div class="class-desc">Structured document in recipient's briefs/ directory</div>
      </li>
      <li>
        <span class="class-name">Commit</span>
        <span class="class-count amber">Building exit</span>
        <div class="class-desc">Git commit with card reference &mdash; (#N) or (C#N)</div>
      </li>
      <li>
        <span class="class-name">Signal</span>
        <span class="class-count amber">Proving exit</span>
        <div class="class-desc">Notification &mdash; ephemeral</div>
      </li>
      <li>
        <span class="class-name">ADR</span>
        <span class="class-count gray">any stage</span>
        <div class="class-desc">Architectural Decision Record &mdash; the why behind structural choices</div>
      </li>
      <li>
        <span class="class-name">Decision</span>
        <span class="class-count gray">any stage</span>
        <div class="class-desc">DEC-NNN &mdash; constrains future behavior</div>
      </li>
      <li>
        <span class="class-name">Screenshot</span>
        <span class="class-count gray">Build Gate</span>
        <div class="class-desc">Visual proof of shipped work</div>
      </li>
    </ul>
  </div>

  <!-- RELATIONSHIPS DIAGRAM -->
  <div class="section full-width">
    <h2>Core Relationships</h2>
    <div class="rel-diagram">
      <div class="rel-node role">Role</div>
      <div class="rel-arrow"><span class="label">operatesAt</span><span>&rarr;</span></div>
      <div class="rel-node vertebra">Vertebra</div>
      <div class="rel-arrow"><span class="label">nextStage</span><span>&rarr;</span></div>
      <div class="rel-node vertebra">Vertebra</div>
    </div>
    <div class="rel-diagram">
      <div class="rel-node tool">Tool</div>
      <div class="rel-arrow"><span class="label">feeds</span><span>&rarr;</span></div>
      <div class="rel-node vertebra">Vertebra</div>
      <div class="rel-arrow"><span class="label">exitArtifactType</span><span>&rarr;</span></div>
      <div class="rel-node artifact">ArtifactType</div>
    </div>
    <div class="rel-diagram">
      <div class="rel-node gate">Gate</div>
      <div class="rel-arrow"><span class="label">fromStage / toStage</span><span>&rarr;</span></div>
      <div class="rel-node vertebra">Vertebra</div>
      <div class="rel-arrow"><span class="label">gatekeeper</span><span>&rarr;</span></div>
      <div class="rel-node role">Role</div>
    </div>
    <div class="rel-diagram">
      <div class="rel-node artifact">Handoff</div>
      <div class="rel-arrow"><span class="label">from / to</span><span>&rarr;</span></div>
      <div class="rel-node role">Role</div>
      <div class="rel-arrow"><span class="label">status</span><span>&rarr;</span></div>
      <div class="rel-node" style="border-color: #666;">Sent | Received | Stale</div>
    </div>
  </div>

  <!-- OBJECT PROPERTIES -->
  <div class="section full-width">
    <h2>Object Properties (29)</h2>
    <table class="prop-table">
      <tr><th>Property</th><th>Domain &rarr; Range</th><th>Notes</th></tr>
      <tr><td class="prop-name">operatesAt</td><td class="prop-range">Role &rarr; Vertebra</td><td style="font-size:12px;color:#777;">Primary/secondary affinity</td></tr>
      <tr><td class="prop-name">feeds</td><td class="prop-range">Tool &rarr; Vertebra</td><td style="font-size:12px;color:#777;">Tool provides input</td></tr>
      <tr><td class="prop-name">indexes</td><td class="prop-range">Tool &rarr; *</td><td style="font-size:12px;color:#777;">/chorus indexes everything</td></tr>
      <tr><td class="prop-name">orchestrates</td><td class="prop-range">Tool &rarr; Workflow</td><td style="font-size:12px;color:#777;">/werk orchestrates</td></tr>
      <tr><td class="prop-name">outputOf</td><td class="prop-range">Product &rarr; Vertebra</td><td style="font-size:12px;color:#777;">Product emerges from Building + Proving</td></tr>
      <tr><td class="prop-name">inputTo</td><td class="prop-range">Product &rarr; Vertebra</td><td style="font-size:12px;color:#777;">Feedback loop to Capturing</td></tr>
      <tr><td class="prop-name">decomposes</td><td class="prop-range">Tool &rarr; Product</td><td style="font-size:12px;color:#777;">Borg analyzes codebases</td></tr>
      <tr><td class="prop-name">nextStage</td><td class="prop-range">Vertebra &rarr; Vertebra</td><td style="font-size:12px;color:#777;">Sequential flow</td></tr>
      <tr><td class="prop-name">previousStage</td><td class="prop-range">Vertebra &rarr; Vertebra</td><td style="font-size:12px;color:#777;">Back-reference</td></tr>
      <tr><td class="prop-name">feedsInto</td><td class="prop-range">Vertebra &rarr; Vertebra</td><td style="font-size:12px;color:#777;">Proving &rarr; Directing loop</td></tr>
      <tr><td class="prop-name">exitArtifactType</td><td class="prop-range">Vertebra &rarr; ArtifactType</td><td style="font-size:12px;color:#777;">What leaves each stage</td></tr>
      <tr><td class="prop-name">crosscuts</td><td class="prop-range">EventCategory &rarr; Vertebra</td><td style="font-size:12px;color:#777;">Operating underpins all</td></tr>
      <tr><td class="prop-name">fromStage / toStage</td><td class="prop-range">Gate &rarr; Vertebra</td><td style="font-size:12px;color:#777;">Gate boundaries</td></tr>
      <tr><td class="prop-name">gatekeeper</td><td class="prop-range">Gate &rarr; Role</td><td style="font-size:12px;color:#777;">Who evaluates</td></tr>
      <tr><td class="prop-name">handoffFrom / To</td><td class="prop-range">Handoff &rarr; Role</td><td style="font-size:12px;color:#777;">Work exchange endpoints</td></tr>
      <tr><td class="prop-name">handoffType</td><td class="prop-range">Handoff &rarr; HandoffType</td><td style="font-size:12px;color:#777;">Brief, Workflow, Decision</td></tr>
      <tr><td class="prop-name">handoffStatus</td><td class="prop-range">Handoff &rarr; HandoffStatus</td><td style="font-size:12px;color:#777;">Sent, Received, Stale</td></tr>
      <tr><td class="prop-name">sequences</td><td class="prop-range">Workflow &rarr; Step</td><td style="font-size:12px;color:#777;">Ordered step list</td></tr>
      <tr><td class="prop-name">assignedTo</td><td class="prop-range">Step &rarr; Role</td><td style="font-size:12px;color:#777;">Step ownership</td></tr>
      <tr><td class="prop-name">createdBy</td><td class="prop-range">Workflow &rarr; Decision</td><td style="font-size:12px;color:#777;">Decision triggers workflow</td></tr>
      <tr><td class="prop-name">currentStage</td><td class="prop-range">WorkItem &rarr; Vertebra</td><td style="font-size:12px;color:#777;">Where work is now</td></tr>
      <tr><td class="prop-name">linkedCard</td><td class="prop-range">WorkItem &rarr; Card</td><td style="font-size:12px;color:#777;">Board card reference</td></tr>
      <tr><td class="prop-name">evaluatedBy</td><td class="prop-range">StageTransition &rarr; Gate</td><td style="font-size:12px;color:#777;">Which gate checked</td></tr>
      <tr><td class="prop-name">result</td><td class="prop-range">StageTransition &rarr; GateResult</td><td style="font-size:12px;color:#777;">Pass, Fail, Override</td></tr>
      <tr><td class="prop-name">bouncedTo</td><td class="prop-range">BounceBack &rarr; Vertebra</td><td style="font-size:12px;color:#777;">Where bounced work returns</td></tr>
      <tr><td class="prop-name">toolType</td><td class="prop-range">Tool &rarr; ToolType</td><td style="font-size:12px;color:#777;">Classification</td></tr>
    </table>
  </div>

  <!-- DATATYPE PROPERTIES -->
  <div class="section full-width">
    <h2>Datatype Properties (10)</h2>
    <table class="prop-table">
      <tr><th>Property</th><th>Domain</th><th>Range</th><th>Notes</th></tr>
      <tr><td class="prop-name">stageOrder</td><td class="prop-range">Vertebra</td><td class="prop-range">xsd:integer</td><td style="font-size:12px;color:#777;">0-based sequential position</td></tr>
      <tr><td class="prop-name">domain</td><td class="prop-range">Role</td><td class="prop-range">xsd:string</td><td style="font-size:12px;color:#777;">Role's domain label</td></tr>
      <tr><td class="prop-name">color</td><td class="prop-range">*</td><td class="prop-range">xsd:string</td><td style="font-size:12px;color:#777;">Hex color for viz</td></tr>
