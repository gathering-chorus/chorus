<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Sexuality Domain — Ontology v1.1.0</title>
<style nonce="<%= locals.cspNonce %>">
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'SF Pro Text', -apple-system, system-ui, sans-serif; background: #0a0a0f; color: #e0e0e8; }
  h1 { font-size: 24px; font-weight: 300; color: #fff; margin-bottom: 6px; }
  .subtitle { font-size: 13px; color: #888; margin-bottom: 40px; }
  .subtitle span { color: #6af; }

  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; max-width: 1100px; }

  .section { background: #13131a; border: 1px solid #2a2a3a; border-radius: 12px; padding: 24px; }
  .section h2 { font-size: 15px; font-weight: 600; color: #aab; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 20px; }

  /* Class hierarchy */
  .class-tree { list-style: none; }
  .class-tree li { position: relative; padding: 10px 0 10px 28px; border-left: 2px solid #2a2a3a; }
  .class-tree li:last-child { border-left-color: transparent; }
  .class-tree li::before { content: ''; position: absolute; left: -1px; top: 22px; width: 20px; height: 2px; background: #2a2a3a; }
  .class-name { font-weight: 600; font-size: 15px; color: #fff; }
  .class-parent { font-size: 12px; color: #666; margin-left: 8px; }
  .class-count { display: inline-block; background: #1a2a1a; color: #6d6; border: 1px solid #2a4a2a; border-radius: 6px; padding: 2px 10px; font-size: 13px; font-weight: 500; margin-left: 10px; font-variant-numeric: tabular-nums; }
  .class-count.large { background: #2a1a2a; color: #d6d; border-color: #4a2a4a; }
  .class-desc { font-size: 12px; color: #777; margin-top: 3px; }

  /* Properties */
  .prop-table { width: 100%; border-collapse: collapse; }
  .prop-table th { text-align: left; font-size: 11px; color: #666; text-transform: uppercase; letter-spacing: 1px; padding: 6px 0; border-bottom: 1px solid #2a2a3a; }
  .prop-table td { padding: 8px 0; border-bottom: 1px solid #1a1a2a; font-size: 13px; }
  .prop-name { color: #8af; font-family: 'SF Mono', monospace; font-size: 12px; }
  .prop-domain { color: #aaa; font-size: 12px; }
  .prop-range { color: #a8a; font-size: 12px; }
  .prop-usage { text-align: right; color: #6d6; font-variant-numeric: tabular-nums; font-size: 13px; }
  .prop-usage.high { color: #d6d; }

  /* Data summary */
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
  .stat { background: #1a1a24; border: 1px solid #2a2a3a; border-radius: 8px; padding: 16px; text-align: center; }
  .stat-value { font-size: 28px; font-weight: 300; color: #fff; font-variant-numeric: tabular-nums; }
  .stat-label { font-size: 11px; color: #777; text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }

  /* Volume chart */
  .volume-bar { display: flex; align-items: center; margin: 6px 0; }
  .volume-label { width: 160px; font-size: 12px; color: #aaa; text-align: right; padding-right: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .volume-fill { height: 20px; border-radius: 4px; min-width: 2px; transition: width 0.3s; }
  .volume-count { font-size: 11px; color: #888; margin-left: 8px; font-variant-numeric: tabular-nums; }

  .full-width { grid-column: 1 / -1; }

  /* Relationship arrows */
  .rel-diagram { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 16px 0; flex-wrap: wrap; }
  .rel-node { background: #1a1a2a; border: 2px solid #4a4a6a; border-radius: 8px; padding: 8px 16px; font-size: 13px; font-weight: 600; color: #fff; }
  .rel-node.person { border-color: #6a8ad6; background: #1a1a3a; }
  .rel-node.media { border-color: #d66a8a; background: #3a1a2a; }
  .rel-node.source { border-color: #6ad68a; background: #1a3a2a; }
  .rel-arrow { color: #666; font-size: 12px; display: flex; flex-direction: column; align-items: center; }
  .rel-arrow .label { font-size: 10px; color: #8af; margin-bottom: 2px; }
</style>
</head>
<body>
<div class="page-container">
<div style="background:#fef3c7;color:#92400e;padding:12px 20px;border-radius:8px;margin-bottom:20px;font-size:13px;border:1px solid #fcd34d;">
  <strong>Deprecated:</strong> This view is being replaced by the Athena CMDB.
  <a href="/gathering-docs/domain-detail.html?id=sexuality-domain" style="color:#92400e;font-weight:600;">View in Athena &rarr;</a>
</div>
<a href="/self" class="back-link">&larr; Self</a>

<%- include('partials/content-actions', { title: 'Sexuality Domain' }) %>

<h1>Sexuality Domain — Ontology Extension</h1>
<p class="subtitle">jb-ontology.ttl <span>v1.1.0</span> · Cards #224 #375 #376 · 25 volumes harvested · 2026-02-25</p>

<div class="stats">
  <div class="stat">
    <div class="stat-value"><%= stats.photos && stats.videos && stats.archives ? (stats.photos + stats.videos + stats.archives).toLocaleString() : '—' %></div>
    <div class="stat-label">Items Loaded</div>
  </div>
  <div class="stat">
    <div class="stat-value">13.07M</div>
    <div class="stat-label">Triples</div>
  </div>
  <div class="stat">
    <div class="stat-value"><%= stats.models ? stats.models.toLocaleString() : '—' %></div>
    <div class="stat-label">Models</div>
  </div>
  <div class="stat">
    <div class="stat-value">26</div>
    <div class="stat-label">Volume Graphs</div>
  </div>
</div>

<div class="grid">

  <!-- Class Hierarchy -->
  <div class="section">
    <h2>Classes (7)</h2>
    <ul class="class-tree">
      <li>
        <span class="class-name">SexualityCollection</span>
        <span class="class-parent">&#8834; Collection</span>
        <span class="class-count">1</span>
        <div class="class-desc">Top-level collection container</div>
      </li>
      <li>
        <span class="class-name">MediaItem</span>
        <span class="class-count">612</span>
        <div class="class-desc">Base class — text/plain, json, html that didn't match video/image/archive</div>
      </li>
      <li>
        <span class="class-name">MediaPhoto</span>
        <span class="class-parent">&#8834; MediaItem</span>
        <span class="class-count large"><%= stats.photos ? stats.photos.toLocaleString() : '—' %></span>
        <div class="class-desc">image/jpeg + image/png + image/gif</div>
      </li>
      <li>
        <span class="class-name">Video</span>
        <span class="class-parent">&#8834; MediaItem</span>
        <span class="class-count"><%= stats.videos ? stats.videos.toLocaleString() : '—' %></span>
        <div class="class-desc">mp4 + wmv + avi + mpeg + quicktime</div>
      </li>
      <li>
        <span class="class-name">MediaArchive</span>
        <span class="class-parent">&#8834; MediaItem</span>
        <span class="class-count"><%= stats.archives ? stats.archives.toLocaleString() : '—' %></span>
        <div class="class-desc">ZIP files (scene bundles, photo sets)</div>
      </li>
      <li>
        <span class="class-name">Model</span>
        <span class="class-parent">&#8834; foaf:Person</span>
        <span class="class-count"><%= stats.models ? stats.models.toLocaleString() : '—' %></span>
        <div class="class-desc">Performers — from MongoDB models collection, SHA-256 deduped</div>
      </li>
      <li>
        <span class="class-name">ContentSource</span>
        <span class="class-count">~40</span>
        <div class="class-desc">Origin studios/sites — parsed from filenames</div>
      </li>
    </ul>
  </div>

  <!-- Relationship Diagram -->
  <div class="section">
    <h2>Relationships</h2>
    <div class="rel-diagram">
      <div class="rel-node person">Model</div>
      <div class="rel-arrow">
        <span class="label">featuresModel</span>
        <span>&#8592;</span>
      </div>
      <div class="rel-node media">Video / Photo / Archive</div>
      <div class="rel-arrow">
        <span class="label">fromSource</span>
        <span>&#8594;</span>
      </div>
      <div class="rel-node source">ContentSource</div>
    </div>
    <div class="rel-diagram" style="margin-top: 12px;">
      <div class="rel-node person">Model</div>
      <div class="rel-arrow">
        <span class="label">hasProfileImage</span>
        <span>&#8594;</span>
      </div>
      <div class="rel-node media">MediaPhoto</div>
    </div>
    <div class="rel-diagram" style="margin-top: 12px;">
      <div class="rel-node" style="border-color:#d6a66a;background:#2a2a1a;">SexualityCollection</div>
      <div class="rel-arrow">
        <span class="label">hasContent</span>
        <span>&#8594;</span>
      </div>
      <div class="rel-node media">MediaItem</div>
    </div>

    <h2 style="margin-top: 28px;">Object Properties (4)</h2>
    <table class="prop-table">
      <tr><th>Property</th><th>Domain &#8594; Range</th></tr>
      <tr><td class="prop-name">jb:hasContent</td><td class="prop-range">Collection &#8594; MediaItem</td></tr>
      <tr><td class="prop-name">jb:featuresModel</td><td class="prop-range">MediaItem &#8594; Model</td></tr>
      <tr><td class="prop-name">jb:fromSource</td><td class="prop-range">MediaItem &#8594; ContentSource</td></tr>
      <tr><td class="prop-name">jb:hasProfileImage</td><td class="prop-range">Model &#8594; MediaPhoto</td></tr>
    </table>
  </div>

  <!-- Datatype Properties -->
  <div class="section">
    <h2>Datatype Properties (13)</h2>
    <table class="prop-table">
      <tr><th>Property</th><th>Range</th><th style="text-align:right">Coverage</th></tr>
      <tr><td class="prop-name">jb:filePath</td><td class="prop-range">xsd:string</td><td class="prop-usage high"><%= stats.photos && stats.videos && stats.archives ? (stats.photos + stats.videos + stats.archives).toLocaleString() : '—' %></td></tr>
      <tr><td class="prop-name">jb:photoFilename</td><td class="prop-range">xsd:string</td><td class="prop-usage high"><%= stats.photos && stats.videos && stats.archives ? (stats.photos + stats.videos + stats.archives).toLocaleString() : '—' %></td></tr>
      <tr><td class="prop-name">dc:format</td><td class="prop-range">xsd:string</td><td class="prop-usage high"><%= stats.photos && stats.videos && stats.archives ? (stats.photos + stats.videos + stats.archives).toLocaleString() : '—' %></td></tr>
      <tr><td class="prop-name">jb:fileSize</td><td class="prop-range">xsd:long</td><td class="prop-usage high"><%= stats.photos && stats.videos && stats.archives ? (stats.photos + stats.videos + stats.archives).toLocaleString() : '—' %></td></tr>
      <tr><td class="prop-name">jb:sourceVolume</td><td class="prop-range">xsd:string</td><td class="prop-usage high"><%= stats.photos && stats.videos && stats.archives ? (stats.photos + stats.videos + stats.archives).toLocaleString() : '—' %></td></tr>
      <tr><td class="prop-name">dc:created</td><td class="prop-range">xsd:dateTime</td><td class="prop-usage">~1.6M</td></tr>
      <tr><td class="prop-name">jb:mediaUrl</td><td class="prop-range">xsd:anyURI</td><td class="prop-usage">0 <span style="color:#888;font-size:11px;">(v1.1.0, harvest pending)</span></td></tr>
      <tr><td class="prop-name">jb:mediaKind</td><td class="prop-range">xsd:string</td><td class="prop-usage">—</td></tr>
      <tr><td class="prop-name">jb:sceneType</td><td class="prop-range">xsd:string</td><td class="prop-usage">—</td></tr>
      <tr><td class="prop-name">jb:contentQuality</td><td class="prop-range">xsd:string</td><td class="prop-usage">—</td></tr>
      <tr><td class="prop-name">jb:finderLabel</td><td class="prop-range">xsd:integer</td><td class="prop-usage">—</td></tr>
      <tr><td class="prop-name">jb:modelName</td><td class="prop-range">xsd:string</td><td class="prop-usage"><%= stats.models ? stats.models.toLocaleString() : '—' %></td></tr>
      <tr><td class="prop-name">jb:modelChecksum</td><td class="prop-range">xsd:string</td><td class="prop-usage"><%= stats.models ? stats.models.toLocaleString() : '—' %></td></tr>
    </table>
    <p style="font-size:11px;color:#555;margin-top:12px;">Coverage = items with this property populated in Fuseki. Properties marked — are in the ontology but not yet harvested (require extended attribute extraction).</p>
  </div>

  <!-- Volume Distribution -->
