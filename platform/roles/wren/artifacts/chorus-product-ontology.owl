    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#InteractionPattern" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Practice" />
    <rdfs:comment>The skill(s) that fire when this interaction pattern is detected.</rdfs:comment>
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#detectedIn">
    <rdfs:label>detected in</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#InteractionPattern" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Phase" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#touchesDomain">
    <rdfs:label>touches domain</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Sequence" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Domain" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#experienceFor">
    <rdfs:label>experience for</rdfs:label>
