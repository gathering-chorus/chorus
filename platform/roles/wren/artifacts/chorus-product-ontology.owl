    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Domain" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#storyInforms">
    <rdfs:label>informs</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Story" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Decision" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#affects">
    <rdfs:label>affects</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Decision" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Domain" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#constrains">
