    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Role" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#briefAboutDomain">
    <rdfs:label>about domain</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Brief" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Domain" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#triggersSkill">
