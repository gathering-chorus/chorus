  </owl:ObjectProperty>

  
  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#hasGate">
    <rdfs:label>has gate</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Practice" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:comment>The hook or gate that enforces this practice. Empty = ungated risk.</rdfs:comment>
  </owl:DatatypeProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#appliesTo">
    <rdfs:label>applies to</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Practice" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Domain" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#affinityWith">
    <rdfs:label>affinity with</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Practice" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Phase" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#hasPhase">
    <rdfs:label>has stage</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#ValueStream" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Phase" />
    <owl:inverseOf rdf:resource="http://gathering.local/ontology/chorus#belongsTo" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#nextPhase">
    <rdfs:label>next stage</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Phase" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Phase" />
    <rdfs:comment>The next stage in the value stream sequence.</rdfs:comment>
  </owl:ObjectProperty>

  
  
  

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#stance">
    <rdfs:label>stance</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Phase" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:comment>The posture of this stage: Receiving, Prioritizing, Architecting, Shipping, Verifying.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#experience">
    <rdfs:label>experience</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:comment>Jeff's voice — one sentence describing the desired user experience.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#language">
    <rdfs:label>language</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#dataStore">
    <rdfs:label>data store</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#tier">
    <rdfs:label>tier</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:comment>Loom tier: Knowledge, Practices, or Services.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#layer">
    <rdfs:label>layer</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Domain" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:comment>Domain layer: core, supporting, or generic.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#status">
    <rdfs:label>status</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Domain" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:comment>Domain maturity: Active, Partial, Stub, To-Be, Aspirational.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#disposition">
    <rdfs:label>disposition</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:comment>Intent: abandon, tolerate, refactor, rewrite. Separate from status (maturity). Status = what is it. Disposition = what are we doing about it.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#rhythm">
    <rdfs:label>rhythm</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#ValueStream" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:comment>Temporal cadence: minutes-hours, weeks-years, hours-sessions.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#port">
    <rdfs:label>port</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:comment>Network port this service listens on.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#endpoint">
    <rdfs:label>endpoint</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:comment>Base URL or socket path for this service.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#order">
    <rdfs:label>order</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Phase" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#codebasePath">
    <rdfs:label>codebase path</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:comment>File path binding the ontology entity to its implementation. The reterritorialization anchor — when OWL and code drift, this property makes it detectable.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://gathering.local/ontology/chorus#testCount">
    <rdfs:label>test count</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
    <rdfs:comment>Number of tests covering this domain or service. Zero = ungoverned territory.</rdfs:comment>
  </owl:DatatypeProperty>

  
  
  

  <chorus:Product rdf:about="http://gathering.local/ontology/chorus#GatheringProduct">
    <rdfs:label>Gathering</rdfs:label>
    <chorus:hasValueStream rdf:resource="http://gathering.local/ontology/chorus#PersonalStream" />
    <chorus:hasValueStream rdf:resource="http://gathering.local/ontology/chorus#LifeStream" />
    <chorus:hasProduct rdf:resource="http://gathering.local/ontology/chorus#ChorusProduct" />
  </chorus:Product>

  <chorus:Product rdf:about="http://gathering.local/ontology/chorus#ChorusProduct">
    <rdfs:label>Chorus</rdfs:label>
    <chorus:hasValueStream rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:hasProduct rdf:resource="http://gathering.local/ontology/chorus#BridgeProduct" />
    <chorus:hasProduct rdf:resource="http://gathering.local/ontology/chorus#ClearingProduct" />
    <chorus:hasProduct rdf:resource="http://gathering.local/ontology/chorus#BoardProduct" />
    <chorus:hasProduct rdf:resource="http://gathering.local/ontology/chorus#ConvergenceProduct" />
    <chorus:hasProduct rdf:resource="http://gathering.local/ontology/chorus#LoomProduct" />
  </chorus:Product>

  <chorus:Product rdf:about="http://gathering.local/ontology/chorus#BridgeProduct">
    <rdfs:label>Bridge</rdfs:label>
    <chorus:ownedBy rdf:resource="http://gathering.local/ontology/chorus#Silas" />
    <chorus:primaryPhaseProduct rdf:resource="http://gathering.local/ontology/chorus#Building" />
    <chorus:hasValueStream rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
  </chorus:Product>

  <chorus:Product rdf:about="http://gathering.local/ontology/chorus#ClearingProduct">
    <rdfs:label>Clearing</rdfs:label>
    <chorus:ownedBy rdf:resource="http://gathering.local/ontology/chorus#Kade" />
    <chorus:hasValueStream rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:primaryPhaseProduct rdf:resource="http://gathering.local/ontology/chorus#Directing" />
  </chorus:Product>

  <chorus:Product rdf:about="http://gathering.local/ontology/chorus#CardsProduct">
    <rdfs:label>Cards</rdfs:label>
    <rdfs:comment>Board CLI + SDK. Renamed from Board (#1801). Template proven (#1807).</rdfs:comment>
    <chorus:ownedBy rdf:resource="http://gathering.local/ontology/chorus#Wren" />
    <chorus:hasValueStream rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:primaryPhaseProduct rdf:resource="http://gathering.local/ontology/chorus#Directing" />
  </chorus:Product>

  <chorus:Product rdf:about="http://gathering.local/ontology/chorus#DemoProduct">
    <rdfs:label>Demo</rdfs:label>
    <rdfs:comment>Proving gate ceremony. Gate scripts owned by Wren (#1809).</rdfs:comment>
    <chorus:ownedBy rdf:resource="http://gathering.local/ontology/chorus#Wren" />
    <chorus:hasValueStream rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:primaryPhaseProduct rdf:resource="http://gathering.local/ontology/chorus#Proving" />
  </chorus:Product>

  <chorus:Product rdf:about="http://gathering.local/ontology/chorus#HooksProduct">
    <rdfs:label>Hooks</rdfs:label>
    <rdfs:comment>Rust hook server + shim binary. Dispatches to product gate scripts.</rdfs:comment>
    <chorus:ownedBy rdf:resource="http://gathering.local/ontology/chorus#Silas" />
    <chorus:hasValueStream rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:primaryPhaseProduct rdf:resource="http://gathering.local/ontology/chorus#Building" />
  </chorus:Product>

  <chorus:Product rdf:about="http://gathering.local/ontology/chorus#LoomProduct">
    <rdfs:label>Loom</rdfs:label>
    <rdfs:comment>The team method as a product. Org, practices, policy, roles, skills, tool chain, messages, logs. Portable — not tied to Gathering.</rdfs:comment>
    <chorus:ownedBy rdf:resource="http://gathering.local/ontology/chorus#Wren" />
    <chorus:hasValueStream rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:primaryPhaseProduct rdf:resource="http://gathering.local/ontology/chorus#Designing" />
  </chorus:Product>

  <chorus:Product rdf:about="http://gathering.local/ontology/chorus#ConvergenceProduct">
    <rdfs:label>Convergence</rdfs:label>
    <rdfs:comment>Integration practice applied as a product. ICDs, harvesters, field mapping.</rdfs:comment>
    <chorus:ownedBy rdf:resource="http://gathering.local/ontology/chorus#Kade" />
    <chorus:hasValueStream rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:hasValueStream rdf:resource="http://gathering.local/ontology/chorus#LifeStream" />
    <chorus:primaryPhaseProduct rdf:resource="http://gathering.local/ontology/chorus#Designing" />
  </chorus:Product>

  
  
  

  <chorus:ValueStream rdf:about="http://gathering.local/ontology/chorus#PersonalStream">
    <rdfs:label>Personal</rdfs:label>
    <chorus:rhythm>minutes-hours</chorus:rhythm>
  </chorus:ValueStream>

  <chorus:ValueStream rdf:about="http://gathering.local/ontology/chorus#LifeStream">
    <rdfs:label>Life</rdfs:label>
    <chorus:rhythm>weeks-years</chorus:rhythm>
  </chorus:ValueStream>

  <chorus:ValueStream rdf:about="http://gathering.local/ontology/chorus#ChorusStream">
    <rdfs:label>Chorus</rdfs:label>
    <chorus:rhythm>hours-sessions</chorus:rhythm>
  </chorus:ValueStream>

  
  
  

  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Capturing">
    <rdfs:label>Capturing</rdfs:label>
    <chorus:stance>Receiving</chorus:stance>
    <chorus:order>1</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:ownedByRole rdf:resource="http://gathering.local/ontology/chorus#Wren" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Directing" />
  </chorus:Stage>

  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Directing">
    <rdfs:label>Directing</rdfs:label>
    <chorus:stance>Prioritizing</chorus:stance>
    <chorus:order>2</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:ownedByRole rdf:resource="http://gathering.local/ontology/chorus#Wren" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Designing" />
  </chorus:Stage>

  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Designing">
    <rdfs:label>Designing</rdfs:label>
    <chorus:stance>Architecting</chorus:stance>
    <chorus:order>3</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:ownedByRole rdf:resource="http://gathering.local/ontology/chorus#Wren" />
    <chorus:ownedByRole rdf:resource="http://gathering.local/ontology/chorus#Silas" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Building" />
  </chorus:Stage>

  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Building">
    <rdfs:label>Building</rdfs:label>
    <chorus:stance>Shipping</chorus:stance>
    <chorus:order>4</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:ownedByRole rdf:resource="http://gathering.local/ontology/chorus#Kade" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Proving" />
  </chorus:Stage>

  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Proving">
    <rdfs:label>Proving</rdfs:label>
    <chorus:stance>Verifying</chorus:stance>
    <chorus:order>5</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:ownedByRole rdf:resource="http://gathering.local/ontology/chorus#Wren" />
  </chorus:Stage>

  
  
  

  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Spark">
    <rdfs:label>Spark</rdfs:label><chorus:stance>Noticing</chorus:stance><chorus:order>1</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#PersonalStream" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Capture" />
  </chorus:Stage>
  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Capture">
    <rdfs:label>Capture</rdfs:label><chorus:stance>Preserving</chorus:stance><chorus:order>2</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#PersonalStream" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Triage" />
  </chorus:Stage>
  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Triage">
    <rdfs:label>Triage</rdfs:label><chorus:stance>Sorting</chorus:stance><chorus:order>3</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#PersonalStream" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Settle" />
  </chorus:Stage>
  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Settle">
    <rdfs:label>Settle</rdfs:label><chorus:stance>Placing</chorus:stance><chorus:order>4</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#PersonalStream" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Revisit" />
  </chorus:Stage>
  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Revisit">
    <rdfs:label>Revisit</rdfs:label><chorus:stance>Returning</chorus:stance><chorus:order>5</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#PersonalStream" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Transform" />
  </chorus:Stage>
  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Transform">
    <rdfs:label>Transform</rdfs:label><chorus:stance>Growing</chorus:stance><chorus:order>6</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#PersonalStream" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Connect" />
  </chorus:Stage>
  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Connect">
    <rdfs:label>Connect</rdfs:label><chorus:stance>Relating</chorus:stance><chorus:order>7</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#PersonalStream" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Reflect" />
  </chorus:Stage>
  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Reflect">
    <rdfs:label>Reflect</rdfs:label><chorus:stance>Understanding</chorus:stance><chorus:order>8</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#PersonalStream" />
  </chorus:Stage>

  
  
  

  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Sowing">
    <rdfs:label>Sowing</rdfs:label><chorus:stance>Planting</chorus:stance><chorus:order>1</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#LifeStream" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Growing" />
  </chorus:Stage>
  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Growing">
    <rdfs:label>Growing</rdfs:label><chorus:stance>Tending</chorus:stance><chorus:order>2</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#LifeStream" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Practicing" />
  </chorus:Stage>
  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Practicing">
    <rdfs:label>Practicing</rdfs:label><chorus:stance>Cultivating</chorus:stance><chorus:order>3</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#LifeStream" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#Harvesting" />
  </chorus:Stage>
  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#Harvesting">
    <rdfs:label>Harvesting</rdfs:label><chorus:stance>Collecting</chorus:stance><chorus:order>4</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#LifeStream" />
    <chorus:nextPhase rdf:resource="http://gathering.local/ontology/chorus#LifeReflecting" />
  </chorus:Stage>
  <chorus:Stage rdf:about="http://gathering.local/ontology/chorus#LifeReflecting">
    <rdfs:label>Reflecting (Life)</rdfs:label><chorus:stance>Understanding</chorus:stance><chorus:order>5</chorus:order>
    <chorus:belongsTo rdf:resource="http://gathering.local/ontology/chorus#LifeStream" />
  </chorus:Stage>

  
  
  

  <chorus:ChorusDomain rdf:about="http://gathering.local/ontology/chorus#CodebaseDomain">
    <rdfs:label>codebase</rdfs:label><chorus:layer>supporting</chorus:layer><chorus:status>Partial</chorus:status>
    <chorus:servesValueStream rdf:resource="http://gathering.local/ontology/chorus#ChorusStream" />
    <chorus:belongsToProduct rdf:resource="http://gathering.local/ontology/chorus#ChorusProduct" />
    <chorus:primaryPhase rdf:resource="http://gathering.local/ontology/chorus#Building" />
  </chorus:ChorusDomain>

  
  
  

  
  <chorus:Constraint rdf:about="http://gathering.local/ontology/chorus#SeekUnderstandingFirst">
    <rdfs:label>Seek understanding before speculating</rdfs:label>
  </chorus:Constraint>
  <chorus:Constraint rdf:about="http://gathering.local/ontology/chorus#RootCauseOnIssue">
    <rdfs:label>Find root cause on reported issues — never call it intermittent</rdfs:label>
  </chorus:Constraint>
  <chorus:Constraint rdf:about="http://gathering.local/ontology/chorus#TrustJeffsEyes">
    <rdfs:label>Trust Jeff over instruments — he sees all screens</rdfs:label>
  </chorus:Constraint>
  <chorus:Constraint rdf:about="http://gathering.local/ontology/chorus#DeleteDontDeprecate">
    <rdfs:label>Delete old path when replacing — no shims, no fallbacks</rdfs:label>
  </chorus:Constraint>
  <chorus:Constraint rdf:about="http://gathering.local/ontology/chorus#NeverSayOops">
    <rdfs:label>System detects failures before Jeff does</rdfs:label>
  </chorus:Constraint>
  <chorus:Constraint rdf:about="http://gathering.local/ontology/chorus#SymptomNotCause">
    <rdfs:label>Describe symptom in nudges, never speculate cause</rdfs:label>
  </chorus:Constraint>
  <chorus:Constraint rdf:about="http://gathering.local/ontology/chorus#NeverOfferToStop">
    <rdfs:label>Only Jeff decides when to stop</rdfs:label>
  </chorus:Constraint>
  <chorus:Constraint rdf:about="http://gathering.local/ontology/chorus#ExperienceBeforeCode">
    <rdfs:label>Experience statement before building — design artifact required</rdfs:label>
  </chorus:Constraint>
  <chorus:Constraint rdf:about="http://gathering.local/ontology/chorus#TwoMessageSMS">
    <rdfs:label>SMS content and hashtag are always separate messages</rdfs:label>
  </chorus:Constraint>

  
  <chorus:Responsibility rdf:about="http://gathering.local/ontology/chorus#DiagnoseUnknownFailures">
    <rdfs:label>Diagnose unknown failures — never dismiss as intermittent</rdfs:label>
  </chorus:Responsibility>
  <chorus:Responsibility rdf:about="http://gathering.local/ontology/chorus#VerifyDelivery">
    <rdfs:label>Verify delivery — confirm nudges, seeds, events actually arrived</rdfs:label>
  </chorus:Responsibility>
  <chorus:Responsibility rdf:about="http://gathering.local/ontology/chorus#OwnDomainStability">
    <rdfs:label>Own domain stability — your domain, your reliability</rdfs:label>
  </chorus:Responsibility>

  
  <chorus:Role rdf:about="http://gathering.local/ontology/chorus#Wren">
    <rdfs:label>Wren</rdfs:label>
    
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#CoordinationDomain" />
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#PolicyDomain" />
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#SkillsDomain" />
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#OrgDomain" />
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#PracticesDomainChorus" />
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#RolesDomain" />
    
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#GlimmersDomain" />
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#IdeasDomain" />
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#ProjectsDomain" />
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#ValuesDomain" />
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#SelfDomain" />
    <chorus:hasConstraint rdf:resource="http://gathering.local/ontology/chorus#SymptomNotCause" />
    <chorus:hasConstraint rdf:resource="http://gathering.local/ontology/chorus#NeverOfferToStop" />
    <chorus:hasConstraint rdf:resource="http://gathering.local/ontology/chorus#ExperienceBeforeCode" />
    <chorus:hasConstraint rdf:resource="http://gathering.local/ontology/chorus#TrustJeffsEyes" />
    <chorus:hasConstraint rdf:resource="http://gathering.local/ontology/chorus#DeleteDontDeprecate" />
    <chorus:hasResponsibility rdf:resource="http://gathering.local/ontology/chorus#VerifyDelivery" />
    <chorus:hasResponsibility rdf:resource="http://gathering.local/ontology/chorus#OwnDomainStability" />
    <chorus:participatesIn rdf:resource="http://gathering.local/ontology/chorus#Capturing" />
    <chorus:participatesIn rdf:resource="http://gathering.local/ontology/chorus#Directing" />
    <chorus:participatesIn rdf:resource="http://gathering.local/ontology/chorus#Designing" />
    <chorus:participatesIn rdf:resource="http://gathering.local/ontology/chorus#Proving" />
  <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#MessagesDomain" /></chorus:Role>
  <chorus:Role rdf:about="http://gathering.local/ontology/chorus#Silas">
    <rdfs:label>Silas</rdfs:label>
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#InfrastructureDomain" />
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#ObservabilityDomain" />
    <chorus:ownsDomain rdf:resource="http://gathering.local/ontology/chorus#ToolChainDomain" />
