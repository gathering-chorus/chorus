    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Role" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#hasExperience">
    <rdfs:label>has experience</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Card" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Experience" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#inSequence">
    <rdfs:label>in sequence</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Card" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Sequence" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#briefFrom">
    <rdfs:label>from</rdfs:label>
