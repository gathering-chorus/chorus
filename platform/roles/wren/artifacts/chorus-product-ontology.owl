    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Service" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#createdBy">
    <rdfs:label>created by</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Decision" />
