<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF xmlns:chorus="http://gathering.local/ontology/chorus#" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:owl="http://www.w3.org/2002/07/owl#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xml:base="http://gathering.local/ontology/chorus">

  
  
  
  <owl:Ontology rdf:about="http://gathering.local/ontology/chorus">
    <dc:title>Chorus Product Ontology</dc:title>
    <dc:description>Value Streams × Domains × Services — the product model for Gathering and Chorus</dc:description>
    <dc:creator>Wren (PM)</dc:creator>
    <dc:date>2026-03-28</dc:date>
    <owl:versionInfo>0.1</owl:versionInfo>
  </owl:Ontology>

  
  
  

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Product">
    <rdfs:label>Product</rdfs:label>
    <rdfs:comment>A named product with its own value streams, domains, and services. Gathering and Chorus are the two products.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#ValueStream">
    <rdfs:label>Value Stream</rdfs:label>
    <rdfs:comment>A named flow of value from signal to outcome. Stable — when a value stream changes, the product has fundamentally changed.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Phase">
    <rdfs:label>Phase</rdfs:label>
    <rdfs:comment>A phase within a value stream. Each stage is a stance — a posture that determines what you see, value, and produce.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Domain">
    <rdfs:label>Domain</rdfs:label>
    <rdfs:comment>A bounded context with its own data, handlers, ontology, and routes. Domains rarely change.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Service">
    <rdfs:label>Service</rdfs:label>
    <rdfs:comment>A running piece of infrastructure with a language, data model, integration contract, and non-functionals.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Tool"><rdfs:label>Tool</rdfs:label><rdfs:comment>Vendor binary we operate but do not own. Configure and run, not build.</rdfs:comment></owl:Class><owl:Class rdf:about="http://gathering.local/ontology/chorus#Deployment"><rdfs:label>Deployment</rdfs:label><rdfs:comment>Running process — Express app, LaunchAgent, container. A deployment unit, not a service.</rdfs:comment></owl:Class><owl:Class rdf:about="http://gathering.local/ontology/chorus#Practice">
    <rdfs:label>Practice</rdfs:label>
    <rdfs:comment>A repeatable discipline that applies across domains. Convergence is a practice, not a domain.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Role">
    <rdfs:label>Role</rdfs:label>
    <rdfs:comment>A named team member with identity, expertise, and vertical scope.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Responsibility">
    <rdfs:label>Responsibility</rdfs:label>
    <rdfs:comment>A named duty assigned to a role. Queryable by hooks for enforcement.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Constraint">
    <rdfs:label>Constraint</rdfs:label>
    <rdfs:comment>Lifecycle: Feedback (Jeff corrects) → Lesson (team learns) → Rule (hooks enforce). Status tracks maturity: feedback, lesson, rule.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Decision">
    <rdfs:label>Decision</rdfs:label>
    <rdfs:comment>A governing choice that affects domains and constrains services. The act, not the record (ADR). Has lifecycle: active, superseded, withdrawn.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#NonFunctionals">
    <rdfs:label>Non-Functionals</rdfs:label>
    <rdfs:comment>Quality attributes for a service: idempotency, observability, error visibility, monitoring.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Machine">
    <rdfs:label>Machine</rdfs:label>
    <rdfs:comment>Physical hardware. Library (M1) and Bedroom (M2 Pro). Service.runsOn Machine.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#DataSource">
    <rdfs:label>Data Source</rdfs:label>
    <rdfs:comment>Where data lives: Fuseki, SQLite, SOLID Pods, filesystem, NiFi. Traces data lineage.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Card">
    <rdfs:label>Card</rdfs:label>
    <rdfs:comment>Unit of work. Connects decisions to domains via services. Has experience statement, AC, status.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Brief">
    <rdfs:label>Brief</rdfs:label>
    <rdfs:comment>Cross-role communication mechanism. Replaces Jeff as relay between roles.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#InteractionPattern">
    <rdfs:label>Interaction Pattern</rdfs:label>
    <rdfs:comment>Named pattern of how Jeff interacts with the team. Detected and emitted as spine events.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Sequence">
    <rdfs:label>Sequence</rdfs:label>
    <rdfs:comment>Temporal wave of work cutting across domains. Born when the team focuses on a theme, retired when the wave passes.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Experience">
    <rdfs:label>Experience</rdfs:label>
    <rdfs:comment>Jeff's voice describing the desired user experience. First-class — not just a string. Has validation lifecycle.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#Story">
    <rdfs:label>Story</rdfs:label>
    <rdfs:comment>Jeff's personal stories — product inputs, not anecdotes. Carry more signal than feature requests.</rdfs:comment>
  </owl:Class>

  
  <owl:Class rdf:about="http://gathering.local/ontology/chorus#GatheringDomain">
    <rdfs:label>Gathering Domain</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://gathering.local/ontology/chorus#Domain" />
    <rdfs:comment>A domain belonging to the Gathering product.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://gathering.local/ontology/chorus#ChorusDomain">
    <rdfs:label>Chorus Domain</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://gathering.local/ontology/chorus#Domain" />
    <rdfs:comment>A domain belonging to the Chorus product.</rdfs:comment>
  </owl:Class>

  
  
  

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#hasValueStream">
    <rdfs:label>has value stream</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Product" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#ValueStream" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#hasProduct">
    <rdfs:label>has product</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Product" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Product" />
    <rdfs:comment>Recursive product composition. Gathering contains Chorus. Chorus contains sub-products.</rdfs:comment>
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#belongsToProduct">
    <rdfs:label>belongs to product</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Domain" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Product" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#belongsTo">
    <rdfs:label>belongs to</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Phase" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#ValueStream" />
    <rdfs:comment>The value stream this stage is part of.</rdfs:comment>
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#servesValueStream">
    <rdfs:label>serves value stream</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Domain" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#ValueStream" />
    <rdfs:comment>Every domain must map to at least one value stream.</rdfs:comment>
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#primaryPhase">
    <rdfs:label>primary stage</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Domain" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Phase" />
    <rdfs:comment>The stage where this domain has strongest affinity.</rdfs:comment>
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#operatesIn">
    <rdfs:label>operates in</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Domain" />
    <rdfs:comment>Every service must map to at least one domain.</rdfs:comment>
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#supportsStream">
    <rdfs:label>supports stream</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#ValueStream" />
    <rdfs:comment>Every service must map to at least one value stream.</rdfs:comment>
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#ownedBy">
    <rdfs:label>owned by</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Role" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#dependsOn">
    <rdfs:label>depends on</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:comment>Service dependency for failure propagation analysis.</rdfs:comment>
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#hasNonFunctionals">
    <rdfs:label>has non-functionals</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#NonFunctionals" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#ownedByRole">
    <rdfs:label>owned by role</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Phase" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Role" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#participatesIn">
    <rdfs:label>participates in</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Role" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Phase" />
    <rdfs:comment>Broader than ownedByRole. A role participates in phases beyond their primary ownership.</rdfs:comment>
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#primaryPhaseProduct">
    <rdfs:label>primary phase</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Product" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Phase" />
    <rdfs:comment>Where this sub-product lives in the temporal flow.</rdfs:comment>
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#hasResponsibility">
    <rdfs:label>has responsibility</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Role" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Responsibility" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#hasConstraint">
    <rdfs:label>has constraint</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Role" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Constraint" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#ownsDomain">
    <rdfs:label>owns domain</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Role" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Domain" />
    <rdfs:comment>Domain ownership per DEC-058.</rdfs:comment>
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#runsOn">
    <rdfs:label>runs on</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Machine" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#readsFrom">
    <rdfs:label>reads from</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#DataSource" />
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#writesTo">
    <rdfs:label>writes to</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Service" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#DataSource" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#cardInDomain">
    <rdfs:label>in domain</rdfs:label>
    <rdfs:domain rdf:resource="http://gathering.local/ontology/chorus#Card" />
    <rdfs:range rdf:resource="http://gathering.local/ontology/chorus#Domain" />
  </owl:ObjectProperty>

  
  <owl:ObjectProperty rdf:about="http://gathering.local/ontology/chorus#cardInPhase">
