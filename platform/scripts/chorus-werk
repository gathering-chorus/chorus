#!/usr/bin/env bash
# chorus-werk — bootstrap and manage per-role git worktrees outside canonical (#2735).
#
# Each role works in its own worktree at $CHORUS_WERK_BASE/<role>/, branched
# from main, with its own HEAD file. Canonical /chorus/ stays on main always
# and is read-only during sessions. Eliminates the shared-canonical-work-area
# anti-pattern Jeff named 2026-05-05.
#
# Subcommands:
#   init <role>            — create the role's worktree at $CHORUS_WERK_BASE/<role>/
#                            from main. Idempotent.
#   repoint <role> <branch> — switch that worktree to <branch>. Creates the
#                            branch off main if it doesn't exist locally.
#                            Routes through git-queue.sh checkout for flock
#                            serialization.
#   remove <role>          — git worktree remove + branch cleanup.
#   status                 — list current worktrees and their branches.
#   pull <role> <card-id>  — atomic init-if-needed + repoint to
#                            <role>/<card-id>. The /pull skill calls this
#                            instead of raw `git-queue.sh checkout -b`.
#
# Environment:
#   CHORUS_HOME       — canonical repo path. Defaults to /Users/jeffbridwell/CascadeProjects/chorus.
#   CHORUS_WERK_BASE  — where worktrees live. Defaults to /Users/jeffbridwell/CascadeProjects/chorus-werk.
#
# Card: #2735. Test: platform/scripts/test-chorus-werk.sh.

set -uo pipefail

CHORUS_HOME="${CHORUS_HOME:-/Users/jeffbridwell/CascadeProjects/chorus}"
CHORUS_WERK_BASE="${CHORUS_WERK_BASE:-/Users/jeffbridwell/CascadeProjects/chorus-werk}"

usage() {
  cat <<EOF
Usage: chorus-werk <subcommand> [args]

Subcommands:
  init <role>             create worktree at \$CHORUS_WERK_BASE/<role> from main (idempotent)
  repoint <role> <branch> switch role's worktree to <branch>
  remove <role>           remove role's worktree + delete its branch reference
  status                  list current worktrees

Environment:
  CHORUS_HOME       (default: /Users/jeffbridwell/CascadeProjects/chorus)
  CHORUS_WERK_BASE  (default: /Users/jeffbridwell/CascadeProjects/chorus-werk)
EOF
}

require_canonical() {
  if [ ! -d "$CHORUS_HOME/.git" ]; then
    echo "chorus-werk: \$CHORUS_HOME=$CHORUS_HOME is not a git repo" >&2
    exit 2
  fi
}

require_role() {
  local role="${1:-}"
  if [ -z "$role" ]; then
    echo "chorus-werk: missing <role> argument" >&2
    usage >&2
    exit 2
  fi
  case "$role" in
    kade|wren|silas) ;;
    *) echo "chorus-werk: unknown role '$role' (expected kade, wren, or silas)" >&2; exit 2 ;;
  esac
}

# Symlink node_modules from canonical into the werk for every npm-managed
# subdirectory that exists in both. Eliminates the ~30s npm-install tax per
# init (#2758). Skips silently when canonical has no node_modules at the
# matching path. Idempotent: existing werk node_modules (file, dir, or
# symlink) are left alone — bootstrap only fills empty slots.
bootstrap_node_modules() {
  local werk="$1"
  local pkg_files
  pkg_files=$(find "$CHORUS_HOME" -name node_modules -prune -o -type f -name package.json -print 2>/dev/null)
  local pkg
  while IFS= read -r pkg; do
    [ -n "$pkg" ] || continue
    local canonical_dir="${pkg%/package.json}"
    local rel="${canonical_dir#$CHORUS_HOME/}"
    [ "$rel" = "$canonical_dir" ] && continue
    local canonical_nm="$canonical_dir/node_modules"
    [ -d "$canonical_nm" ] || continue
    local werk_dir="$werk/$rel"
    [ -d "$werk_dir" ] || continue
    local werk_nm="$werk_dir/node_modules"
    if [ -e "$werk_nm" ] || [ -L "$werk_nm" ]; then
      continue
    fi
    ln -s "$canonical_nm" "$werk_nm" 2>/dev/null || true
  done <<< "$pkg_files"
}

cmd_init() {
  require_role "${1:-}"
  local role="$1"
  local werk="$CHORUS_WERK_BASE/$role"

  require_canonical
  mkdir -p "$CHORUS_WERK_BASE"

  # Idempotent: if worktree already exists and is registered, no-op.
  # macOS resolves /tmp and /var/folders through /private/, and git stores
  # the resolved path in worktree list — compare resolved paths.
  local werk_resolved=""
  if [ -d "$werk" ]; then
    werk_resolved="$(cd "$werk" && pwd -P)"
  fi
  if [ -n "$werk_resolved" ] && \
     git -C "$CHORUS_HOME" worktree list --porcelain 2>/dev/null | grep -q "^worktree $werk_resolved$"; then
    echo "chorus-werk: $role worktree already initialized at $werk"
    return 0
  fi

  # If the directory exists but isn't a registered worktree, refuse rather than clobber.
  if [ -e "$werk" ]; then
    echo "chorus-werk: $werk exists but isn't a registered worktree — refusing to clobber" >&2
    exit 3
  fi

  # Detached HEAD at main's tip. We can't share the `main` branch with
  # canonical (git refuses dual-checkout), and role worktrees should never
  # sit on main anyway — they exist to host card branches. Detached state
  # is the "ready to receive a repoint" position.
  if ! git -C "$CHORUS_HOME" worktree add --detach "$werk" main 2>&1; then
    echo "chorus-werk: git worktree add failed" >&2
    exit 4
  fi

  # Per-werk git identity (Wren #2735 review). Worktrees share canonical's
  # .git/config, so commits would otherwise all use one identity. Setting
  # user.email/name in the worktree's local config gives each role its
  # own attribution. Worktree config wins over the shared .git/config.
  git -C "$werk" config user.email "$role@chorus.local"
  git -C "$werk" config user.name "$role"

  bootstrap_node_modules "$werk"

  echo "chorus-werk: initialized $role at $werk (detached at main, repoint to start a card)"
}

cmd_repoint() {
  require_role "${1:-}"
  local role="$1"
  local branch="${2:-}"
  local werk="$CHORUS_WERK_BASE/$role"

  if [ -z "$branch" ]; then
    echo "chorus-werk: missing <branch> argument" >&2
    exit 2
  fi
  if [ ! -d "$werk" ]; then
    echo "chorus-werk: $role worktree not initialized — run 'chorus-werk init $role' first" >&2
    exit 3
  fi

  # Use git-queue.sh checkout if available (production path), fall back to
  # plain git for the test fixture (where canonical isn't a chorus repo).
  local gq="$CHORUS_HOME/platform/scripts/git-queue.sh"
  pushd "$werk" >/dev/null

  # Does the branch exist locally?
  if git rev-parse --verify "$branch" >/dev/null 2>&1; then
    if [ -x "$gq" ]; then
      DEPLOY_ROLE="$role" "$gq" checkout "$branch" >/dev/null 2>&1 || git checkout "$branch" >/dev/null 2>&1
    else
      git checkout "$branch" >/dev/null 2>&1
    fi
  else
    # New branch — create from main (or from origin/main if remote exists)
    local base="main"
    if git rev-parse --verify "origin/main" >/dev/null 2>&1; then
      base="origin/main"
    fi
    if [ -x "$gq" ]; then
      DEPLOY_ROLE="$role" "$gq" checkout -b "$branch" "$base" >/dev/null 2>&1 || git checkout -b "$branch" "$base" >/dev/null 2>&1
    else
      git checkout -b "$branch" "$base" >/dev/null 2>&1
    fi
  fi
  local rc=$?
  popd >/dev/null

  if [ "$rc" -ne 0 ]; then
    echo "chorus-werk: failed to switch $role worktree to $branch" >&2
    exit 5
  fi
  echo "chorus-werk: $role now on $branch"
}

cmd_remove() {
  require_role "${1:-}"
  local role="$1"
  local werk="$CHORUS_WERK_BASE/$role"

  require_canonical
  if [ ! -d "$werk" ]; then
    echo "chorus-werk: $role worktree not present at $werk — nothing to remove"
    return 0
  fi

  if ! git -C "$CHORUS_HOME" worktree remove --force "$werk" 2>&1; then
    echo "chorus-werk: git worktree remove failed" >&2
    exit 6
  fi
  echo "chorus-werk: removed $role worktree at $werk"
}

cmd_status() {
  require_canonical
  echo "Canonical: $CHORUS_HOME (HEAD=$(git -C "$CHORUS_HOME" rev-parse --abbrev-ref HEAD 2>/dev/null))"
  echo "Werk base: $CHORUS_WERK_BASE"
  echo
  echo "Role worktrees:"
  local found=0
  for role in kade wren silas; do
    local werk="$CHORUS_WERK_BASE/$role"
    if [ -d "$werk" ]; then
      local branch
      branch=$(git -C "$werk" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
      printf "  %-7s %s  (branch: %s)\n" "$role" "$werk" "$branch"
      found=1
    fi
  done
  if [ "$found" = "0" ]; then
    echo "  (no role worktrees initialized)"
  fi
}

cmd_close() {
  # Parse optional --no-done-check flag (must come before positional args).
  # When present, skip the cards CLI Done-state lookup. Production /acp
  # wiring runs `cards done` immediately before close, so Done state is
  # guaranteed by call order; the flag exists for tests + manual cleanup.
  local skip_done_check=0
  while [ "${1:-}" = "--no-done-check" ]; do
    skip_done_check=1
    shift
  done

  require_role "${1:-}"
  local role="$1"
  local card_id="${2:-}"
  local werk="$CHORUS_WERK_BASE/$role"
  local branch="$role/$card_id"

  if [ -z "$card_id" ]; then
    echo "chorus-werk: missing <card-id> argument" >&2
    exit 2
  fi

  require_canonical

  # Idempotent: if the local branch is already gone, close is a no-op.
  if ! git -C "$CHORUS_HOME" rev-parse --verify "refs/heads/$branch" >/dev/null 2>&1; then
    echo "chorus-werk: $branch already closed (no local ref)"
    return 0
  fi

  # Refuse on dirty werk — never silently lose work.
  if [ -d "$werk" ]; then
    local dirty
    dirty=$(git -C "$werk" status --porcelain 2>/dev/null)
    if [ -n "$dirty" ]; then
      echo "chorus-werk: $werk has uncommitted changes — refusing close (commit, stash, or abandon explicitly)" >&2
      exit 7
    fi
  fi

  # Verify card is Done unless caller bypassed.
  if [ "$skip_done_check" = "0" ]; then
    if [ -x "$CHORUS_HOME/platform/scripts/cards" ]; then
      local card_status
      card_status=$("$CHORUS_HOME/platform/scripts/cards" view "$card_id" 2>/dev/null \
        | grep -E '^\s*Status:' | head -1 | awk '{print $2}')
      if [ "$card_status" != "Done" ]; then
        echo "chorus-werk: card #$card_id status is '$card_status' — refusing close (use --no-done-check to override)" >&2
        exit 8
      fi
    fi
  fi

  # Detach the worktree at canonical's main tip BEFORE deleting the branch
  # (can't delete a branch that's checked out in the worktree).
  if [ -d "$werk" ]; then
    local main_tip
    main_tip=$(git -C "$CHORUS_HOME" rev-parse main 2>/dev/null)
    if [ -z "$main_tip" ]; then
      echo "chorus-werk: cannot resolve canonical main — refusing close" >&2
      exit 9
    fi
    if ! (cd "$werk" && git checkout --detach "$main_tip" >/dev/null 2>&1); then
      echo "chorus-werk: failed to detach $role werk at main's tip" >&2
      exit 10
    fi
  fi

  # Delete the local branch.
  if ! git -C "$CHORUS_HOME" update-ref -d "refs/heads/$branch" 2>&1; then
    echo "chorus-werk: failed to delete local branch $branch" >&2
    exit 11
  fi

  # Best-effort: delete remote branch via git-queue.sh push --delete.
  # Already-deleted-remote (the common case post-acp) is fine.
  local gq="$CHORUS_HOME/platform/scripts/git-queue.sh"
  if [ -x "$gq" ]; then
    DEPLOY_ROLE="$role" "$gq" push --delete "$branch" >/dev/null 2>&1 || true
  fi

  # Spine event — best-effort.
  if command -v chorus-log >/dev/null 2>&1; then
    chorus-log card.branch.closed "$role" "card=$card_id" "branch=$branch" >/dev/null 2>&1 || true
  elif [ -x "$CHORUS_HOME/platform/scripts/chorus-log" ]; then
    "$CHORUS_HOME/platform/scripts/chorus-log" card.branch.closed "$role" "card=$card_id" "branch=$branch" >/dev/null 2>&1 || true
  fi

  echo "chorus-werk: closed $branch (werk detached, local branch deleted, remote cleanup attempted)"
}

cmd_pull() {
  require_role "${1:-}"
  local role="$1"
  local card_id="${2:-}"

  if [ -z "$card_id" ]; then
    echo "chorus-werk: missing <card-id> argument" >&2
    exit 2
  fi

  # Idempotent init — no-op if already initialized.
  cmd_init "$role" >/dev/null
  # Repoint to the card branch. Branch naming convention: <role>/<card-id>.
  cmd_repoint "$role" "$role/$card_id"
}

main() {
  if [ $# -lt 1 ]; then
    usage >&2
    exit 2
  fi
  local sub="$1"; shift
  case "$sub" in
    init) cmd_init "$@" ;;
    repoint) cmd_repoint "$@" ;;
    remove) cmd_remove "$@" ;;
    status) cmd_status "$@" ;;
    pull) cmd_pull "$@" ;;
    close) cmd_close "$@" ;;
    -h|--help|help) usage ;;
    *) echo "chorus-werk: unknown subcommand '$sub'" >&2; usage >&2; exit 2 ;;
  esac
}

main "$@"
