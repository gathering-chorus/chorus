#!/usr/bin/env bash
# chorus-werk — ephemeral per-card git worktrees outside canonical (#2913).
#
# #2913 rewrite. The persistent-per-role model (#2735: init/repoint/pull/close
# around one stable chorus-werk/<role>/ dir) is gone. Its `repoint` verb swapped
# branches in a live directory — branch-swap-in-place — which detached HEADs and
# burned the team 2026-05-13/14. The ephemeral model has no repoint: each card
# gets its own worktree, created on pull and destroyed on acp.
#
#   chorus-werk/<role>-<card>/   one worktree per card, on branch <role>/<card>
#
# Subcommands:
#   add <role> <card-id>     create chorus-werk/<role>-<card>/ on branch
#                            <role>/<card-id> from origin/main. node_modules
#                            symlink bootstrap, per-werk git identity.
#                            Idempotent: re-add of an existing card is a no-op.
#   remove <role> <card-id>  refuse if the werk is dirty; otherwise
#                            git worktree remove + delete local branch +
#                            best-effort remote-ref delete + git worktree prune.
#                            Idempotent: re-remove of a gone card is a no-op.
#   status                   list ephemeral worktrees (chorus-werk/<role>-*).
#
# Environment:
#   CHORUS_HOME       canonical repo path. Default /Users/jeffbridwell/CascadeProjects/chorus.
#   CHORUS_WERK_BASE  where worktrees live. Default /Users/jeffbridwell/CascadeProjects/chorus-werk.
#
# Card: #2913. Test: platform/scripts/test-chorus-werk.sh.

set -uo pipefail

CHORUS_HOME="${CHORUS_HOME:-/Users/jeffbridwell/CascadeProjects/chorus}"
CHORUS_WERK_BASE="${CHORUS_WERK_BASE:-/Users/jeffbridwell/CascadeProjects/chorus-werk}"

usage() {
  cat <<EOF
Usage: chorus-werk <subcommand> [args]

Subcommands:
  add <role> <card-id>     create chorus-werk/<role>-<card>/ on branch <role>/<card-id>
  remove <role> <card-id>  remove the card's worktree + branch (refuses on dirty werk)
  status                   list ephemeral worktrees

Environment:
  CHORUS_HOME       (default: /Users/jeffbridwell/CascadeProjects/chorus)
  CHORUS_WERK_BASE  (default: /Users/jeffbridwell/CascadeProjects/chorus-werk)
EOF
}

require_canonical() {
  if [ ! -d "$CHORUS_HOME/.git" ]; then
    echo "chorus-werk: \$CHORUS_HOME=$CHORUS_HOME is not a git repo" >&2
    exit 2
  fi
}

require_role() {
  local role="${1:-}"
  if [ -z "$role" ]; then
    echo "chorus-werk: missing <role> argument" >&2
    usage >&2
    exit 2
  fi
  case "$role" in
    kade|wren|silas) ;;
    *) echo "chorus-werk: unknown role '$role' (expected kade, wren, or silas)" >&2; exit 2 ;;
  esac
}

require_card_id() {
  local card_id="${1:-}"
  if [ -z "$card_id" ]; then
    echo "chorus-werk: missing <card-id> argument" >&2
    usage >&2
    exit 2
  fi
}

# node_modules bootstrap RETIRED here (#3169). The werk-build preamble
# (werk_build::ensure_node_modules) is now the SINGLE owner of werk
# node_modules: it symlinks every werk package's node_modules to canonical's
# complete tree right before building, REPLACING stale partial real dirs /
# broken symlinks — which this skip-if-exists one-shot never did (it only
# filled empty slots, so a partial node_modules left in-werk tsc unable to
# resolve @types, the merged≠live root for #3174/#3171). One execution path,
# nothing to drift against (coherence-is-one-execution-path). Skipping the
# pull-time link costs nothing: no TS runs between pull and the first build,
# and the build preamble is idempotent + runs every build.

# Emit a spine event, best-effort — never fails the caller.
emit_spine() {
  local event="$1"; shift
  if command -v chorus-log >/dev/null 2>&1; then
    chorus-log "$event" "$@" >/dev/null 2>&1 || true
  elif [ -x "$CHORUS_HOME/platform/scripts/chorus-log" ]; then
    "$CHORUS_HOME/platform/scripts/chorus-log" "$event" "$@" >/dev/null 2>&1 || true
  fi
}

# Resolve the base ref for a new card branch. Prefer origin/main — canonical's
# local main lags whenever a peer pushes between sessions; basing a new branch
# on stale local main starts the card behind. Best-effort fetch first; fall
# back to local main when origin/main doesn't exist (test fixtures, no remote).
resolve_base() {
  git -C "$CHORUS_HOME" fetch origin main >/dev/null 2>&1 || true
  if git -C "$CHORUS_HOME" rev-parse --verify origin/main >/dev/null 2>&1; then
    echo "origin/main"
  else
    echo "main"
  fi
}

cmd_add() {
  require_role "${1:-}"
  require_card_id "${2:-}"
  local role="$1"
  local card_id="$2"
  local werk="$CHORUS_WERK_BASE/$role-$card_id"
  local branch="$role/$card_id"

  require_canonical
  mkdir -p "$CHORUS_WERK_BASE"

  # Idempotent: if the worktree already exists, is registered, and sits on the
  # expected branch — no-op. macOS resolves /tmp + /var/folders through
  # /private/; git stores the resolved path, so compare resolved paths.
  if [ -d "$werk" ]; then
    local werk_resolved
    werk_resolved="$(cd "$werk" && pwd -P)"
    if git -C "$CHORUS_HOME" worktree list --porcelain 2>/dev/null \
         | grep -q "^worktree $werk_resolved$"; then
      local cur_branch
      cur_branch=$(git -C "$werk" rev-parse --abbrev-ref HEAD 2>/dev/null)
      if [ "$cur_branch" = "$branch" ]; then
        echo "chorus-werk: $role-$card_id already on $branch"
        return 0
      fi
      echo "chorus-werk: $werk is registered but on '$cur_branch', not '$branch' — refusing to clobber" >&2
      exit 3
    fi
    echo "chorus-werk: $werk exists but isn't a registered worktree — refusing to clobber" >&2
    exit 3
  fi

  local base
  base=$(resolve_base)

  # Create the worktree directly on the card branch. If the branch already
  # exists locally (e.g. a prior session created it), attach to it; otherwise
  # branch it from base. No detach, no repoint — the worktree is born on the
  # branch it will live on.
  if git -C "$CHORUS_HOME" rev-parse --verify "refs/heads/$branch" >/dev/null 2>&1; then
    if ! git -C "$CHORUS_HOME" worktree add "$werk" "$branch" 2>&1; then
      echo "chorus-werk: git worktree add (existing branch $branch) failed" >&2
      exit 4
    fi
  else
    if ! git -C "$CHORUS_HOME" worktree add -b "$branch" "$werk" "$base" 2>&1; then
      echo "chorus-werk: git worktree add -b $branch failed" >&2
      exit 4
    fi
  fi

  # Per-werk git identity. Worktrees share canonical's .git/config, so commits
  # would otherwise all use one identity. Worktree-local config wins.
  git -C "$werk" config user.email "$role@chorus.local"
  git -C "$werk" config user.name "$role"

  # node_modules now ensured by the werk-build preamble (#3169), not here.

  emit_spine card.werk.added "$role" "card=$card_id" "branch=$branch" "werk=$werk"
  echo "chorus-werk: added $role-$card_id at $werk (branch $branch)"
}

# #3016 — stop + clean up a werk-deployed chorus-mcp daemon. Reads the launchd
# label from the werk's .werk-mcp/ marker, boots out the per-werk agent
# (launchctl, never a kill — no-raw-kill rule), removes its plist, then drops the
# marker dir. Idempotent: no marker → silent no-op.
teardown_werk_mcp() {
  local werk="$1"
  [ -n "$werk" ] && [ -f "$werk/.werk-mcp/label" ] || return 0
  local mcp_label
  mcp_label=$(cat "$werk/.werk-mcp/label" 2>/dev/null || true)
  if [ -n "$mcp_label" ]; then
    launchctl bootout "gui/$(id -u)/$mcp_label" 2>/dev/null || true
    rm -f "$HOME/Library/LaunchAgents/$mcp_label.plist" 2>/dev/null || true
    echo "chorus-werk: tore down werk chorus-mcp daemon ($mcp_label)"
  fi
  rm -rf "$werk/.werk-mcp" 2>/dev/null || true
}

cmd_remove() {
  require_role "${1:-}"
  require_card_id "${2:-}"
  local role="$1"
  local card_id="$2"
  local werk="$CHORUS_WERK_BASE/$role-$card_id"
  local branch="$role/$card_id"

  require_canonical

  local werk_present=0
  local branch_present=0
  [ -d "$werk" ] && werk_present=1
  git -C "$CHORUS_HOME" rev-parse --verify "refs/heads/$branch" >/dev/null 2>&1 && branch_present=1

  # #3016 — tear down any werk-deployed chorus-mcp daemon before the dirty-check
  # + worktree remove (the .werk-mcp marker is untracked and would otherwise
  # refuse the remove). Covers both /acp and /unpull (both call remove).
  [ "$werk_present" = "1" ] && teardown_werk_mcp "$werk"

  # Idempotent: nothing left to remove.
  if [ "$werk_present" = "0" ] && [ "$branch_present" = "0" ]; then
    git -C "$CHORUS_HOME" worktree prune >/dev/null 2>&1 || true
    echo "chorus-werk: $role-$card_id already removed"
    return 0
  fi

  # Refuse on dirty werk — never silently lose work.
  if [ "$werk_present" = "1" ]; then
    local dirty
    dirty=$(git -C "$werk" status --porcelain 2>/dev/null)
    if [ -n "$dirty" ]; then
      echo "chorus-werk: $werk has uncommitted changes — refusing remove (commit, stash, or abandon explicitly)" >&2
      exit 5
    fi
  fi

  # Remove the worktree (clean — dirty was refused above; --force suppresses
  # the interactive guard, nothing to lose).
  if [ "$werk_present" = "1" ]; then
    if ! git -C "$CHORUS_HOME" worktree remove --force "$werk" 2>&1; then
      echo "chorus-werk: git worktree remove failed for $werk" >&2
      exit 6
    fi
  fi

  # Delete the local branch. Merged-ness is decided in two tiers:
  #
  # #3014 — Tier 1: acp-commit-on-main. The reliable merge proof is an
  # acceptance commit for THIS card on origin/main. /acp's whole job is
  # merge-then-record, so a subject referencing `#<card>` on main means the
  # work landed. This is the ONLY check that survives squash-merge:
  #   - patch-id (git cherry, Tier 2 below) false-refuses because after a
  #     squash the branch's commits aren't ancestors of main and their
  #     patch-ids don't match the single squash commit.
  #   - content/tree diff also false-refuses because main moves on after acp
  #     (later cards touch the same files), so the branch "differs from main"
  #     despite its work being fully merged.
  # Verified 2026-05-19 on silas/3000, /2952, /2775 — all had acp commits,
  # all were falsely refused by both diff approaches. Squash-orphan storm.
  #
  # Tier 2 (fallback): patch-id via `git cherry` — same test chorus_acp uses
  # (#2911). Only reached when NO acp-commit exists on main, preserving the
  # refusal for genuinely-unmerged branches with real work.
  if [ "$branch_present" = "1" ]; then
    # Tier 1: look for an acp commit referencing #<card_id> on origin/main.
    # Two bugs previously defeated this (#3018), both landing on Tier 2's
    # always-false squash-orphan refusal:
    #   (a) `git log | grep -q` under `set -o pipefail`: grep -q matches the
    #       NEWEST subject (the acp commit) and closes the pipe; git log, still
    #       emitting up to 300 subjects, takes SIGPIPE (141); pipefail promotes
    #       141 to the pipeline exit; the check reads "no match". Triggers only
    #       once log output exceeds the pipe buffer — production history does,
    #       the small test repo did not (why TEST 16 passed despite the live
    #       bug). Fix: capture subjects, match with a here-string — no upstream
    #       process in the pipe, so no SIGPIPE.
    #   (b) the single `fetch ... || true` raced the squash-merge becoming
    #       visible on origin/main and swallowed any failure, leaving Tier 1
    #       evaluating a stale ref. Fix: re-fetch and retry a bounded number of
    #       times before falling through, and record fetch failure rather than
    #       swallowing it silently.
    local acp_committed=0
    local fetch_failed=0
    local attempt subjects
    # Match `#<card_id>` with a non-digit (or end) boundary so #300 doesn't
    # match #3000. 300-commit window covers any plausible acp/close lag.
    for attempt in 1 2 3; do
      git -C "$CHORUS_HOME" fetch --quiet origin main 2>/dev/null || fetch_failed=1
      subjects=$(git -C "$CHORUS_HOME" log origin/main -n 300 --format='%s' 2>/dev/null)
      if grep -qE "#${card_id}([^0-9]|\$)" <<< "$subjects"; then
        acp_committed=1
        fetch_failed=0
        break
      fi
      [ "$attempt" -lt 3 ] && sleep 1
    done

    if [ "$acp_committed" = "1" ]; then
      : # Tier 1 pass — card accepted on main; safe to delete regardless of
        # patch-id divergence from squash-merge.
    else
      # Tier 2 — no acceptance commit found; fall back to patch-id check.
      # Surface (don't swallow) a fetch failure so a stale-ref refusal is never
      # silent.
      local stale_note=""
      [ "$fetch_failed" = "1" ] && stale_note=" (note: could not refresh origin/main — merge state may be stale)"
      local cherry_out
      if ! cherry_out=$(git -C "$CHORUS_HOME" cherry origin/main "$branch" 2>/dev/null); then
        echo "chorus-werk: could not determine merge state of '$branch' (no acp commit on main, git cherry failed)${stale_note} — refusing to delete. Resolve manually." >&2
        exit 7
      fi
      if grep -q '^+' <<< "$cherry_out"; then
        echo "chorus-werk: '$branch' has commits not on origin/main by content and no acp #${card_id} commit on main${stale_note} — refusing to delete. Merge or abandon explicitly (git branch -D)." >&2
        exit 7
      fi
    fi

    if ! git -C "$CHORUS_HOME" branch -D "$branch" 2>&1; then
      echo "chorus-werk: 'git branch -D $branch' failed" >&2
      exit 7
    fi
  fi

  # Best-effort remote-ref delete via git-queue.sh. Already-deleted-remote
  # (the common case post-acp) is fine.
  local gq="$CHORUS_HOME/platform/scripts/git-queue.sh"
  if [ -x "$gq" ]; then
    DEPLOY_ROLE="$role" "$gq" push --delete "$branch" >/dev/null 2>&1 || true
  fi

  # Prune stale .git/worktrees admin entries (Silas gate-arch condition 3b).
  # git worktree remove unregisters cleanly; prune also catches entries left
  # by a non-clean removal (e.g. the dir was rm -rf'd out from under git).
  git -C "$CHORUS_HOME" worktree prune >/dev/null 2>&1 || true

  emit_spine card.branch.closed "$role" "card=$card_id" "branch=$branch"
  echo "chorus-werk: removed $role-$card_id (worktree gone, branch $branch deleted, remote cleanup attempted)"
}

cmd_status() {
  require_canonical
  echo "Canonical: $CHORUS_HOME (HEAD=$(git -C "$CHORUS_HOME" rev-parse --abbrev-ref HEAD 2>/dev/null))"
  echo "Werk base: $CHORUS_WERK_BASE"
  echo
  echo "Ephemeral worktrees:"
  local found=0
  local werk
  for werk in "$CHORUS_WERK_BASE"/kade-* "$CHORUS_WERK_BASE"/wren-* "$CHORUS_WERK_BASE"/silas-*; do
    [ -d "$werk" ] || continue
    local name branch
    name=$(basename "$werk")
    branch=$(git -C "$werk" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
    printf "  %-22s %s  (branch: %s)\n" "$name" "$werk" "$branch"
    found=1
  done
  if [ "$found" = "0" ]; then
    echo "  (no ephemeral worktrees)"
  fi
}

main() {
  if [ $# -lt 1 ]; then
    usage >&2
    exit 2
  fi
  local sub="$1"; shift
  case "$sub" in
    add) cmd_add "$@" ;;
    remove) cmd_remove "$@" ;;
    status) cmd_status "$@" ;;
    -h|--help|help) usage ;;
    *) echo "chorus-werk: unknown subcommand '$sub'" >&2; usage >&2; exit 2 ;;
  esac
}

main "$@"
