#!/usr/bin/env bash
# ops-nudge — fire a nudge from operational scripts THROUGH the MCP.
#
# Why this exists: bash `nudge` was retired by #2804 and deleted by #2809.
# The 6 operational health/alert scripts (deep-health, alert-delivery,
# library-health-probe, infra-alert, session-health, health-check-bedroom)
# still need to fire nudges when probes detect issues — they ARE calls to
# action for a role (Jeff 2026-05-08). They need a path that isn't the
# deleted bash wrapper.
#
# #3485 (Jeff 2026-06-18: "all of them must point to mcp"): this no longer
# POSTs pulse directly. It POSTs the mcp-server's /nudge route, which runs
# the SAME executeNudge() the MCP tool uses — the single execution path and
# the only thing that POSTs pulse. One way to call nudge.
#
# Usage:
#   ops-nudge <to> <content> [from]
#
# Examples:
#   ops-nudge silas "deep-health: chorus-api degraded"
#   ops-nudge silas "infra-alert: disk 92%" system
#
# Returns 0 on success, non-zero on MCP rejection or transport error.

set -eo pipefail

TO="${1:-}"
CONTENT="${2:-}"
FROM="${3:-system}"

if [ -z "$TO" ] || [ -z "$CONTENT" ]; then
  echo "usage: ops-nudge <to> <content> [from]" >&2
  exit 1
fi

# The single execution path: the mcp-server /nudge route (loopback :3341).
MCP_NUDGE_URL="${CHORUS_MCP_NUDGE_URL:-http://127.0.0.1:3341/nudge}"

BODY=$(jq -nc --arg from "$FROM" --arg to "$TO" --arg content "$CONTENT" \
  '{from:$from,to:$to,content:$content}')

RESP=$(curl -s --max-time 5 -X POST "$MCP_NUDGE_URL" \
  -H 'Content-Type: application/json' \
  -d "$BODY" 2>&1) || {
    echo "ops-nudge: transport error to $MCP_NUDGE_URL — $RESP" >&2
    exit 2
  }

if ! echo "$RESP" | grep -q '"ok":true'; then
  echo "ops-nudge: mcp rejected — $RESP" >&2
  exit 3
fi
