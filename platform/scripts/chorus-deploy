#!/usr/bin/env bash
# chorus-deploy — building-pipeline deploy step (#2774).
#
# Wraps chorus-bin-install to install signed binaries from target/release/
# into ~/.chorus/bin/, then kickstarts launchd-managed services that depend
# on the deployed binary. Emits one deploy.completed spine event per crate
# with the canonical {commit, crate, cdhash, target} payload.
#
# chorus-build (the pair) produces the artifacts in target/release/ and
# emits build.completed. chorus-deploy picks them up and activates them.
# Both run in the building-pipeline workflow.
#
# Usage:
#   chorus-deploy <chorus-hooks|chorus-inject>
#
# Behavior:
#   1. Resolve crate → binary paths (mirrors build-signed.sh resolve_crate).
#   2. For each binary: chorus-bin-install (atomic mv to ~/.chorus/bin/),
#      which emits binary.deployed.
#   3. Kickstart relevant services (chorus-hooks → com.chorus.hooks).
#   4. Emit deploy.completed per crate.
#
# Exit codes:
#   0   success — installed + kickstarted + emitted.
#   1   deploy-fail (binary missing, install failed, kickstart failed).
#   2   usage error.
#
# Requires: chorus-bin-install, chorus-log (this dir).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Test seam (ADR-032 §1 testability): override the installer/logger so the deploy
# path is exercisable against stubs without touching ~/.chorus/bin or the live spine.
INSTALL="${CHORUS_BIN_INSTALL:-$SCRIPT_DIR/chorus-bin-install}"
CHORUS_LOG="${CHORUS_LOG_BIN:-$SCRIPT_DIR/chorus-log}"
ROOT="${CHORUS_ROOT:-/Users/jeffbridwell/CascadeProjects/chorus}"
ROLE="${DEPLOY_ROLE:-${CHORUS_ROLE:-system}}"
# Extract card_id from commit message (pattern: "role: acp #NNNN"). First match; empty on hand-edited commits.
# `|| true` is required (#2937 AC1): on commits without #NNNN, `grep -oE` exits non-zero, and
# `set -o pipefail` propagates that as the script's exit code, killing the deploy silently.
CARD_ID=$(git -C "$ROOT" log -1 --pretty=%s 2>/dev/null | grep -oE '#[0-9]+' | head -1 | tr -d '#' || true)

# #3222 (#3179 port) / #3250 — enumerate EVERY binary a crate emits, STRUCTURALLY, as
# the UNION of cargo's two default-binary rules: (1) explicit `[[bin]]` entries, and
# (2) `src/bin/*.rs` autobins. Falls back to the package `name` for the simple
# single-binary crate. Replaces the hardcoded per-crate BINARIES arrays, which drifted
# the moment a crate gained a binary nobody updated by hand (the merged≠live class #3179
# fixed in werk-deploy::crate_binaries). #3250: reading ONLY [[bin]] was itself a drift —
# the werk-accept crate declared one [[bin]] but carried werk-do-more.rs + werk-finalize.rs
# in src/bin/; cargo built 3, deploy installed 1, the two verbs went absent from
# ~/.chorus/bin and the next card's finalize step broke. Honor both rules or rule 2 drifts.
crate_binaries() {  # $1 = crate dir → prints one binary name per line (dedup'd)
  local dir="$1" toml="$1/Cargo.toml"
  if [ ! -f "$toml" ]; then
    basename "$dir"
    return
  fi
  # Rule 1: explicit [[bin]] name = ... entries.
  local explicit autobins pkg out=""
  explicit=$(awk '
    /^[[:space:]]*\[\[bin\]\]/ { inbin=1; next }
    /^[[:space:]]*\[/          { inbin=0 }
    inbin && /^[[:space:]]*name[[:space:]]*=/ {
      sub(/^[^=]*=[[:space:]]*"/, ""); sub(/".*/, ""); print
    }' "$toml")
  # Rule 2: src/bin/*.rs autobins — each file is an auto-discovered binary.
  autobins=""
  if [ -d "$dir/src/bin" ]; then
    local f
    for f in "$dir/src/bin/"*.rs; do
      [ -e "$f" ] || continue
      autobins="${autobins}$(basename "$f" .rs)
"
    done
  fi
  # The package default binary (src/main.rs). Cargo emits it when there are no explicit
  # [[bin]] entries; with no [[bin]] AND no autobins we still fall back to the package
  # name (the simple single-binary crate). When autobins exist, the package binary only
  # ships if src/main.rs is actually present.
  pkg=$(awk '
    /^[[:space:]]*\[package\]/ { inpkg=1; next }
    /^[[:space:]]*\[/          { inpkg=0 }
    inpkg && /^[[:space:]]*name[[:space:]]*=/ {
      sub(/^[^=]*=[[:space:]]*"/, ""); sub(/".*/, ""); print; exit
    }' "$toml")
  if [ -n "$explicit" ]; then
    out="${explicit}
"
  elif [ -z "$autobins" ]; then
    out="${pkg}
"
  elif [ -f "$dir/src/main.rs" ]; then
    out="${pkg}
"
  fi
  out="${out}${autobins}"
  # dedup, drop blanks, preserve first-seen order.
  printf '%s\n' "$out" | awk 'NF && !seen[$0]++'
}

# Populate the global BINARIES array from a crate dir (bash-3.2 safe; no mapfile).
set_binaries_from() {  # $1 = crate dir
  BINARIES=()
  local __b
  while IFS= read -r __b; do
    [ -n "$__b" ] && BINARIES+=("$__b")
  done < <(crate_binaries "$1")
}

# #2831 review (Kade): single constant for known crates so Usage line + case
# default don't drift. Add new targets here once.
KNOWN_CRATES="chorus-hooks|chorus-inject|chorus-api|chorus-mcp|werk-pull|werk-commit|werk-push|werk-build|werk-deploy|werk-accept|werk-demo|pulse-gather|pair-heartbeat"

# #2993: gate chorus-api deploy.completed on a real MCP-init smoke. Without
# this gate, `launchctl kickstart -k` returns immediately and deploy.completed
# fires before the new node process has bound + initialized MCP middleware —
# producing a 5-15s window where session-starts get "no session id header"
# failures. Silas's Loki audit: 245 session.principles.stale events/24h, 46%
# concentrated in deploy windows.
#
# Smoke: POST a real JSON-RPC initialize request. Success = the SSE body
# contains "protocolVersion" inside a "result" field — the unambiguous signal
# that the MCP middleware processed the request and answered as a valid server
# (not an error wrapper, not a generic 200 from the wrong handler). Poll at
# 250ms intervals up to CHORUS_MCP_SMOKE_TIMEOUT_S (default 30s).
#
# Override via env for tests; expose the function for the rollback path too.
CHORUS_MCP_SMOKE_TIMEOUT_S="${CHORUS_MCP_SMOKE_TIMEOUT_S:-30}"
# #2998: chorus-api no longer hosts /mcp — MCP lives in chorus-mcp on :3341.
# The chorus-api deploy smoke is now a plain health-check on :3340 (not /mcp);
# the chorus-mcp daemon smoke at :3341/mcp is used only by chorus-deploy's
# chorus-mcp branch. CHORUS_MCP_SMOKE_URL kept as a back-compat alias.
CHORUS_MCP_DAEMON_SMOKE_URL="${CHORUS_MCP_DAEMON_SMOKE_URL:-http://localhost:3341/mcp}"
CHORUS_MCP_SMOKE_URL="${CHORUS_MCP_SMOKE_URL:-$CHORUS_MCP_DAEMON_SMOKE_URL}"
CHORUS_API_HEALTH_URL="${CHORUS_API_HEALTH_URL:-http://localhost:3340/api/chorus/health}"

# #2997: shared smoke routine — takes a URL, polls real MCP initialize until
# protocolVersion comes back in result, or timeout. Used by both chorus-api
# (3340/mcp) and chorus-mcp (3341/mcp) deploy paths.
wait_for_mcp_ready_at() {
  local url="$1"
  local deadline=$(( $(date +%s) + CHORUS_MCP_SMOKE_TIMEOUT_S ))
  local body='{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2024-11-05","capabilities":{},"clientInfo":{"name":"chorus-deploy-smoke","version":"1.0"}}}'
  while [ "$(date +%s)" -lt "$deadline" ]; do
    if curl -s -m 2 -X POST "$url" \
        -H 'Accept: application/json, text/event-stream' \
        -H 'Content-Type: application/json' \
        -d "$body" 2>/dev/null \
        | python3 -c '
import json, sys
for line in sys.stdin:
    if line.startswith("data:"):
        try:
            d = json.loads(line[5:].strip())
            if d.get("result", {}).get("protocolVersion"):
                sys.exit(0)
        except Exception:
            pass
sys.exit(1)
' 2>/dev/null; then
      return 0
    fi
    sleep 0.25
  done
  return 1
}

# #2998: chorus-api no longer serves /mcp — the deploy smoke for chorus-api is
# now a plain health-check on :3340/api/chorus/health, not an MCP initialize.
# The MCP daemon smoke (wait_for_mcp_ready_at) is used only for the chorus-mcp
# crate's deploy path.
wait_for_chorus_api_mcp_ready() {
  local deadline=$(( $(date +%s) + CHORUS_MCP_SMOKE_TIMEOUT_S ))
  while [ "$(date +%s)" -lt "$deadline" ]; do
    if curl -s -m 2 "$CHORUS_API_HEALTH_URL" 2>/dev/null | grep -q '"status":"healthy"'; then
      return 0
    fi
    sleep 0.25
  done
  return 1
}

# #3232 — verify a kickstarted daemon is actually RUNNING (and, for chorus-hooks, that its
# socket is live), polling with bounded retries. `launchctl kickstart` returns before the
# daemon binds, so a crash-on-start otherwise ships green; this is the rust-daemon analogue
# of chorus-api's self-smoke. Retries/delay are env-overridable for tests. Returns 0 once
# up, 1 if it never comes up within the budget.
verify_service_running() {  # $1 = launchd label
  local label="$1"
  local retries="${CHORUS_DEPLOY_VERIFY_RETRIES:-20}"
  local delay="${CHORUS_DEPLOY_VERIFY_DELAY:-0.5}"
  local i=0
  while [ "$i" -lt "$retries" ]; do
    if launchctl print "gui/$(id -u)/$label" 2>/dev/null | grep -q "state = running"; then
      if [ "$label" = "com.chorus.hooks" ]; then
        # the daemon is only truly up once its socket is bound (the liveness the
        # 2026-06-04 outage lacked — launchctl said loaded, socket was gone).
        local sock="${CHORUS_HOOKS_SOCK:-/tmp/chorus-hooks.sock}"
        if [ -S "$sock" ] || [ -e "$sock" ]; then return 0; fi
      else
        return 0
      fi
    fi
    i=$((i + 1))
    sleep "$delay" 2>/dev/null || true
  done
  return 1
}

# #2995 — --target werk|canonical. canonical (default) preserves the existing
# behavior: install to ~/.chorus/bin/ + kickstart the daemon. werk installs
# to $WERK_<ROLE>_BIN (the role's per-werk slot) and skips kickstart — the
# role's session resolves the new binary via PATH-prefix, no daemon restart
# needed. /acp's promote step (chorus_acp MCP) moves the werk slot's contents
# into canonical and fires the kickstart at acceptance time.
DEPLOY_TARGET="canonical"
PARSED_ARGS=()
while [ $# -gt 0 ]; do
  case "$1" in
    --target)
      DEPLOY_TARGET="${2:-}"
      case "$DEPLOY_TARGET" in
        werk|canonical) ;;
        *) echo "chorus-deploy: --target must be 'werk' or 'canonical' (got '$DEPLOY_TARGET')" >&2; exit 2 ;;
      esac
      shift 2
      ;;
    *)
      PARSED_ARGS+=("$1")
      shift
      ;;
  esac
done
set -- "${PARSED_ARGS[@]+"${PARSED_ARGS[@]}"}"

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
  echo "Usage: chorus-deploy [--target werk|canonical] <${KNOWN_CRATES}> [--rollback]" >&2
  exit 2
fi

CRATE="$1"
MODE="${2:-deploy}"

# #3181 — canonical build-source must be synced BEFORE building. chorus-deploy builds
# from $ROOT's HEAD; when $ROOT is canonical (not a per-card werk), fast-forward it to
# origin/main first, so a "merged" fix is never built from a stale canonical. This was
# the merged≠live engine: canonical sat 13 commits behind all of 2026-06-01 and a
# `chorus-deploy chorus-mcp` shipped a daemon missing the merged werk-* tool renames
# while reporting success. A werk-sourced build ($ROOT under chorus-werk) builds from
# the werk, so canonical sync is N/A and skipped. The guard no-ops when $ROOT has no
# git / no origin/main ref (can't determine sync state → don't block). Refuses rather
# than force-sync when canonical can't ff cleanly (ahead/diverged/dirty).
if [ "$MODE" != "--rollback" ]; then
  case "$ROOT" in
    *chorus-werk/*) : ;;  # werk-sourced build — canonical sync N/A
    *)
      if git -C "$ROOT" rev-parse --git-dir >/dev/null 2>&1; then
        git -C "$ROOT" fetch -q origin main 2>/dev/null || true
        if git -C "$ROOT" rev-parse --verify -q origin/main >/dev/null 2>&1; then
          behind=$(git -C "$ROOT" rev-list --count HEAD..origin/main 2>/dev/null || echo 0)
          if [ "${behind:-0}" -gt 0 ]; then
            ahead=$(git -C "$ROOT" rev-list --count origin/main..HEAD 2>/dev/null || echo 0)
            dirty=$(git -C "$ROOT" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
            if [ "${ahead:-0}" -gt 0 ] || [ "${dirty:-0}" -gt 0 ]; then
              echo "chorus-deploy: REFUSING — canonical is $behind behind origin/main but can't ff cleanly (ahead=$ahead, dirty=$dirty file(s)). Run 'chorus-werk-sync recover', then re-deploy." >&2
              exit 1
            fi
            echo "chorus-deploy: canonical $behind behind origin/main — fast-forwarding before build (#3181)"
            if ! git -C "$ROOT" merge --ff-only origin/main >/dev/null 2>&1; then
              echo "chorus-deploy: REFUSING — ff to origin/main failed; run 'chorus-werk-sync recover'." >&2
              exit 1
            fi
          fi
        fi
      fi
      ;;
  esac
fi

# #3110: chorus-deploy --all werk — build + deploy all 7 verb binaries in one
# call. Retires install-werk-verbs.sh as the parallel orchestrator. Each verb
# goes through chorus-build then chorus-deploy in sequence; failure of one
# does not stop the others (collected and reported at end). Handled BEFORE the
# MODE check below because MODE="werk" wouldn't match deploy/--rollback.
if [ "$CRATE" = "--all" ] && [ "$MODE" = "werk" ]; then
  WERK_VERBS=(werk-pull werk-commit werk-push werk-build werk-deploy werk-accept werk-demo pulse-gather pair-heartbeat)
  failed=()
  for v in "${WERK_VERBS[@]}"; do
    crate_dir="$ROOT/platform/services/$v"
    if [ ! -f "$crate_dir/Cargo.toml" ]; then
      echo "  ✗ $v: no crate at $crate_dir/Cargo.toml — skipping"
      failed+=("$v:missing")
      continue
    fi
    echo "  → building $v..."
    if ! cargo build --release --quiet --manifest-path "$crate_dir/Cargo.toml"; then
      echo "  ✗ $v: cargo build failed"
      failed+=("$v:build")
      continue
    fi
    echo "  → deploying $v..."
    if ! "$0" ${DEPLOY_TARGET:+--target $DEPLOY_TARGET} "$v"; then
      echo "  ✗ $v: chorus-deploy failed"
      failed+=("$v:deploy")
      continue
    fi
  done
  if [ ${#failed[@]} -gt 0 ]; then
    echo
    echo "chorus-deploy --all werk: FAILED — ${failed[*]}"
    exit 1
  fi
  echo
  echo "chorus-deploy --all werk: ${#WERK_VERBS[@]}/${#WERK_VERBS[@]} verbs built + installed."
  exit 0
fi

if [ "$MODE" != "deploy" ] && [ "$MODE" != "--rollback" ]; then
  echo "Usage: chorus-deploy [--target werk|canonical] <${KNOWN_CRATES}> [--rollback]" >&2
  echo "       chorus-deploy --all werk    # build + deploy all 7 verb binaries" >&2
  exit 2
fi

# #3016 — chorus-mcp now supports --target werk (per-werk launchd daemon on a
# deterministic per-role port; the chorus-mcp branch below handles it). chorus-api
# still doesn't (no per-session endpoint resolution wired for :3340 yet) — refuse
# loudly for it rather than silently dropping the request.
if [ "$DEPLOY_TARGET" = "werk" ] && [ "$CRATE" = "chorus-api" ]; then
  echo "chorus-deploy: --target werk is not yet supported for chorus-api (only chorus-mcp among TS daemons, plus Rust crates chorus-hooks/chorus-inject). File a follow-on if needed." >&2
  exit 2
fi

# #2831: chorus-api is TS, not a Rust crate. Different deploy mechanic — build
# dist via npm + kickstart launchd service. Branched early because the rest of
# the script is structured around target/release/ binaries and chorus-bin-install.
# #2925 AC4: --rollback restores dist/ from dist.prev/ (preserved at each deploy).
if [ "$CRATE" = "chorus-api" ]; then
  COMMIT=$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null || echo "unknown")
  START_TS=$(date +%s)
  API_DIR="$ROOT/platform/api"
  if [ ! -d "$API_DIR" ]; then
    echo "chorus-deploy: chorus-api dir not found at $API_DIR" >&2
    exit 1
  fi

  if [ "$MODE" = "--rollback" ]; then
    # #2925 AC4: one-shot rollback to prior deployed dist/.
    PREV_DIR="$API_DIR/dist.prev"
    if [ ! -d "$PREV_DIR" ]; then
      echo "chorus-deploy: no dist.prev to rollback to ($PREV_DIR not found) — no prior deploy to restore" >&2
      exit 1
    fi
    rm -rf "$API_DIR/dist"
    mv "$PREV_DIR" "$API_DIR/dist"
    if ! launchctl kickstart -k "gui/$(id -u)/com.chorus.api" 2>/dev/null; then
      echo "chorus-deploy: WARN — launchctl kickstart com.chorus.api failed during rollback" >&2
    else
      echo "chorus-deploy: kickstarted com.chorus.api (rollback)"
    fi
    # #2993: rollback also waits for MCP smoke before declaring success. Same
    # deploy.completed-lies-during-gap failure mode applies to rollback restarts.
    echo "chorus-deploy: waiting for chorus-api MCP smoke (rollback, deadline ${CHORUS_MCP_SMOKE_TIMEOUT_S}s)"
    if ! wait_for_chorus_api_mcp_ready; then
      END_TS=$(date +%s)
      DURATION_MS=$(( (END_TS - START_TS) * 1000 ))
      if [ -x "$CHORUS_LOG" ]; then
        "$CHORUS_LOG" deploy.failed "$ROLE" \
          "commit=$COMMIT" "crate=$CRATE" "duration_ms=$DURATION_MS" \
          "reason=mcp-smoke-timeout-rollback" "card=$CARD_ID" >/dev/null 2>&1 || true
      fi
      echo "chorus-deploy: $CRATE rollback MCP smoke timed out after ${CHORUS_MCP_SMOKE_TIMEOUT_S}s" >&2
      exit 1
    fi
    END_TS=$(date +%s)
    DURATION_MS=$(( (END_TS - START_TS) * 1000 ))
    if [ -x "$CHORUS_LOG" ]; then
      "$CHORUS_LOG" deploy.rolled_back "$ROLE" \
        "commit=$COMMIT" "crate=$CRATE" "duration_ms=$DURATION_MS" "card=$CARD_ID" \
        >/dev/null 2>&1 || true
    fi
    echo "chorus-deploy: $CRATE rolled back in ${DURATION_MS}ms"
    exit 0
  fi

  # #2925 AC4: preserve current dist/ as dist.prev/ before rebuild so rollback
  # has a target. atomic mv; rm any stale dist.prev first.
  if [ -d "$API_DIR/dist" ]; then
    rm -rf "$API_DIR/dist.prev"
    mv "$API_DIR/dist" "$API_DIR/dist.prev"
  fi
  echo "chorus-deploy: npm run build in $API_DIR"
  if ! (cd "$API_DIR" && npm run build); then
    echo "chorus-deploy: npm run build failed" >&2
    # Restore dist from dist.prev so disk state stays consistent — service is
    # still running prior code in memory, so disk should match.
    if [ -d "$API_DIR/dist.prev" ]; then
      rm -rf "$API_DIR/dist"
      mv "$API_DIR/dist.prev" "$API_DIR/dist"
    fi
    if [ -x "$CHORUS_LOG" ]; then
      END_TS=$(date +%s)
      DURATION_MS=$(( (END_TS - START_TS) * 1000 ))
      "$CHORUS_LOG" deploy.failed "$ROLE" \
        "commit=$COMMIT" "crate=$CRATE" "duration_ms=$DURATION_MS" \
        "reason=npm-build-fail" "card=$CARD_ID" >/dev/null 2>&1 || true
    fi
    exit 1
  fi
  if ! launchctl kickstart -k "gui/$(id -u)/com.chorus.api" 2>/dev/null; then
    echo "chorus-deploy: WARN — launchctl kickstart com.chorus.api failed" >&2
  else
    echo "chorus-deploy: kickstarted com.chorus.api"
  fi
  # #2993: wait for the new node process to bind and initialize MCP middleware
  # before declaring deploy.completed. Without this gate the spine claims the
  # API is ready while session-starts in the gap window get "no session id
  # header" failures. Smoke timeout → emit deploy.failed instead.
  echo "chorus-deploy: waiting for chorus-api MCP smoke (deadline ${CHORUS_MCP_SMOKE_TIMEOUT_S}s)"
  if ! wait_for_chorus_api_mcp_ready; then
    END_TS=$(date +%s)
    DURATION_MS=$(( (END_TS - START_TS) * 1000 ))
    if [ -x "$CHORUS_LOG" ]; then
      "$CHORUS_LOG" deploy.failed "$ROLE" \
        "commit=$COMMIT" "crate=$CRATE" "duration_ms=$DURATION_MS" \
        "reason=mcp-smoke-timeout" "card=$CARD_ID" >/dev/null 2>&1 || true
    fi
    echo "chorus-deploy: $CRATE MCP smoke timed out after ${CHORUS_MCP_SMOKE_TIMEOUT_S}s — deploy.failed emitted" >&2
    exit 1
  fi
  END_TS=$(date +%s)
  DURATION_MS=$(( (END_TS - START_TS) * 1000 ))
  if [ -x "$CHORUS_LOG" ]; then
    "$CHORUS_LOG" deploy.completed "$ROLE" \
      "commit=$COMMIT" "crate=$CRATE" "target=$API_DIR/dist/server.js" "duration_ms=$DURATION_MS" "card=$CARD_ID" \
      >/dev/null 2>&1 || true
  fi
  echo "chorus-deploy: $CRATE deployed in ${DURATION_MS}ms (commit=$COMMIT)"
  exit 0
fi

# #2997: chorus-mcp is the second TS daemon, sibling to chorus-api. Same shape
# as the chorus-api branch above (npm build + dist swap + kickstart + MCP-smoke
# gate), targeting :3341 instead of :3340. Decouples MCP from chorus-api's
# deploy lifecycle so chorus-api redeploys no longer kill role-session MCP
# transports (the daily-failure-class Jeff named 2026-05-18).
if [ "$CRATE" = "chorus-mcp" ]; then
  COMMIT=$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null || echo "unknown")
  START_TS=$(date +%s)
  MCP_DIR="$ROOT/platform/mcp-server"
  if [ ! -d "$MCP_DIR" ]; then
    echo "chorus-deploy: chorus-mcp dir not found at $MCP_DIR" >&2
    exit 1
  fi

  # #3016 — --target werk: build the werk's dist and run a SEPARATE chorus-mcp
  # as a per-werk launchd agent on a deterministic per-role port. The role's
  # session resolves this port via CHORUS_MCP_PORT (chorus-env-setup.sh) +
  # .mcp.json url interpolation. Canonical :3341 is NOT touched — other roles
  # stay on it. launchd-managed (not a raw background PID) so teardown is
  # `launchctl bootout`, never a kill (no-raw-kill rule). /acp promotes (stop
  # werk daemon → canonical dist-swap + kickstart :3341); /unpull tears down.
  if [ "$DEPLOY_TARGET" = "werk" ]; then
    case "$ROLE" in
      silas) WERK_PORT=3351 ;;
      kade)  WERK_PORT=3352 ;;
      wren)  WERK_PORT=3353 ;;
      *) echo "chorus-deploy: --target werk chorus-mcp needs a role (DEPLOY_ROLE/CHORUS_ROLE), got '$ROLE'" >&2; exit 2 ;;
    esac
    LABEL="com.chorus.mcp.werk.$ROLE"
    PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
    MARKER_DIR="$ROOT/.werk-mcp"
    NODE_BIN="$(command -v node)"
    echo "chorus-deploy: npm run build in $MCP_DIR (werk)"
    if ! (cd "$MCP_DIR" && npm run build); then
      echo "chorus-deploy: npm run build failed (werk)" >&2
      [ -x "$CHORUS_LOG" ] && "$CHORUS_LOG" deploy.failed "$ROLE" "commit=$COMMIT" "crate=$CRATE" "deploy_target=werk" "reason=npm-build-fail-werk" "card=$CARD_ID" >/dev/null 2>&1 || true
      exit 1
    fi
    mkdir -p "$MARKER_DIR"
    # Generate the per-werk LaunchAgent. WorkingDirectory = werk mcp-server so it
    # runs the werk's freshly-built dist; CHORUS_MCP_PORT pins the werk port.
    cat > "$PLIST" <<PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>$NODE_BIN</string>
    <string>$MCP_DIR/dist/main.js</string>
  </array>
  <key>WorkingDirectory</key><string>$MCP_DIR</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>CHORUS_MCP_PORT</key><string>$WERK_PORT</string>
    <key>CHORUS_ROOT</key><string>$ROOT</string>
    <key>CHORUS_ROLE</key><string>$ROLE</string>
  </dict>
  <key>RunAtLoad</key><true/>
  <key>StandardOutPath</key><string>$MARKER_DIR/daemon.log</string>
  <key>StandardErrorPath</key><string>$MARKER_DIR/daemon.log</string>
</dict>
</plist>
PLIST_EOF
    # Reload cleanly: bootout any prior instance, then bootstrap fresh.
    launchctl bootout "gui/$(id -u)/$LABEL" 2>/dev/null || true
    if ! launchctl bootstrap "gui/$(id -u)" "$PLIST" 2>/dev/null; then
      launchctl kickstart -k "gui/$(id -u)/$LABEL" 2>/dev/null || true
    fi
    echo "chorus-deploy: bootstrapped $LABEL on port $WERK_PORT"
    echo "chorus-deploy: waiting for werk chorus-mcp smoke at :$WERK_PORT (deadline ${CHORUS_MCP_SMOKE_TIMEOUT_S}s)"
    if ! wait_for_mcp_ready_at "http://localhost:$WERK_PORT/mcp"; then
      echo "chorus-deploy: werk chorus-mcp smoke timed out at :$WERK_PORT" >&2
      [ -x "$CHORUS_LOG" ] && "$CHORUS_LOG" deploy.failed "$ROLE" "commit=$COMMIT" "crate=$CRATE" "deploy_target=werk" "reason=werk-mcp-smoke-timeout" "card=$CARD_ID" >/dev/null 2>&1 || true
      exit 1
    fi
    # Marker: env-setup reads .werk-mcp/active to switch the session's
    # CHORUS_MCP_PORT to this werk daemon. Record port + label for teardown.
    printf '%s' "$WERK_PORT" > "$MARKER_DIR/port"
    printf '%s' "$LABEL" > "$MARKER_DIR/label"
    : > "$MARKER_DIR/active"
    END_TS=$(date +%s)
    DURATION_MS=$(( (END_TS - START_TS) * 1000 ))
    if [ -x "$CHORUS_LOG" ]; then
      "$CHORUS_LOG" deploy.completed "$ROLE" \
        "commit=$COMMIT" "crate=$CRATE" "target=$MCP_DIR/dist/main.js" \
        "deploy_target=werk" "port=$WERK_PORT" "duration_ms=$DURATION_MS" "card=$CARD_ID" \
        >/dev/null 2>&1 || true
    fi
    echo "chorus-deploy: $CRATE deployed to werk in ${DURATION_MS}ms (port=$WERK_PORT label=$LABEL) — /reboot this session to pick up CHORUS_MCP_PORT"
    exit 0
  fi

  if [ "$MODE" = "--rollback" ]; then
    PREV_DIR="$MCP_DIR/dist.prev"
    if [ ! -d "$PREV_DIR" ]; then
      echo "chorus-deploy: no dist.prev to rollback to ($PREV_DIR not found)" >&2
      exit 1
    fi
    rm -rf "$MCP_DIR/dist"
    mv "$PREV_DIR" "$MCP_DIR/dist"
    if ! launchctl kickstart -k "gui/$(id -u)/com.chorus.mcp" 2>/dev/null; then
      echo "chorus-deploy: WARN — launchctl kickstart com.chorus.mcp failed during rollback" >&2
    else
      echo "chorus-deploy: kickstarted com.chorus.mcp (rollback)"
    fi
    echo "chorus-deploy: waiting for chorus-mcp smoke (rollback, deadline ${CHORUS_MCP_SMOKE_TIMEOUT_S}s)"
    if ! wait_for_mcp_ready_at "$CHORUS_MCP_DAEMON_SMOKE_URL"; then
      END_TS=$(date +%s)
      DURATION_MS=$(( (END_TS - START_TS) * 1000 ))
      if [ -x "$CHORUS_LOG" ]; then
        "$CHORUS_LOG" deploy.failed "$ROLE" \
          "commit=$COMMIT" "crate=$CRATE" "duration_ms=$DURATION_MS" \
          "reason=mcp-smoke-timeout-rollback" "card=$CARD_ID" >/dev/null 2>&1 || true
      fi
      echo "chorus-deploy: $CRATE rollback MCP smoke timed out after ${CHORUS_MCP_SMOKE_TIMEOUT_S}s" >&2
      exit 1
    fi
    END_TS=$(date +%s)
    DURATION_MS=$(( (END_TS - START_TS) * 1000 ))
    if [ -x "$CHORUS_LOG" ]; then
      "$CHORUS_LOG" deploy.rolled_back "$ROLE" \
        "commit=$COMMIT" "crate=$CRATE" "duration_ms=$DURATION_MS" "card=$CARD_ID" \
        >/dev/null 2>&1 || true
    fi
    echo "chorus-deploy: $CRATE rolled back in ${DURATION_MS}ms"
    exit 0
  fi

  if [ -d "$MCP_DIR/dist" ]; then
    rm -rf "$MCP_DIR/dist.prev"
    mv "$MCP_DIR/dist" "$MCP_DIR/dist.prev"
  fi
  echo "chorus-deploy: npm run build in $MCP_DIR"
  if ! (cd "$MCP_DIR" && npm run build); then
    echo "chorus-deploy: npm run build failed" >&2
    if [ -d "$MCP_DIR/dist.prev" ]; then
      rm -rf "$MCP_DIR/dist"
      mv "$MCP_DIR/dist.prev" "$MCP_DIR/dist"
    fi
    if [ -x "$CHORUS_LOG" ]; then
      END_TS=$(date +%s)
      DURATION_MS=$(( (END_TS - START_TS) * 1000 ))
      "$CHORUS_LOG" deploy.failed "$ROLE" \
        "commit=$COMMIT" "crate=$CRATE" "duration_ms=$DURATION_MS" \
        "reason=npm-build-fail" "card=$CARD_ID" >/dev/null 2>&1 || true
    fi
    exit 1
  fi
  if ! launchctl kickstart -k "gui/$(id -u)/com.chorus.mcp" 2>/dev/null; then
    echo "chorus-deploy: WARN — launchctl kickstart com.chorus.mcp failed" >&2
  else
    echo "chorus-deploy: kickstarted com.chorus.mcp"
  fi
  echo "chorus-deploy: waiting for chorus-mcp smoke (deadline ${CHORUS_MCP_SMOKE_TIMEOUT_S}s)"
  if ! wait_for_mcp_ready_at "$CHORUS_MCP_DAEMON_SMOKE_URL"; then
    END_TS=$(date +%s)
    DURATION_MS=$(( (END_TS - START_TS) * 1000 ))
    if [ -x "$CHORUS_LOG" ]; then
      "$CHORUS_LOG" deploy.failed "$ROLE" \
        "commit=$COMMIT" "crate=$CRATE" "duration_ms=$DURATION_MS" \
        "reason=mcp-smoke-timeout" "card=$CARD_ID" >/dev/null 2>&1 || true
    fi
    echo "chorus-deploy: $CRATE MCP smoke timed out after ${CHORUS_MCP_SMOKE_TIMEOUT_S}s — deploy.failed emitted" >&2
    exit 1
  fi
  END_TS=$(date +%s)
  DURATION_MS=$(( (END_TS - START_TS) * 1000 ))
  if [ -x "$CHORUS_LOG" ]; then
    "$CHORUS_LOG" deploy.completed "$ROLE" \
      "commit=$COMMIT" "crate=$CRATE" "target=$MCP_DIR/dist/main.js" "duration_ms=$DURATION_MS" "card=$CARD_ID" \
      >/dev/null 2>&1 || true
  fi
  echo "chorus-deploy: $CRATE deployed in ${DURATION_MS}ms (commit=$COMMIT)"
  exit 0
fi

case "$CRATE" in
  chorus-hooks)
    CRATE_DIR="$ROOT/platform/services/chorus-hooks"
    set_binaries_from "$CRATE_DIR"   # #3222: structural — daemon + shim, from Cargo.toml
    KICKSTART_SERVICE="com.chorus.hooks"
    ;;
  chorus-inject)
    CRATE_DIR="$ROOT/platform/services/chorus-inject"
    set_binaries_from "$CRATE_DIR"   # #3222: structural
    KICKSTART_SERVICE=""  # spawn-on-demand by pulse worker; no daemon
    ;;
  werk-pull|werk-commit|werk-push|werk-build|werk-deploy|werk-accept|werk-demo|pulse-gather|pair-heartbeat)
    # #3110: chorus-deploy absorbs the werk-* verb-binary install path
    # (#3205: pulse-gather joins them — same single-bin verb-crate shape, installs
    # as a role-slot-routed CLI binary, no daemon. It is the loom-gather verb that
    # gemba + pair poll.)
    # (retiring install-werk-verbs.sh as a parallel-implementation violation
    # of chorus:principle-no-competing-implementations). CLI verbs — no
    # service, no kickstart. The binary installs to ~/.chorus/bin/<verb>-bin
    # with a role-slot-routing wrapper at ~/.chorus/bin/<verb> (per #3101).
    CRATE_DIR="$ROOT/platform/services/$CRATE"
    set_binaries_from "$CRATE_DIR"   # #3222: structural (single-bin verb crate)
    KICKSTART_SERVICE=""  # CLI verb, no daemon
    INSTALL_AS_WRAPPER=1   # post-install: write wrapper, install raw as -bin
    ;;
  *)
    echo "chorus-deploy: unknown crate '$CRATE' (known: ${KNOWN_CRATES})" >&2
    exit 2
    ;;
esac

COMMIT=$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null || echo "unknown")
START_TS=$(date +%s)

# Helper: emit deploy.failed with reason (#2774 review — typed outcome events).
emit_deploy_failed() {
  local reason="$1"
  local end_ts=$(date +%s)
  local duration_ms=$(( (end_ts - START_TS) * 1000 ))
  if [ -x "$CHORUS_LOG" ]; then
    "$CHORUS_LOG" deploy.failed "$ROLE" \
      "commit=$COMMIT" "crate=$CRATE" "duration_ms=$duration_ms" \
      "reason=$reason" "card=$CARD_ID" >/dev/null 2>&1 || true
  fi
}

if [ ! -x "$INSTALL" ]; then
  echo "chorus-deploy: chorus-bin-install not executable at $INSTALL" >&2
  emit_deploy_failed "install-script-missing"
  exit 1
fi

# Install each binary. chorus-bin-install emits binary.deployed per binary.
# #2995 — target=werk → pass --target werk to chorus-bin-install (installs to
# the role's per-werk bin slot) and skip kickstart (session PATH-prefix
# resolves the new binary without a daemon restart).
INSTALLED_CDHASH=""
INSTALL_TARGET_FLAGS=()
if [ "$DEPLOY_TARGET" = "werk" ]; then
  INSTALL_TARGET_FLAGS=(--target werk)
fi
for bin in "${BINARIES[@]}"; do
  src="$CRATE_DIR/target/release/$bin"
  if [ ! -f "$src" ]; then
    echo "chorus-deploy: binary missing — run chorus-build $CRATE first ($src)" >&2
    emit_deploy_failed "binary-missing"
    exit 1
  fi
  # #3110: werk-* verbs install raw binary as `<verb>-bin` so the role-slot
  # routing wrapper (written below) can live at `<verb>`. Service binaries
  # install as their plain name (legacy path, unchanged).
  install_name="$bin"
  if [ "${INSTALL_AS_WRAPPER:-0}" = "1" ]; then
    install_name="${bin}-bin"
  fi
  if ! "$INSTALL" ${INSTALL_TARGET_FLAGS[@]+"${INSTALL_TARGET_FLAGS[@]}"} "$src" "$install_name"; then
    echo "chorus-deploy: install failed for $install_name" >&2
    emit_deploy_failed "install-fail"
    exit 1
  fi
  # Capture cdhash from the deployed binary (last one wins; primary recorded
  # for the spine event payload). #2995: resolve install dir to match target.
  if command -v codesign >/dev/null 2>&1; then
    if [ "$DEPLOY_TARGET" = "werk" ]; then
      case "$ROLE" in
        kade)  __cdh_dir="${WERK_KADE_BIN:-}"  ;;
        wren)  __cdh_dir="${WERK_WREN_BIN:-}"  ;;
        silas) __cdh_dir="${WERK_SILAS_BIN:-}" ;;
        *)     __cdh_dir=""                    ;;
      esac
    else
      __cdh_dir="$HOME/.chorus/bin"
    fi
    if [ -n "$__cdh_dir" ]; then
      INSTALLED_CDHASH=$(codesign -dvvv "$__cdh_dir/$install_name" 2>&1 | grep "^CDHash=" | head -1 | sed 's/^CDHash=//')
      # #3222 (AC4 / #3132) — content gate: the INSTALLED binary's cdhash MUST equal
      # the BUILT binary's cdhash. Never trust the deploy self-report; verify by
      # content so a stale/corrupt install (rebuild didn't take, partial move) can't
      # ship green. Canonical (prod) only — a werk-slot install is isolated, no live
      # service to protect. Mirrors werk-deploy's canonical-only cdhash verify, so the
      # converge-on-chorus-deploy path keeps the same guarantee.
      if [ "$DEPLOY_TARGET" = "canonical" ]; then
        __built_cdhash=$(codesign -dvvv "$src" 2>&1 | grep "^CDHash=" | head -1 | sed 's/^CDHash=//')
        if [ -z "$INSTALLED_CDHASH" ] || [ "$__built_cdhash" != "$INSTALLED_CDHASH" ]; then
          echo "chorus-deploy: VERIFY FAILED for $install_name — built=${__built_cdhash:-<none>} installed=${INSTALLED_CDHASH:-<none>} (stale/corrupt install; refusing)" >&2
          emit_deploy_failed "cdhash-mismatch"
          exit 1
        fi
        echo "chorus-deploy: verified $install_name (built==installed cdhash=$INSTALLED_CDHASH)"
      fi
    fi
  fi
done

# #3110: write the role-slot-routing wrapper for werk-* verb binaries.
# Wrapper lives at ~/.chorus/bin/<verb>; exec's the role's WERK_<ROLE>_BIN/<verb>
# if present (so a demo-er's session uses their freshly-built variant mid-demo),
# else falls through to ~/.chorus/bin/<verb>-bin. Mirrors install-werk-verbs.sh
# lines 60-77, which this case now retires. Service binaries skip this block
# (INSTALL_AS_WRAPPER unset).
if [ "${INSTALL_AS_WRAPPER:-0}" = "1" ]; then
  if [ "$DEPLOY_TARGET" = "werk" ]; then
    case "$ROLE" in
      kade)  __wrap_dir="${WERK_KADE_BIN:-}"  ;;
      wren)  __wrap_dir="${WERK_WREN_BIN:-}"  ;;
      silas) __wrap_dir="${WERK_SILAS_BIN:-}" ;;
      *)     __wrap_dir=""                    ;;
    esac
  else
    __wrap_dir="$HOME/.chorus/bin"
  fi
  if [ -n "$__wrap_dir" ]; then
    for bin in "${BINARIES[@]}"; do
      cat > "$__wrap_dir/$bin" <<WRAPPER_EOF
#!/bin/sh
# Auto-generated by chorus-deploy (#3110). Routes to role-slot first, then
# canonical. Edit chorus-deploy's TEMPLATE; manual edits here get overwritten.
case "\${CHORUS_ROLE:-}" in
  silas) slot="\${WERK_SILAS_BIN:-}/$bin" ;;
  wren)  slot="\${WERK_WREN_BIN:-}/$bin" ;;
  kade)  slot="\${WERK_KADE_BIN:-}/$bin" ;;
  *)     slot="" ;;
esac
if [ -n "\$slot" ] && [ -x "\$slot" ]; then
  exec "\$slot" "\$@"
fi
exec "$__wrap_dir/${bin}-bin" "\$@"
WRAPPER_EOF
      chmod +x "$__wrap_dir/$bin"
    done
  fi

  # #3110 AC6: orphan-sweep. Pre-#3110 deploys wrote raw werk-* binaries
  # straight into peer overlay dirs (chorus-werk/<role>-bin/). Once the
  # wrapper convention shipped, those raw files mask the canonical binary
  # because the wrapper routes role-slot-first. On every canonical werk-*
  # deploy, sweep the three overlay dirs and remove any non-wrapper file
  # at <verb> for the verbs we just installed. Wrapper recognized by the
  # "Auto-generated by chorus-deploy" marker on line 2; anything else
  # under that name is orphan from before the convention.
  if [ "$DEPLOY_TARGET" = "canonical" ]; then
    __sweep_base="${CHORUS_WERK_BASE:-$HOME/CascadeProjects/chorus-werk}"
    for __peer in silas-bin wren-bin kade-bin; do
      __peer_dir="$__sweep_base/$__peer"
      [ -d "$__peer_dir" ] || continue
      for bin in "${BINARIES[@]}"; do
        __peer_file="$__peer_dir/$bin"
        [ -e "$__peer_file" ] || continue
        if ! head -2 "$__peer_file" 2>/dev/null | grep -q "Auto-generated by chorus-deploy"; then
          rm -f "$__peer_file" && echo "chorus-deploy: swept orphan $__peer_file (pre-#3110 raw binary)"
        fi
      done
    done
  fi
fi

# #2823: kickstart the launchd-managed service after atomic mv. Skipped on
# --target werk (#2995): the binary lives in the role's per-werk slot and is
# resolved via session PATH-prefix; canonical-bound daemons keep running the
# pre-werk-build canonical binary, undisturbed. Kickstart fires at /acp's
# promote step instead, when the werk slot is moved into canonical.
if [ "$DEPLOY_TARGET" = "canonical" ] && [ -n "$KICKSTART_SERVICE" ]; then
  if ! launchctl kickstart -k "gui/$(id -u)/$KICKSTART_SERVICE" 2>/dev/null; then
    echo "chorus-deploy: WARN — launchctl kickstart $KICKSTART_SERVICE returned non-zero; verifying liveness anyway" >&2
  fi
  # #3232 — VERIFY the daemon actually came UP (launchctl running + socket live), retry,
  # and FAIL LOUD if it never does. `launchctl kickstart` returns BEFORE the daemon binds
  # its socket, so a crash-on-start (or a binary that loads but never serves) shipped green
  # while the service was down — the 2026-06-04 chorus-hooks outage (all guards offline
  # team-wide). chorus-api already self-smokes; this gives the rust daemon the same gate.
  if verify_service_running "$KICKSTART_SERVICE"; then
    echo "chorus-deploy: verified $KICKSTART_SERVICE running"
  else
    echo "chorus-deploy: FATAL — $KICKSTART_SERVICE did not come up running after deploy (service not running / socket not live)" >&2
    emit_deploy_failed "not-running"
    exit 1
  fi
elif [ "$DEPLOY_TARGET" = "werk" ]; then
  echo "chorus-deploy: target=werk — skipped kickstart of ${KICKSTART_SERVICE:-<none>}; role session PATH-prefix resolves the new binary"
fi

# deploy.completed spine event per crate. target field distinguishes werk
# (preview-in-session) from canonical (production-bound).
END_TS=$(date +%s)
DURATION_MS=$(( (END_TS - START_TS) * 1000 ))
if [ "$DEPLOY_TARGET" = "werk" ]; then
  case "$ROLE" in
    kade)  TARGET="${WERK_KADE_BIN:-}/${BINARIES[0]}"  ;;
    wren)  TARGET="${WERK_WREN_BIN:-}/${BINARIES[0]}"  ;;
    silas) TARGET="${WERK_SILAS_BIN:-}/${BINARIES[0]}" ;;
    *)     TARGET="<unknown-role>/${BINARIES[0]}"      ;;
  esac
else
  TARGET="$HOME/.chorus/bin/${BINARIES[0]}"
fi

if [ -x "$CHORUS_LOG" ]; then
  "$CHORUS_LOG" deploy.completed "$ROLE" \
    "commit=$COMMIT" "crate=$CRATE" "cdhash=$INSTALLED_CDHASH" "target=$TARGET" "deploy_target=$DEPLOY_TARGET" "duration_ms=$DURATION_MS" "card=$CARD_ID" \
    >/dev/null 2>&1 || echo "chorus-deploy: WARN — deploy.completed emit failed (non-fatal)" >&2
fi

echo "chorus-deploy: $CRATE deployed in ${DURATION_MS}ms (commit=$COMMIT cdhash=$INSTALLED_CDHASH target=$DEPLOY_TARGET)"
