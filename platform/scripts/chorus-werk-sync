#!/usr/bin/env bash
# chorus-werk-sync — manual canonical recovery tool (#2863).
#
# History: pre-#2863 this was a 10-min-poll auto-sync that kept canonical's
# main ref current with origin. That polling substrate is retired. Sync now
# happens inside /build as an invariant first step (chorus-build does
# `git fetch + merge --ff-only origin/main` before any work).
#
# This file remains as a manual recovery primitive for the rare cases where
# /build aborts because canonical can't fast-forward (detached HEAD, prior
# commits on local main not on origin, dirty tree blocking the merge).
#
# Subcommands:
#   chorus-werk-sync repair
#     Re-attach HEAD to refs/heads/main, fetch origin/main, align local main
#     to origin/main, and reset the working tree. Uses git plumbing
#     (symbolic-ref / update-ref / read-tree) to bypass blocked porcelain
#     (checkout / switch / branch).
#
#   chorus-werk-sync recover (#2909)
#     Auto-recover from a dirty canonical without losing work. For each file
#     in M/A/D state that isn't merge=union: copy to ~/.chorus/recovery/<ts>/,
#     emit canonical.recovery.stashed event with path + sha + recovery_path,
#     restore from HEAD. Then fetch + ff-only origin/main. End state: clean
#     tree at origin/main tip; recovered work preserved in ~/.chorus/recovery/.
#     Replaces the manual stash+pull workaround chorus-build pointed at
#     pre-#2909. A role can invoke this from their own session if /build
#     happens to leave canonical stuck.
#
# Usage:
#   chorus-werk-sync repair
#   chorus-werk-sync recover
#
# Exit codes:
#   0  success
#   1  repair / recover failed (printed reason)
#   2  usage error

set -uo pipefail

CHORUS_HOME="${CHORUS_HOME:-/Users/jeffbridwell/CascadeProjects/chorus}"
LOCK_FILE="$CHORUS_HOME/.git-commit.lock"
LOCK_TIMEOUT="${CHORUS_WERK_SYNC_LOCK_TIMEOUT:-30}"

emit() {
  local event="$1"; shift
  if command -v chorus-log >/dev/null 2>&1; then
    chorus-log "$event" system "$@" >/dev/null 2>&1 || true
  elif [ -x "$CHORUS_HOME/platform/scripts/chorus-log" ]; then
    "$CHORUS_HOME/platform/scripts/chorus-log" "$event" system "$@" >/dev/null 2>&1 || true
  fi
}

abort() {
  echo "chorus-werk-sync: ABORT — $1" >&2
  exit 1
}

do_repair() {
  if [ ! -d "$CHORUS_HOME/.git" ]; then
    abort "CHORUS_HOME=$CHORUS_HOME is not a git repo"
  fi

  local from_sha
  from_sha=$(git -C "$CHORUS_HOME" rev-parse HEAD 2>/dev/null || echo "?")

  exec 9>"$LOCK_FILE"
  if ! lockf -t "$LOCK_TIMEOUT" 9; then
    abort "lockf timeout after ${LOCK_TIMEOUT}s — another git op is holding $LOCK_FILE"
  fi

  # Step 1: attach HEAD to refs/heads/main via plumbing.
  if ! git -C "$CHORUS_HOME" symbolic-ref HEAD refs/heads/main 2>/dev/null; then
    abort "repair failed: could not set HEAD → refs/heads/main"
  fi

  # Step 2: fetch origin/main.
  git -C "$CHORUS_HOME" fetch --quiet origin main 2>/dev/null || \
    git -C "$CHORUS_HOME" fetch origin main 2>/dev/null || true

  # Step 3: fast-forward local main to origin/main.
  local origin_main
  origin_main=$(git -C "$CHORUS_HOME" rev-parse origin/main 2>/dev/null || echo "")
  if [ -n "$origin_main" ]; then
    if ! git -C "$CHORUS_HOME" update-ref refs/heads/main "$origin_main" 2>/dev/null; then
      abort "repair failed: could not update refs/heads/main → $origin_main"
    fi
  fi

  # Step 4: align working tree to HEAD via plumbing.
  if ! git -C "$CHORUS_HOME" read-tree -u --reset HEAD 2>/dev/null; then
    abort "repair failed: could not align working tree to HEAD"
  fi

  local to_sha
  to_sha=$(git -C "$CHORUS_HOME" rev-parse HEAD 2>/dev/null || echo "?")

  if [ "$from_sha" = "$to_sha" ]; then
    echo "chorus-werk-sync: repair — already on main at $from_sha (no-op)"
  else
    echo "chorus-werk-sync: repair — $from_sha → $to_sha (HEAD attached to main)"
  fi
  emit "canonical.repaired" "from=$from_sha" "to=$to_sha"
  exit 0
}

# #2909 — do_recover: auto-stash real uncommitted files to ~/.chorus/recovery/
# then sync. Replaces the "ops runs git stash && git pull" workaround the
# pre-#2909 chorus-build pointed at. Lossless, no role-in-the-middle.
do_recover() {
  if [ ! -d "$CHORUS_HOME/.git" ]; then
    abort "CHORUS_HOME=$CHORUS_HOME is not a git repo"
  fi

  local recovery_ts
  recovery_ts=$(date +%Y%m%dT%H%M%S)
  local recovery_dir="$HOME/.chorus/recovery/$recovery_ts"

  exec 9>"$LOCK_FILE"
  if ! lockf -t "$LOCK_TIMEOUT" 9; then
    abort "lockf timeout after ${LOCK_TIMEOUT}s — another git op is holding $LOCK_FILE"
  fi

  # Read dirty files (M/A/D entries in working tree or index).
  local dirty_lines
  dirty_lines=$(git -C "$CHORUS_HOME" status --porcelain 2>/dev/null | grep -E '^[ MAD]' || true)

  local recovered=0
  if [ -n "$dirty_lines" ]; then
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      local path="${line:3}"
      [ -z "$path" ] && continue

      # Skip merge=union files — git auto-merges them on pull.
      local attr
      attr=$(git -C "$CHORUS_HOME" check-attr merge "$path" 2>/dev/null | awk -F': ' '{print $3}')
      if [ "$attr" = "union" ]; then
        continue
      fi

      # Hash the path for the recovery filename (12 chars is enough to avoid
      # collisions across a single timestamp dir).
      local path_hash
      path_hash=$(printf '%s' "$path" | shasum -a 256 | awk '{print $1}' | cut -c1-12)

      mkdir -p "$recovery_dir"

      # Save current working-tree content (if file exists; D-state files are
      # already gone from disk).
      local content_sha=""
      if [ -f "$CHORUS_HOME/$path" ]; then
        cp "$CHORUS_HOME/$path" "$recovery_dir/$path_hash"
        content_sha=$(shasum -a 256 "$recovery_dir/$path_hash" | awk '{print $1}')
      fi

      # Append to manifest so a human can recover from $recovery_dir.
      printf '%s\t%s\n' "$path_hash" "$path" >> "$recovery_dir/manifest.tsv"

      # Restore from HEAD to clean the dirty state. If file isn't in HEAD (A
      # state — added to index but not committed), remove it instead.
      if git -C "$CHORUS_HOME" cat-file -e "HEAD:$path" 2>/dev/null; then
        git -C "$CHORUS_HOME" checkout HEAD -- "$path" 2>/dev/null || true
      else
        rm -f "$CHORUS_HOME/$path" 2>/dev/null || true
        # Unstage if it was added to index
        git -C "$CHORUS_HOME" reset -q HEAD -- "$path" 2>/dev/null || true
      fi

      emit "canonical.recovery.stashed" \
        "path=$path" \
        "recovery_path=$recovery_dir/$path_hash" \
        "sha=$content_sha"

      recovered=$((recovered + 1))
    done <<< "$dirty_lines"
  fi

  # Tree is now clean (or only has union-merge files). Fetch + ff-only.
  if ! git -C "$CHORUS_HOME" fetch --quiet origin main 2>/dev/null; then
    abort "recover: git fetch origin main failed"
  fi
  if ! git -C "$CHORUS_HOME" merge --ff-only origin/main >/dev/null 2>&1; then
    abort "recover: ff-only merge failed after stash — try chorus-werk-sync repair"
  fi

  local to_sha
  to_sha=$(git -C "$CHORUS_HOME" rev-parse --short HEAD)

  if [ "$recovered" -gt 0 ]; then
    echo "chorus-werk-sync: recover — stashed $recovered file(s) to $recovery_dir/, synced to $to_sha"
    echo "  Manifest: $recovery_dir/manifest.tsv (one row per stashed file: hash<TAB>original_path)"
  else
    echo "chorus-werk-sync: recover — no dirty files; synced to $to_sha (no-op)"
  fi
  emit "canonical.recovery.completed" "recovered=$recovered" "to=$to_sha"
  exit 0
}

case "${1:-}" in
  repair) do_repair ;;
  recover) do_recover ;;
  *)
    echo "Usage: chorus-werk-sync {repair|recover}" >&2
    echo "  repair   — Re-attach HEAD to main, ff to origin/main (detached-HEAD recovery)" >&2
    echo "  recover  — Auto-stash dirty files to ~/.chorus/recovery/<ts>/, then ff to origin/main (#2909)" >&2
    echo "" >&2
    echo "  Sync is automatic inside /build (#2863). Use these only when /build aborts." >&2
    exit 2
    ;;
esac
