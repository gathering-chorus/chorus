#!/usr/bin/env bash
# chorus-werk-sync — DEPRECATION ALIAS (#3300, ADR-031 rollout).
#
# The implementation moved to the zero-dep Rust verb `werk-sync`
# (platform/services/werk-sync, ADR-032 blueprint). This stub forwards
# verbatim so existing operational callers keep working; migrate to
# `werk-sync {repair|recover}` — this alias will be dropped once callers are clean.
set -uo pipefail
echo "chorus-werk-sync: DEPRECATED — use \`werk-sync $*\` (#3300); forwarding" >&2
if command -v werk-sync >/dev/null 2>&1; then
  exec werk-sync "$@"
fi
FALLBACK="${CHORUS_HOME:-/Users/jeffbridwell/CascadeProjects/chorus}/platform/services/werk-sync/target/release/werk-sync"
if [ -x "$FALLBACK" ]; then
  exec "$FALLBACK" "$@"
fi
echo "chorus-werk-sync: werk-sync binary not found (not deployed and no release build) — build/deploy the werk-sync crate" >&2
exit 1
