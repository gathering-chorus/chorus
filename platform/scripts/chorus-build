#!/usr/bin/env bash
# chorus-build — building-pipeline build step (#2774).
#
# Wraps build-signed.sh in build-only mode (BUILD_SKIP_INSTALL=1), so the
# pipeline's deploy step (chorus-deploy) is a separate concern. After build,
# emits one build.completed spine event per signed binary with the canonical
# {commit, crate, sha256, cdhash} payload.
#
# Why this exists: build-signed.sh today bundles build+sign+install. The
# building-pipeline (per ADR-030) needs build and deploy as separate workflow
# steps so failures are surfaced at the right boundary. chorus-build does the
# build slice; chorus-deploy does the deploy slice.
#
# Usage:
#   chorus-build <chorus-hooks|chorus-inject>
#   chorus-build <crate-dir> <identifier> <binary-name>
#
# Exit codes:
#   0   success — binaries signed in target/release/, manifest written, spine
#       events emitted (build.artifact.hashed AND build.completed per binary).
#   1   build-fail (cargo build failed, codesign failed, missing crate dir).
#   2   usage error.
#
# Requires: build-signed.sh, chorus-log, chorus-manifest (all in this dir).

set -uo pipefail  # not -e: we want to capture build-signed.sh's exit code

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUILD_SIGNED="$SCRIPT_DIR/build-signed.sh"
CHORUS_LOG="$SCRIPT_DIR/chorus-log"
ROLE="${DEPLOY_ROLE:-${CHORUS_ROLE:-system}}"

if [ $# -lt 1 ]; then
  echo "Usage: chorus-build <chorus-hooks|chorus-inject>" >&2
  echo "   or: chorus-build <crate-dir> <identifier> <binary-name>" >&2
  exit 2
fi

if [ ! -x "$BUILD_SIGNED" ]; then
  echo "chorus-build: build-signed.sh not found or not executable at $BUILD_SIGNED" >&2
  exit 1
fi

# #2863 — INVARIANT: every build starts by syncing canonical from origin.
# /build is the only path that advances canonical's main ref. No skip
# conditions, no fallbacks; if fetch or fast-forward fails, abort loudly so
# we never build on stale canonical. Replaces the chorus-werk-sync poll
# substrate (10-min interval was the gap that let canonical lag behind
# origin during team activity, leaving the daemon running old code).
CHORUS_HOME_BUILD="${CHORUS_ROOT:-/Users/jeffbridwell/CascadeProjects/chorus}"
echo "chorus-build: sync canonical from origin (invariant — first step of every build)"
if ! git -C "$CHORUS_HOME_BUILD" fetch --quiet origin main 2>&1; then
  echo "chorus-build: ABORT — git fetch origin main failed" >&2
  exit 1
fi
if ! git -C "$CHORUS_HOME_BUILD" merge --ff-only origin/main >/dev/null 2>&1; then
  HEAD_BEFORE=$(git -C "$CHORUS_HOME_BUILD" rev-parse --short HEAD 2>/dev/null || echo unknown)
  ORIGIN_TIP=$(git -C "$CHORUS_HOME_BUILD" rev-parse --short origin/main 2>/dev/null || echo unknown)
  echo "chorus-build: ABORT — canonical not fast-forwardable to origin/main" >&2
  echo "  canonical HEAD: $HEAD_BEFORE" >&2
  echo "  origin/main:    $ORIGIN_TIP" >&2
  echo "  Likely cause: detached HEAD, divergent local commits, or dirty tree blocking the merge" >&2
  echo "  Recover: chorus-werk-sync repair, then re-run /build" >&2
  exit 1
fi
echo "chorus-build: canonical at $(git -C "$CHORUS_HOME_BUILD" rev-parse --short HEAD)"

CRATE="${1}"
COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
BUILDER_HOST=$(hostname -s)
START_TS=$(date +%s)

# Build-only: BUILD_SKIP_INSTALL prevents the chorus-bin-install at end of
# build-signed.sh. The build.artifact.hashed events still fire (manifest write
# happens during build, not at install).
BUILD_SKIP_INSTALL=1 "$BUILD_SIGNED" "$@"
RC=$?

END_TS=$(date +%s)
DURATION_MS=$(( (END_TS - START_TS) * 1000 ))

if [ "$RC" -ne 0 ]; then
  echo "chorus-build: build-signed.sh failed (exit=$RC)" >&2
  # Typed failure event (#2774 review feedback from Kade): consumers should
  # see "outcome-of" not "absence-of". Reason maps coarsely to where in the
  # build slice the failure occurred — finer detail lives in build-signed.sh
  # stderr.
  if [ -x "$CHORUS_LOG" ]; then
    "$CHORUS_LOG" build.failed "$ROLE" \
      "commit=$COMMIT" "crate=$CRATE" "exit_code=$RC" "duration_ms=$DURATION_MS" \
      "reason=build-signed-fail" "builder_host=$BUILDER_HOST" \
      >/dev/null 2>&1 || true
  fi
  exit 1
fi

# build.completed spine event per crate. duration_ms enables Loki histogram
# (build cache rot detection per #2774 review).
if [ -x "$CHORUS_LOG" ]; then
  "$CHORUS_LOG" build.completed "$ROLE" \
    "commit=$COMMIT" "crate=$CRATE" "duration_ms=$DURATION_MS" "builder_host=$BUILDER_HOST" \
    >/dev/null 2>&1 || echo "chorus-build: WARN — build.completed emit failed (non-fatal)" >&2
fi

echo "chorus-build: $CRATE built and signed in ${DURATION_MS}ms (commit=$COMMIT). Run chorus-deploy to install."
