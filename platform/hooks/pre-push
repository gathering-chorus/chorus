#!/usr/bin/env bash
# pre-push — refuse pushes that bypass git-queue or that originate from a
# branch not matching the role's expected prefix.
#
# Closes the bypass-path half of #2586's defense-in-depth (the queue-path
# half is git-queue.sh check_branch from #2580). Without this hook, raw
# `git push` outside git-queue is the silent bypass.
#
# Card: #2598
#
# Two checks:
#   1. Was push invoked through git-queue.sh? (envvar marker _GIT_QUEUE_PUSH=1)
#      If not → refuse unless DEPLOY_ROLE_PREPUSH_OVERRIDE=1 is set.
#   2. Does the local branch match `<DEPLOY_ROLE>/*`? Same invariant as #2580.
#      Refuse on mismatch.
#
# Skip conditions:
#   - DEPLOY_ROLE_PREPUSH_OVERRIDE=1 — explicit override (logs a warning).
#   - Refspec is a delete (`:refs/heads/foo`) — git push --delete is allowed.

set -euo pipefail

ROLE="${DEPLOY_ROLE:-unknown}"
OVERRIDE="${DEPLOY_ROLE_PREPUSH_OVERRIDE:-}"
QUEUE_MARKER="${_GIT_QUEUE_PUSH:-}"

# git push passes refspecs on stdin: <local-ref> <local-sha> <remote-ref> <remote-sha>
# Read the first one to inspect the local ref / sha.
local_ref=""
local_sha=""
while read -r local_ref local_sha _remote_ref _remote_sha; do
  # Empty local-sha = delete; allow it.
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    exit 0
  fi
  break
done

# 1. Override path
if [ "$OVERRIDE" = "1" ]; then
  echo "pre-push: WARN — DEPLOY_ROLE_PREPUSH_OVERRIDE=1; bypassing #2598 push gate" >&2
  exit 0
fi

# 2. Must be invoked via git-queue.sh push
if [ "$QUEUE_MARKER" != "1" ]; then
  echo "pre-push: ERROR — raw 'git push' refused (#2598)" >&2
  echo "  Use git-queue.sh push instead:" >&2
  echo "    DEPLOY_ROLE=${ROLE} bash platform/scripts/git-queue.sh push" >&2
  echo "" >&2
  echo "  Why: substrate-uniformity (Jeff 2026-04-29). All pushes go through" >&2
  echo "  the queue so the branch-check (#2580), pre-push validation, and" >&2
  echo "  spine-event emission happen on every push, regardless of role." >&2
  echo "" >&2
  echo "  Emergency override (logs the bypass):" >&2
  echo "    DEPLOY_ROLE_PREPUSH_OVERRIDE=1 git push <args>" >&2
  exit 1
fi

# 3. Branch-prefix check (mirrors #2580 commit-side)
if [ -z "${DEPLOY_ROLE:-}" ] || [ "$ROLE" = "unknown" ]; then
  echo "pre-push: ERROR — DEPLOY_ROLE not set (#2598)" >&2
  exit 1
fi

branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [ -z "$branch" ]; then
  echo "pre-push: ERROR — HEAD is detached" >&2
  exit 1
fi

# #2639: branch-prefix match delegated to branch-check.sh (single source
# for the invariant; git-queue.sh sources the same file).
HOOK_SOURCE_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
if [ -z "$HOOK_SOURCE_ROOT" ] || [ ! -f "$HOOK_SOURCE_ROOT/platform/scripts/branch-check.sh" ]; then
  HOOK_SOURCE_ROOT="${CHORUS_ROOT:-/Users/jeffbridwell/CascadeProjects/chorus}"
fi
# shellcheck source=../scripts/branch-check.sh
source "$HOOK_SOURCE_ROOT/platform/scripts/branch-check.sh"

if branch_check_match "$ROLE" "$branch"; then
  # Branch matches role prefix — allow.
  exit 0
else
  echo "pre-push: ERROR — branch '$branch' does not match role prefix '${ROLE}/' (#2598)" >&2
  echo "  Same invariant as the commit-side branch-check in #2580." >&2
  echo "  Either switch to a ${ROLE}/<card-id> branch or use the override env var." >&2
  exit 1
fi
