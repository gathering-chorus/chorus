#!/bin/bash
# pre-commit — secret scan on staged changes (#2709 AC1)
# Fails the commit on any NEW secret (beyond the accepted baseline). Skippable
# with --no-verify locally, but CI is authoritative on main (ADR-026 quality layers).
set -euo pipefail
REPO="$(git rev-parse --show-toplevel)"

# #3442 — test-type declaration gate (diff-scoped: staged test files only).
# Local-authoritative per the cost-stop model (ADR-026 layer-3 CI is schedule-
# only; local guards hold the line — same class as branch-check/deploy-from-main).
# The script fail-opens on any infra gap and exits non-zero ONLY on a real
# declaration contradiction. Placed before the gitleaks block so it runs even
# where gitleaks isn't installed.
if ! "$REPO/platform/scripts/gate-test-type.sh" staged; then
  echo "" >&2
  echo "🏷  pre-commit BLOCKED: a changed test file is missing or contradicting its @test-type declaration (#3442)." >&2
  echo "   Add a header // @test-type: <unit|integration|api|ui|perf|security|bdd|e2e>." >&2
  echo "   If a content signal is fixture-data, justify it: // @test-type: <type> — <why>." >&2
  exit 1
fi

# #3598 — retirement gate: a deleted surface (script/gate/hook/source) must not
# leave orphaned tests that still reference it (the rot class that fed the nightly
# false-reds — git-queue.sh/show-gate.sh/done-gate.sh deleted, their .bats left
# behind). Diff-scoped to staged deletions; fail-opens on infra gaps.
if ! CHORUS_ROOT="$REPO" "$REPO/platform/scripts/retirement-gate.sh"; then
  echo "" >&2
  echo "🪦 pre-commit BLOCKED: a deleted surface still has tests referencing it (#3598)." >&2
  echo "   Retire or repoint those tests in THIS commit — don't leave orphaned rot." >&2
  exit 1
fi

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit: gitleaks not installed (brew install gitleaks) — secret scan SKIPPED" >&2
  exit 0  # fail-open on missing tool: don't block work on a dev-setup gap; CI gates hard
fi
# 'protect --staged' scans only what's being committed, against the config +
# baseline. New finding (not in baseline, not allowlisted) => nonzero => block.
if ! gitleaks protect --staged \
      --config "$REPO/.gitleaks.toml" \
      --baseline-path "$REPO/.gitleaks-baseline.json" \
      --redact --no-banner 2>/tmp/gitleaks-precommit.out; then
  echo "" >&2
  echo "🔒 pre-commit BLOCKED: a new secret was detected in your staged changes." >&2
  echo "   Review /tmp/gitleaks-precommit.out (redacted)." >&2
  echo "   If it's a false positive: add the path to .gitleaks.toml [allowlist]." >&2
  echo "   If it's real: remove it, and rotate the credential. Never --no-verify a real hit." >&2
  exit 1
fi
