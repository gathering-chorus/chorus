#!/bin/bash
# pre-commit hook — chorus repo (tracked at platform/hooks/pre-commit, installed via
# platform/scripts/install-hooks.sh, #2465).
# Signal-not-narrate (DEC-035): one status line, details on demand.
# Gates: git-queue enforcement, WIP card (#1799), secrets, ESLint ratchet (#2462/#2464),
# werk version auto-bump (#1881). Legacy gathering-team checks (board-client,
# workflow-engine) are gated by path-presence and no-op in this repo.
set -euo pipefail

# Block commits that bypass git-queue.sh
if [ ! -f "$(git rev-parse --show-toplevel)/.git-commit.meta" ] && [ -z "${_GIT_QUEUE_INTERNAL:-}" ]; then
  echo "pre-commit: 🔴 blocked — all commits must go through git-queue.sh"
  echo "  Usage: DEPLOY_ROLE=<role> git-queue.sh commit <files...> -- -m \"message\""
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

# --- WIP card gate (#1799, #2204) ---
# Reject commits when the committing role has no WIP card declared.
# State file is a cache; board is authoritative (#2204) — fall back to
# `cards list --status WIP` when cache is missing/stale/idle, so a role with
# real WIP commits even after declared.json drifts.
# Bypass: no DEPLOY_ROLE (Jeff direct), swat/chore/acp/close/reboot commits.
_WIP_ROLE="${DEPLOY_ROLE:-}"
_WIP_MSG="${_COMMIT_MSG:-}"
if [ -n "$_WIP_ROLE" ]; then
  _wip_bypass=false
  # #1977: acp commits are acceptance actions — valid after card moves to Done
  # close/reboot commits happen after WIP cards are Done — bypass WIP gate
  echo "$_WIP_MSG" | grep -qiE '\b(swat|chore|acp|close|reboot)\b' && _wip_bypass=true

  if ! $_wip_bypass; then
    _state_file="/tmp/claude-team-scan/${_WIP_ROLE}-declared.json"
    _wip_ok=false
    if [ -f "$_state_file" ]; then
      _state=$(python3 -c "import json; d=json.load(open('${_state_file}')); print(d.get('state',''))" 2>/dev/null || echo "")
      _card=$(python3 -c "import json; d=json.load(open('${_state_file}')); print(d.get('card',''))" 2>/dev/null || echo "")
      if [ "$_state" = "building" ] && [ -n "$_card" ] && [ "$_card" != "None" ]; then
        _wip_ok=true
      fi
    fi
    if ! $_wip_ok; then
      # `cards list --status WIP` returns the WIP section AND a Next section
      # below it. Scope to the WIP block (between "WIP (" and the next blank
      # line / "Next (") so a role with cards only in Next doesn't pass.
      # Anchor the grep to the metadata bracket shape '[Role|P<digit>' —
      # priority is always immediately after the role pipe, and titles
      # don't contain that pattern. Without this, a card whose TITLE
      # contains literal '[Role|' false-positives (kade #2204 review).
      _cards_cmd="${CARDS_CMD:-${REPO_ROOT}/platform/scripts/cards}"
      if "$_cards_cmd" list --status WIP 2>/dev/null \
          | awk '/^WIP \(/{p=1; next} /^[A-Z]/ && p{p=0} p' \
          | grep -qiE "\[${_WIP_ROLE}\|P[0-9]"; then
        _wip_ok=true
      fi
    fi
    if ! $_wip_ok; then
      echo "pre-commit: 🔴 blocked — ${_WIP_ROLE} has no WIP card declared. Pull a card first."
      exit 1
    fi
  fi
fi

DETAIL_FILE="/tmp/pre-commit-detail.md"
CHECKS_RUN=0
CHECKS_PASSED=0
CHECKS_FAILED=0
FAILURES=""

# Write detail header
cat > "$DETAIL_FILE" <<EOF
# Pre-Commit Detail — $(date -u +%Y-%m-%dT%H:%M:%SZ)

EOF

run_check() {
  local name="$1"
  local dir="$2"
  local cmd="$3"
  CHECKS_RUN=$((CHECKS_RUN + 1))

  echo "## $name" >> "$DETAIL_FILE"
  echo '```' >> "$DETAIL_FILE"

  if output=$(cd "$dir" && eval "$cmd" 2>&1); then
    CHECKS_PASSED=$((CHECKS_PASSED + 1))
    echo "$output" >> "$DETAIL_FILE"
    echo '```' >> "$DETAIL_FILE"
    echo "Result: PASS" >> "$DETAIL_FILE"
    echo "" >> "$DETAIL_FILE"
  else
    CHECKS_FAILED=$((CHECKS_FAILED + 1))
    FAILURES="${FAILURES}\n  - ${name}"
    echo "$output" >> "$DETAIL_FILE"
    echo '```' >> "$DETAIL_FILE"
    echo "Result: FAIL" >> "$DETAIL_FILE"
    echo "" >> "$DETAIL_FILE"
  fi
}

# Detect which packages have staged changes
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

# ADR-026 §b: tsc + jest run for every active TS package whose files staged.
# Mapping is by directory prefix; legacy gathering-team paths
# (messages/board-client, messages/workflow-engine) are intentionally absent
# from chorus repo — those packages live elsewhere.
TS_PACKAGES=(
  "directing/clearing"
  "directing/products/cards"
  "platform/api"
  "platform/chorus-sdk"
  "platform/pulse"
  "platform/tests"
  "platform/workflow-engine"
)

AFFECTED_PACKAGES=()
for pkg in "${TS_PACKAGES[@]}"; do
  if echo "$STAGED" | grep -qE "^${pkg}/"; then
    AFFECTED_PACKAGES+=("$pkg")
  fi
done

# --- Check 1: TypeScript compilation (per affected package) ---
# Guard for set -u: empty-array expansion is an unbound-variable error in
# bash, so check length before iterating.

if [ ${#AFFECTED_PACKAGES[@]} -gt 0 ]; then
  for pkg in "${AFFECTED_PACKAGES[@]}"; do
    run_check "$pkg: tsc" \
      "$REPO_ROOT/$pkg" \
      "npx tsc --noEmit 2>&1"
  done
fi

# --- Check 2: Tests (per affected package) ---

if [ ${#AFFECTED_PACKAGES[@]} -gt 0 ]; then
  for pkg in "${AFFECTED_PACKAGES[@]}"; do
    # passWithNoTests so packages without test files don't fail
    run_check "$pkg: tests" \
      "$REPO_ROOT/$pkg" \
      "npx jest --forceExit --passWithNoTests 2>&1"
  done
fi

# --- Check 3: No secrets in staged files ---

if echo "$STAGED" | grep -qE '\.(env|credentials|secret)'; then
  CHECKS_RUN=$((CHECKS_RUN + 1))
  CHECKS_FAILED=$((CHECKS_FAILED + 1))
  FAILURES="${FAILURES}\n  - secrets: .env or credentials file staged"
  echo "## Secrets check" >> "$DETAIL_FILE"
  echo "FAIL: Sensitive file staged for commit" >> "$DETAIL_FILE"
  echo "" >> "$DETAIL_FILE"
fi

# Check for credential patterns in staged diffs. Exclusions:
#   - CLAUDE.md / claudemd/ / TEAM_PROTOCOL* — docs with token names as examples
#   - logs/ — log ingest can legitimately surface token strings
#   - platform/hooks/ — hook sources contain the regex itself (#2465 self-match fix)
#   - platform/scripts/install-hooks.sh — same reason
if git diff --cached -U0 -- ':!*CLAUDE.md' ':!*claudemd/*' ':!*TEAM_PROTOCOL*' ':!*logs/*' ':!platform/hooks/*' ':!platform/scripts/install-hooks.sh' | grep '^+' | grep -qiE '(SLACK_BOT_TOKEN|VIKUNJA_TOKEN|API_KEY|SECRET_KEY|password\s*=)' 2>/dev/null; then
  CHECKS_RUN=$((CHECKS_RUN + 1))
  CHECKS_FAILED=$((CHECKS_FAILED + 1))
  FAILURES="${FAILURES}\n  - secrets: credential pattern found in staged diff"
  echo "## Credential pattern check" >> "$DETAIL_FILE"
  echo "FAIL: Credential-like pattern found in staged changes" >> "$DETAIL_FILE"
  echo "" >> "$DETAIL_FILE"
fi

# --- Check 3.5: Catalog-dir oversize-binary gate (#2461) ---
# Reject commits that add files >2MB into any doc-catalog SOURCE_DIR.
# Logic in platform/scripts/check-catalog-oversize.sh (hermetic-tested).
CHECKS_RUN=$((CHECKS_RUN + 1))
if oversize_out=$(echo "$STAGED" | REPO_ROOT="$REPO_ROOT" "$REPO_ROOT/platform/scripts/check-catalog-oversize.sh" 2>&1); then
  CHECKS_PASSED=$((CHECKS_PASSED + 1))
else
  CHECKS_FAILED=$((CHECKS_FAILED + 1))
  FAILURES="${FAILURES}\n  - catalog-oversize — large binaries in catalog dirs (#2461, #2458 push-bloat incident)"
  echo "## Catalog oversize binaries (#2461)" >> "$DETAIL_FILE"
  echo '```'  >> "$DETAIL_FILE"
  echo "$oversize_out" >> "$DETAIL_FILE"
  echo '```'  >> "$DETAIL_FILE"
  echo "" >> "$DETAIL_FILE"
fi

# --- Check 3.6: Principle direct-edit gate (#2314) ---
# Reject staged chorus.ttl edits that add new chorus:Principle instance triples.
# Principles are written via POST /api/athena/subdomains/loom-principles/principles
# (ADR-025). Override via PRINCIPLE_DIRECT_EDIT_SKIP=1 for one-off migration / schema-only edits.
CHECKS_RUN=$((CHECKS_RUN + 1))
if principle_out=$(echo "$STAGED" | REPO_ROOT="$REPO_ROOT" "$REPO_ROOT/platform/scripts/check-principle-direct-edit.sh" 2>&1); then
  CHECKS_PASSED=$((CHECKS_PASSED + 1))
else
  CHECKS_FAILED=$((CHECKS_FAILED + 1))
  FAILURES="${FAILURES}\n  - principle-direct-edit — chorus.ttl stages new Principle instances (#2314)"
  echo "## Principle direct-edit (#2314)" >> "$DETAIL_FILE"
  echo '```' >> "$DETAIL_FILE"
  echo "$principle_out" >> "$DETAIL_FILE"
  echo '```' >> "$DETAIL_FILE"
  echo "" >> "$DETAIL_FILE"
fi

# --- Check 4: (retired) Per-rule ESLint ratchet — DELETED #2603 ---
# Was the per-rule ESLint ratchet from #2462/#2464. DEC-2525 retired it
# (#2526 deleted the .eslint-baseline.json file). The block guarded on
# baseline existence and was therefore dead code. Removed inline rather
# than left as a follow-on; the eliminate-vs-manage pattern Wren named
# during #2603 demo. The narrower Check 4.4 below replaces its scope
# for the one rule we now block on.

# --- Check 4.4: sonarjs error-tier (#2603, #2627) ---
# Two rules block at error: no-duplicate-string (#2603, threshold 5) and
# cognitive-complexity (#2627, threshold 12). Cog-complexity supports a
# magic-comment override: `// cog-override: <one-line reason>` on the line
# directly above the offending function exempts that function and emits a
# cog.override.used spine event for audit. No baseline file, no ratchet.
# Existing functions over 12 stay until their file is next staged
# (fix-as-we-go discipline).

if [ -f "$REPO_ROOT/eslint.config.js" ]; then
  STAGED_TS=$(echo "$STAGED" | grep -E '\.ts$' || true)
  if [ -n "$STAGED_TS" ]; then
    CHECKS_RUN=$((CHECKS_RUN + 1))
    echo "## sonarjs error-tier (#2603, #2627)" >> "$DETAIL_FILE"
    echo '```' >> "$DETAIL_FILE"
    # Run eslint once, parse JSON for both rules. Cog-complexity hits get
    # filtered against the magic-comment override; surviving hits + all
    # no-duplicate-string hits combine into the failure count.
    sonar_out=$(cd "$REPO_ROOT" && echo "$STAGED_TS" | xargs npx eslint --format=json 2>/dev/null || true)
    sonar_report=$(echo "$sonar_out" | node -e '
      const fs = require("fs");
      let s = "";
      process.stdin.on("data", d => s += d);
      process.stdin.on("end", () => {
        try {
          const arr = JSON.parse(s || "[]");
          const dupes = [];
          const cogHits = [];
          const cogOverrides = [];
          for (const f of arr) {
            for (const m of (f.messages || [])) {
              if (m.ruleId === "sonarjs/no-duplicate-string") {
                dupes.push({ file: f.filePath, line: m.line, msg: m.message });
              } else if (m.ruleId === "sonarjs/cognitive-complexity") {
                let exempt = false; let reason = "";
                try {
                  const lines = fs.readFileSync(f.filePath, "utf-8").split("\n");
                  // Look 1-3 lines above the hit for the override comment.
                  for (let k = m.line - 2; k >= Math.max(0, m.line - 4); k--) {
                    const m2 = (lines[k] || "").match(/\/\/\s*cog-override:\s*(.+)/);
                    if (m2) { exempt = true; reason = m2[1].trim(); break; }
                  }
                } catch { /* file unreadable */ }
                if (exempt) {
                  cogOverrides.push({ file: f.filePath, line: m.line, reason });
                } else {
                  cogHits.push({ file: f.filePath, line: m.line, msg: m.message });
                }
              }
            }
          }
          process.stdout.write(JSON.stringify({ dupes, cogHits, cogOverrides }));
        } catch { process.stdout.write(JSON.stringify({ dupes: [], cogHits: [], cogOverrides: [] })); }
      });
    ' 2>/dev/null || echo "{}")
    DUPE_N=$(echo "$sonar_report" | node -e 'let s="";process.stdin.on("data",d=>s+=d);process.stdin.on("end",()=>{try{process.stdout.write(String((JSON.parse(s).dupes||[]).length))}catch{process.stdout.write("0")}})' 2>/dev/null || echo 0)
    COG_N=$(echo "$sonar_report" | node -e 'let s="";process.stdin.on("data",d=>s+=d);process.stdin.on("end",()=>{try{process.stdout.write(String((JSON.parse(s).cogHits||[]).length))}catch{process.stdout.write("0")}})' 2>/dev/null || echo 0)
    OVR_N=$(echo "$sonar_report" | node -e 'let s="";process.stdin.on("data",d=>s+=d);process.stdin.on("end",()=>{try{process.stdout.write(String((JSON.parse(s).cogOverrides||[]).length))}catch{process.stdout.write("0")}})' 2>/dev/null || echo 0)
    # Emit spine event per cog-override applied (#2627 AC3).
    if [ "${OVR_N:-0}" != "0" ]; then
      echo "$sonar_report" | node -e 'let s="";process.stdin.on("data",d=>s+=d);process.stdin.on("end",()=>{try{const o=JSON.parse(s).cogOverrides||[];for(const ov of o)process.stdout.write(`${ov.file}:${ov.line}\t${ov.reason}\n`)}catch{}})' 2>/dev/null | while IFS=$'\t' read -r loc reason; do
        "$REPO_ROOT/platform/scripts/chorus-log" cog.override.used "${ROLE:-unknown}" "loc=${loc}" "reason=${reason}" >/dev/null 2>&1 || true
      done
    fi
    TOTAL_FAIL=$((${DUPE_N:-0} + ${COG_N:-0}))
    if [ "$TOTAL_FAIL" = "0" ]; then
      CHECKS_PASSED=$((CHECKS_PASSED + 1))
      echo "sonarjs error-tier clean on staged TS (overrides=${OVR_N:-0})" >> "$DETAIL_FILE"
      echo '```' >> "$DETAIL_FILE"
      echo "Result: PASS" >> "$DETAIL_FILE"
      echo "" >> "$DETAIL_FILE"
    else
      CHECKS_FAILED=$((CHECKS_FAILED + 1))
      FAILURES="${FAILURES}\n  - sonarjs error-tier — ${DUPE_N} no-duplicate-string + ${COG_N} cognitive-complexity (overrides=${OVR_N})"
      echo "no-duplicate-string: ${DUPE_N} | cognitive-complexity: ${COG_N} (override applied: ${OVR_N})" >> "$DETAIL_FILE"
      echo "$sonar_report" | node -e 'let s="";process.stdin.on("data",d=>s+=d);process.stdin.on("end",()=>{try{const r=JSON.parse(s);for(const h of (r.dupes||[]))process.stdout.write(`  ${h.file}:${h.line} ${h.msg}\n`);for(const h of (r.cogHits||[]))process.stdout.write(`  ${h.file}:${h.line} ${h.msg}\n`)}catch{}})' >> "$DETAIL_FILE" 2>/dev/null
      echo '```' >> "$DETAIL_FILE"
      echo "Result: FAIL" >> "$DETAIL_FILE"
      echo "Fix no-duplicate-string: extract literal to const (threshold 5)." >> "$DETAIL_FILE"
      echo "Fix cognitive-complexity: refactor function under threshold 12, OR add // cog-override: <reason> on the line above the function declaration if structurally intransigent (#2627)." >> "$DETAIL_FILE"
      echo "" >> "$DETAIL_FILE"
    fi
  fi
fi

# --- Check 4.5: MCP tool description shape (#2475) ---
# The description string is the doc surface for every MCP tool — Claude reads
# it on every reach. Drift here is doc rot at runtime. Lint asserts each tool's
# description meets the shape contract: min length, disposition guidance,
# anti-pattern clause, polymorphism clarifiers on multi-value enums.

if echo "$STAGED" | grep -qE '^platform/api/src/mcp/.*\.ts$'; then
  CHECKS_RUN=$((CHECKS_RUN + 1))
  echo "## MCP tool description shape (#2475)" >> "$DETAIL_FILE"
  echo '```' >> "$DETAIL_FILE"
  if mcp_lint_out=$(node "$REPO_ROOT/platform/scripts/mcp-tool-description-lint.js" 2>&1); then
    CHECKS_PASSED=$((CHECKS_PASSED + 1))
    echo "$mcp_lint_out" >> "$DETAIL_FILE"
    echo '```' >> "$DETAIL_FILE"
    echo "Result: PASS" >> "$DETAIL_FILE"
    echo "" >> "$DETAIL_FILE"
  else
    CHECKS_FAILED=$((CHECKS_FAILED + 1))
    FAILURES="${FAILURES}\n  - mcp-description-shape — tool description fails the shape contract (#2475)"
    echo "$mcp_lint_out" >> "$DETAIL_FILE"
    echo '```' >> "$DETAIL_FILE"
    echo "Result: FAIL" >> "$DETAIL_FILE"
    echo "Fix: see platform/scripts/mcp-tool-description-lint.js for the shape." >> "$DETAIL_FILE"
    echo "" >> "$DETAIL_FILE"
  fi
fi

# --- Check 4.6: cargo test (per affected Rust crate) — hermetic only ---
# ADR-026 §b: cargo test runs in pre-commit when *.rs files stage in any
# Rust crate. Two crates today: chorus-hooks, chorus-inject.
#
# DEC-2525 (#2526 wave 1): pre-commit runs `cargo test --lib --bins`,
# matching the CI required-check filter. Inline `#[test]` in src/ are
# hermetic by construction; tests/*.rs integration suite is non-hermetic
# (axis-4 state-ownership clashes with live role daemons — see #2558,
# #2559) and runs in the cargo-test-integration CI job (continue-on-error)
# and the nightly drift lane (#2527, future). Pre-commit blocks only on
# the hermetic tier so non-hermetic flake doesn't train --no-verify.
RUST_CRATES=(
  "platform/services/chorus-hooks"
  "platform/services/chorus-inject"
)

for crate in "${RUST_CRATES[@]}"; do
  if echo "$STAGED" | grep -qE "^${crate}/.*\.rs$"; then
    run_check "$crate: cargo test --lib --bins" \
      "$REPO_ROOT/$crate" \
      "cargo test --lib --bins --quiet 2>&1"
  fi
done

# --- Check 4.65: clippy per-lint ratchet (#2532, extended for #2602 cog-complexity) ---
# Counts may only decrease per lint per crate. Baseline at .clippy-baseline.json.
# Runs only when Rust files stage in a tracked crate.
if echo "$STAGED" | grep -qE "^platform/services/(chorus-hooks|chorus-inject)/.*\.rs$"; then
  run_check "clippy-ratchet" \
    "$REPO_ROOT" \
    "bash platform/scripts/clippy-ratchet.sh 2>&1"
fi

# --- Check 4.7: Doc-coherence ratchet (#2451) ---
# Wires the existing test at platform/tests/doc-coherence-ratchet.test.sh.
# Runs only when CLAUDE.md or claudemd/ fragments stage. Local-only per
# ADR-026 §b ("No (no remote effect)" CI cell).
if echo "$STAGED" | grep -qE '(^|/)CLAUDE\.md$|^designing/claudemd/'; then
  run_check "doc-coherence-ratchet" \
    "$REPO_ROOT" \
    "bash platform/tests/doc-coherence-ratchet.test.sh 2>&1"
fi

# --- Check 5: Compiled dist matches source — RETIRED ---
# Was board-client-only, referenced messages/board-client/dist which lives
# in legacy gathering-team repo, not chorus. Per ADR-026 §b "Extend or
# retire when build moves" — build moved, retired. If dist drift becomes
# a concern in chorus packages, reintroduce per-package.

# --- Check 6: Werk version auto-bump (#1881) ---
# Protocol changes require a version bump. If qualifying files changed but
# manifest.json version didn't bump, auto-increment it.

WERK_BUMP_PATTERNS="platform/scripts/ platform/skills/ platform/services/chorus-hooks/src/hooks/ platform/services/chorus-hooks/src/commands/ designing/claudemd/"
NEEDS_BUMP=false
MANIFEST="$REPO_ROOT/designing/claudemd/manifest.json"

for pattern in $WERK_BUMP_PATTERNS; do
  if echo "$STAGED" | grep -q "^${pattern}"; then
    NEEDS_BUMP=true
    break
  fi
done

if $NEEDS_BUMP && [ -f "$MANIFEST" ]; then
  # Check if manifest.json is already in the staged files (manual bump)
  if echo "$STAGED" | grep -q "designing/claudemd/manifest.json"; then
    : # Already bumped manually — skip
  else
    # Auto-bump: read current version, increment, write, stage
    CURRENT_V=$(grep '"version"' "$MANIFEST" | head -1 | grep -oE '[0-9]+')
    if [ -n "$CURRENT_V" ]; then
      NEW_V=$((CURRENT_V + 1))
      sed -i '' "s/\"version\": \"${CURRENT_V}\"/\"version\": \"${NEW_V}\"/" "$MANIFEST"
      git add "$MANIFEST"
      CHECKS_RUN=$((CHECKS_RUN + 1))
      CHECKS_PASSED=$((CHECKS_PASSED + 1))
      echo "## Werk version auto-bump" >> "$DETAIL_FILE"
      echo "Result: PASS — v${CURRENT_V} → v${NEW_V} (protocol files changed)" >> "$DETAIL_FILE"
      echo "" >> "$DETAIL_FILE"
    fi
  fi
fi

# --- Emit event to chorus log ---

"$REPO_ROOT/chorus/platform/scripts/chorus-log" "pre_commit" \
  "$(cd "$REPO_ROOT" && basename "$(pwd)")" \
  "checks_run=${CHECKS_RUN}" \
  "checks_passed=${CHECKS_PASSED}" \
  "checks_failed=${CHECKS_FAILED}" 2>/dev/null || true

# --- Signal output ---

if [ $CHECKS_RUN -eq 0 ]; then
  echo "pre-commit: 🟢 no checks needed (no TypeScript/package changes)"
  exit 0
fi

if [ $CHECKS_FAILED -gt 0 ]; then
  echo "pre-commit: 🔴 ${CHECKS_FAILED}/${CHECKS_RUN} checks failed"
  echo -e "$FAILURES"
  echo "  Details: $DETAIL_FILE"
  exit 1
fi

echo "pre-commit: 🟢 ${CHECKS_PASSED}/${CHECKS_RUN} checks passed"
exit 0
