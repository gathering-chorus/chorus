<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.chorus.owl-api</string>
    <!-- #3354 reliability ility: the generated Domain API runs SUPERVISED from
         day one (the 2026-06-11 pulse lesson: unsupervised services become
         landmines). Serves the installed binary from ~/.chorus/bin; KeepAlive
         restarts on crash; localhost-bound (the gathering local-security model). -->
    <key>ProgramArguments</key>
    <array>
        <string>/Users/jeffbridwell/.chorus/bin/owl-api</string>
        <string>serve</string>
        <string>--port</string>
        <string>3360</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>CHORUS_HOME</key>
        <string>/Users/jeffbridwell/CascadeProjects/chorus</string>
        <key>PATH</key>
        <string>/Users/jeffbridwell/.chorus/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/jeffbridwell/Library/Logs/Gathering/owl-api.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/jeffbridwell/Library/Logs/Gathering/owl-api.log</string>
</dict>
</plist>
