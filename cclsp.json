{
  "servers": [
    {
      "extensions": ["ts", "tsx", "js", "jsx", "mjs", "cjs"],
      "command": ["typescript-language-server", "--stdio"],
      "rootDir": "."
    },
    {
      "extensions": ["rs"],
      "command": ["rust-analyzer"],
      "rootDir": ".",
      "initializationOptions": {
        "linkedProjects": [
          "platform/services/werk-pull/Cargo.toml",
          "platform/services/werk-commit/Cargo.toml",
          "platform/services/werk-push/Cargo.toml",
          "platform/services/werk-build/Cargo.toml",
          "platform/services/werk-deploy/Cargo.toml",
          "platform/services/werk-accept/Cargo.toml",
          "platform/services/werk-demo/Cargo.toml",
          "platform/services/chorus-hooks/Cargo.toml",
          "platform/services/chorus-inject/Cargo.toml"
        ]
      }
    }
  ]
}
