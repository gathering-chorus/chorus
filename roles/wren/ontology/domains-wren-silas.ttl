@prefix chorus: <https://jeffbridwell.com/chorus#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .

# #3581 — materialize the V2 domains as real chorus:Domain entities, the proven
# TTL-deploy way (matching chorus:Properties, the sole surviving template), authored
# properly (Jeff's "do it properly, no stubs" ruling, 2026-06-25). Paired Wren(drive)
# + Kade(navigate). This file = Wren's lane (loom/athena/chorus-service/clearing) +
# Silas's borg (attributed to tree owner = silas). PEER-CHECK + verify-edges-resolve
# BEFORE deploy. EDGE FORMS = the live RESOLVING IRIs (verified on fact, Wren+Kade):
#   ownedBy → BARE role (chorus:wren/silas)         [NOT chorus:role-wren]
#   atStep  → CAPITALIZED step (chorus:Shaping…Proving) [NOT value-stream-step-x]
#   partOf  → the owning PRODUCT. #3603: re-parented from coarse chorusProduct to
#             the typed child products (loomProduct/athenaProduct/clearingProduct/
#             spineProduct/werkProduct) per Jeff's roster call 2026-07-03 — this is
#             the follow-on the note below named. memory/knowledge/search stay
#             chorusProduct (cross-product capabilities).
#   atStream→ chorus:chorusStream
# COARSE partOf (chorusProduct/borgProduct) matches the one valid template; the
# subproduct (loom/athena/clearing/werk) granularity is a FOLLOW-ON additive edge +
# a Jeff structural call — NOT invented here. definesVocabulary ONLY where a real
# owl:Class exists (verified vs the live 59); OMITTED (flagged) where none — NOT faked.

# ── loom (Shaping, ownedBy wren, partOf chorusProduct) ────────────────────────
chorus:roles a owl:Class, chorus:Domain ;
  rdfs:label "roles" ; chorus:comment "Team member identities, capabilities, and session lifecycle." ;
  chorus:purpose "Define who the team is — each role's identity, accountability, and session lifecycle." ;
  chorus:ownedBy chorus:wren ; chorus:partOf chorus:product-loom ;
  chorus:atStep chorus:Shaping ; chorus:atStream chorus:chorusStream ;
  chorus:repoTarget "roles" ; chorus:definesVocabulary chorus:Role, chorus:AgentRole, chorus:HumanRole .

chorus:principles a owl:Class, chorus:Domain ;
  rdfs:label "principles" ; chorus:comment "Values and constraints governing team decisions and priorities." ;
  chorus:purpose "Hold the values and constraints that govern how the team decides and prioritizes." ;
  chorus:ownedBy chorus:wren ; chorus:partOf chorus:product-loom ;
  chorus:atStep chorus:Shaping ; chorus:atStream chorus:chorusStream ;
  chorus:repoTarget "loom/principles" ; chorus:definesVocabulary chorus:Principle .

chorus:policies a owl:Class, chorus:Domain ;
  rdfs:label "policies" ; chorus:comment "Rules that enforce principles in practice — hooks, guards, gates." ;
  chorus:purpose "Turn principles into enforced rules — the hooks, guards, and gates that hold the line." ;
  chorus:ownedBy chorus:wren ; chorus:partOf chorus:product-loom ;
  chorus:atStep chorus:Shaping ; chorus:atStream chorus:chorusStream ;
  chorus:repoTarget "loom/policies" ; chorus:definesVocabulary chorus:Policy .

chorus:practices a owl:Class, chorus:Domain ;
  rdfs:label "practices" ; chorus:comment "Repeatable patterns the team uses — how we work, not just what we value." ;
  chorus:purpose "Capture the repeatable ways the team works — the how, distinct from the values." ;
  chorus:ownedBy chorus:wren ; chorus:partOf chorus:product-loom ;
  chorus:atStep chorus:Shaping ; chorus:atStream chorus:chorusStream ;
  chorus:repoTarget "loom/practices" ; chorus:definesVocabulary chorus:Practice .

chorus:skills a owl:Class, chorus:Domain ;
  rdfs:label "skills" ; chorus:comment "Invokable capabilities — /skill-name commands that automate team workflows." ;
  chorus:purpose "Provide the team's invokable capabilities — the /skill commands that automate workflows." ;
  chorus:ownedBy chorus:wren ; chorus:partOf chorus:product-loom ;
  chorus:atStep chorus:Shaping ; chorus:atStream chorus:chorusStream ;
  chorus:repoTarget "skills" ; chorus:definesVocabulary chorus:Skill, chorus:UtilitySkill .

chorus:decisions a owl:Class, chorus:Domain ;
  rdfs:label "decisions" ; chorus:comment "Decision log with context, rationale, and tradeoffs recorded." ;
  chorus:purpose "Record the team's decisions with their context, rationale, and tradeoffs — the why behind the system." ;
  chorus:ownedBy chorus:wren ; chorus:partOf chorus:product-loom ;
  chorus:atStep chorus:Shaping ; chorus:atStream chorus:chorusStream ;
  chorus:repoTarget "designing/decisions" .
  # FLAG: no real owl:Class vocab (no chorus:Decision/ADR class) — definesVocabulary omitted, not faked.

chorus:rcas a owl:Class, chorus:Domain ;
  rdfs:label "rcas" ; chorus:comment "Root cause analyses — what broke, why, and what changed as a result." ;
  chorus:purpose "Hold root-cause analyses — what broke, why, and what changed so it doesn't recur." ;
  chorus:ownedBy chorus:wren ; chorus:partOf chorus:product-loom ;
  chorus:atStep chorus:Shaping ; chorus:atStream chorus:chorusStream ;
  chorus:repoTarget "loom/rcas" .
  # FLAG: no real owl:Class vocab (no chorus:RCA class) — omitted, not faked.

# ── athena (Designing, ownedBy wren, partOf chorusProduct) ────────────────────
chorus:domains a owl:Class, chorus:Domain ;
  rdfs:label "domains" ; chorus:comment "The canonical product/domain/service structural model — this tree." ;
  chorus:purpose "Hold the canonical structural model of the system — products, domains, services and their edges." ;
  chorus:ownedBy chorus:wren ; chorus:partOf chorus:product-athena ;
  chorus:atStep chorus:Designing ; chorus:atStream chorus:chorusStream ;
  chorus:repoTarget "designing/domains" ; chorus:definesVocabulary chorus:Domain, chorus:SubDomain, chorus:CollectionDomain .

chorus:services a owl:Class, chorus:Domain ;
  rdfs:label "services" ; chorus:comment "Service definitions, interfaces, and ownership within the product model." ;
  chorus:purpose "Define the system's services — their interfaces, ownership, and place in the product model." ;
  chorus:ownedBy chorus:wren ; chorus:partOf chorus:product-athena ;
  chorus:atStep chorus:Designing ; chorus:atStream chorus:chorusStream ;
  chorus:repoTarget "designing/services" ; chorus:definesVocabulary chorus:Service, chorus:ServiceDesign .

