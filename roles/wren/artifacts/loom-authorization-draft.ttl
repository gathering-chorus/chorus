# chorus:practice-context-injection — auto-injected via SessionStart hook; no role invocation.
# chorus:practice-2-touch-target — measurement target, not enforceable at turn time;
# observed via spine events in Borg.

chorus:practice-domain-context-before-code
    chorus:hasGate chorus:gate-fuseki-health .
    # /pull Step 4 enforces Fuseki-up before domain context loads.

# chorus:practice-verify-before-asserting — process-only; trained via feedback memories.

# --- Legacy practices (7 original from team-architecture) ---

# chorus:practice-actor-bdd — design-time practice; no run-time skill or gate yet.
# Could add: gate-has-scenarios before pull.

chorus:practice-domain-first
    chorus:hasGate chorus:gate-design-wip-ready .

# chorus:practice-service-next — process-only; the service-design doc precedes the card.

chorus:practice-product-owner-aligned
    chorus:hasGate chorus:gate-product .
    # Every code card routes through Wren's gate-product.

chorus:practice-tdd
    chorus:hasGate chorus:gate-tdd, chorus:gate-code .

chorus:practice-production-ready
    chorus:hasGate chorus:gate-demo, chorus:gate-product, chorus:gate-ops .

# chorus:practice-api-first — process-only today; could have gate-api-first
# (OpenAPI required before merge) — not built.

# =============================================================================
# NEW GATE INSTANCES referenced above (not in sub-spike 1)
# =============================================================================

chorus:gate-stop-the-line a chorus:Gate ;
    rdfs:label "stop-the-line PostToolUse" ;
    rdfs:subClassOf chorus:BuildGate ;
    rdfs:comment "PostToolUse hook — blocks turn when a tool errors; forces resolve/card/defer. #2145 (Next) is the implementation card." ;
    chorus:implementedIn "platform/services/chorus-hooks/src/gates/stop_the_line.rs" .
    # Implementation status: PENDING. Gate exists conceptually; card #2145 is the build work.

chorus:gate-fuseki-health a chorus:Gate ;
    rdfs:label "Fuseki health" ;
    rdfs:subClassOf chorus:BuildGate ;
    rdfs:comment "Inline check in /pull Step 4 — blocks pull if Fuseki :3030 is not 200. #2033 origin." ;
    chorus:implementedIn "~/.claude/skills/pull/SKILL.md:step-4" .

chorus:gate-design-wip-ready a chorus:Gate ;
    rdfs:label "Design gate (WIP-ready)" ;
    rdfs:subClassOf chorus:DesignGate ;
    rdfs:comment "Inline check in /pull Step 4.5 — blocks type:new or type:enhance pulls when domain lifecycle.wip is not pass. #1396 origin." ;
    chorus:implementedIn "~/.claude/skills/pull/SKILL.md:step-4.5" .

# =============================================================================
# SUB-SPIKE 3C — DANGLING POLICY REPAIR
# =============================================================================
#
# chorus.ttl declares practice→policy edges to 9 policies that don't exist
# as instances. This section materializes them — one policy instance per
# dangling reference, with derivedFrom pointing at the principle that
# motivates the rule.
#
# Rule: each policy is a BINARY assertion — allowed/blocked, required/forbidden.
# If it's a discipline (a how, not a yes/no), it's a practice, not a policy.
# -----------------------------------------------------------------------------

chorus:policy-tdd-gate a chorus:Policy ;
    rdfs:label "TDD required before code" ;
    rdfs:comment "Every code card must have failing tests (red) before production code is written. Enforced by tdd_gate.rs PreToolUse hook. DEC-1674." ;
    chorus:derivedFrom chorus:principle-quality-at-source,
                       chorus:principle-speed-and-quality-correlate .

chorus:policy-demo-gate a chorus:Policy ;
    rdfs:label "No accept without demo" ;
    rdfs:comment "A code card cannot be marked Done without demo evidence. Builder cannot self-accept. DEC-048 Proving Gate. Enforced by demo_gate.rs hook and /acp skill." ;
    chorus:derivedFrom chorus:principle-apply-self-regulation-and-accept-feedback,
                       chorus:principle-no-dark-work .

chorus:policy-accept-gate a chorus:Policy ;
    rdfs:label "Accept = Done + spine + commit + push" ;
    rdfs:comment "An acceptance must complete all four: move card to Done, emit card.accepted spine event, commit changes via git-queue, push. Partial acceptance is not acceptance. Enforced by /acp skill steps 1-4." ;
    chorus:derivedFrom chorus:principle-artifacts,
                       chorus:principle-no-dark-work .

chorus:policy-handoff-logger a chorus:Policy ;
    rdfs:label "Every cross-role handoff logged" ;
    rdfs:comment "Briefs, nudges, gate-passes, and acceptances across roles must log to activity.md. If it's a handoff, it's traceable. Enforced by role discipline + future handoff-gate hook (not yet materialized)." ;
    chorus:derivedFrom chorus:principle-artifacts,
                       chorus:principle-no-dark-work .

chorus:policy-demo-provenance a chorus:Policy ;
    rdfs:label "Demo evidence is an artifact" ;
    rdfs:comment "Every demo produces a durable artifact (brief file or card comment) identifying what was shown, by whom, when. Verbal-only demos do not satisfy the demo gate. Enforced by demo_gate.rs hook reading comments/briefs — #2177 migrates fully to card comments." ;
    chorus:derivedFrom chorus:principle-artifacts,
                       chorus:principle-no-dark-work .

chorus:policy-nudge-blast-radius a chorus:Policy ;
    rdfs:label "Nudge requires WIP context" ;
    rdfs:comment "A nudge targeting a role carries the card context (WIP id if present, reason for interruption). Cross-domain nudges surface a warning. DEC-107 dual-path persist+deliver is the mechanism; blast-radius is the discipline around when it fires." ;
    chorus:derivedFrom chorus:principle-protect-attention,
                       chorus:principle-focus-is-infrastructure .

chorus:policy-pair-enforcement a chorus:Policy ;
    rdfs:label "Pair has navigator + driver, not spectators" ;
    rdfs:comment "A /pair session has exactly one navigator and one driver. Navigator scopes; driver implements. Rotation checkpoints enforce turn-taking. Partner silence > 60s = stall signal (see policy-response-window-60s for the heartbeat). Enforced by /pair skill state + future pair-heartbeat-check skill (#2317)." ;
    chorus:derivedFrom chorus:principle-comprehension-is-the-rate-limit,
                       chorus:principle-integrate-rather-than-segregate .

chorus:policy-icd-write-gate a chorus:Policy ;
    rdfs:label "No harvester without ICD provider" ;
    rdfs:comment "A harvester service file (harvest-*.sh, *-harvester.service.ts) cannot be written if the domain has no ICD provider section in urn:gathering:icd/current. Populate the ICD first, then code. DEC-095. Enforced by icd-gate-hook.sh PreToolUse hook." ;
    chorus:derivedFrom chorus:principle-services-reliable-bounded-idempotent,
                       chorus:principle-no-dark-work .

chorus:policy-quality-gate a chorus:Policy ;
    rdfs:label "Quality gate required before demo" ;
    rdfs:comment "Quality gate (hooks pass, no regression, no console.log in production code) must pass before /demo is called on a code card. Kade-owned. Enforced by /gate-quality skill + quality_gate.rs hook integration." ;
    chorus:derivedFrom chorus:principle-quality-at-source,
                       chorus:principle-produce-no-waste .

