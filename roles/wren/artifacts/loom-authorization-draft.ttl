@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix chorus:  <https://jeffbridwell.com/chorus#> .

# =============================================================================
# Loom Authorization Graph — DRAFT (Wren, 2026-04-22, #2348 sub-spike 1)
# =============================================================================
#
# Closes the orphan-skill + orphan-gate gaps by giving every skill and gate
# an upstream owner: a Role or a Practice.
#
# Status: DRAFT for review — not yet loaded into Fuseki.
# Targets merging into: roles/silas/ontology/chorus.ttl
#
# Scope of this phase (sub-spike 1 of #2348-expanded):
#   - Role → hasSkill + hasGate edges for wren, silas, kade
#   - First-pass Skill instances for the 39 ~/.claude/skills entries
#   - First-pass Gate instances for the 5 domain gates + key hook gates
#   - Orphan flag stays empty in this draft — pass 2 will flag anything here
#     that doesn't also have a Practice owner.
#
# Reference: roles/wren/artifacts/roles-domain-design.html (as-designed side)
# =============================================================================

# -----------------------------------------------------------------------------
# Classes (additions — Skill is new; Gate/Role already in chorus.ttl)
# -----------------------------------------------------------------------------

chorus:Skill a owl:Class ;
    rdfs:label "Skill" ;
    rdfs:comment "A named invocable procedure a role executes. Entry point into a pipeline of actions; contains hard gates, spine emission, and building logic. Invoked as /<slug>. Skills are attributes of roles and practices, not products." .

# -----------------------------------------------------------------------------
# Object properties
# -----------------------------------------------------------------------------

chorus:hasSkill a owl:ObjectProperty ;
    rdfs:label "has skill" ;
    rdfs:comment "A role or practice has a skill in its repertoire. Role hasSkill is the role's toolkit; Practice hasSkill is the named entry point that enacts the practice." ;
    rdfs:domain [ owl:unionOf ( chorus:Role chorus:Practice ) ] ;
    rdfs:range chorus:Skill .

chorus:hasGate a owl:ObjectProperty ;
    rdfs:label "has gate" ;
    rdfs:comment "A role or practice has a gate it runs or enforces. Role hasGate is the gate the role is authorized to evaluate; Practice hasGate is the gate that enforces the practice's invariant." ;
    rdfs:domain [ owl:unionOf ( chorus:Role chorus:Practice ) ] ;
    rdfs:range chorus:Gate .

chorus:authorizedBy a owl:ObjectProperty ;
    rdfs:label "authorized by" ;
    rdfs:comment "A skill or gate is authorized by a role or practice. Inverse of hasSkill / hasGate. Makes the orphan-query cheap: any Skill or Gate without an authorizedBy edge is an orphan." ;
    rdfs:domain [ owl:unionOf ( chorus:Skill chorus:Gate ) ] ;
    rdfs:range [ owl:unionOf ( chorus:Role chorus:Practice ) ] .

chorus:implementedIn a owl:ObjectProperty ;
    rdfs:label "implemented in" ;
    rdfs:comment "A skill or gate is implemented in a file. Path relative to chorus repo root (e.g., platform/scripts/cards, platform/services/chorus-hooks/src/gates/demo_gate.rs). Makes the Loom→Werk trace concrete." ;
    rdfs:domain [ owl:unionOf ( chorus:Skill chorus:Gate ) ] ;
    rdfs:range xsd:string .

# =============================================================================
# SKILL INSTANCES (39 total from ~/.claude/skills/)
# =============================================================================
#
# Grouped by category. Every skill gets an implementedIn path and an
# authorizedBy edge (pass 1 points everything at a role; pass 2 will refine
# to practice where appropriate).
# -----------------------------------------------------------------------------

# --- Build-flow skills (all roles use) ---

chorus:skill-pull a chorus:Skill ;
    rdfs:label "/pull" ;
    rdfs:comment "Single engineering entry point. Validate → preflight → WIP check → domain context → design gate → TDD readiness → move + declare + signal." ;
    chorus:implementedIn "~/.claude/skills/pull/SKILL.md" .

chorus:skill-demo a chorus:Skill ;
    rdfs:label "/demo" ;
    rdfs:comment "Proving gate — smoke check, prep summary, signal to Wren, builder cannot self-accept." ;
    chorus:implementedIn "~/.claude/skills/demo/SKILL.md" .

chorus:skill-acp a chorus:Skill ;
    rdfs:label "/acp" ;
    rdfs:comment "Accept + commit + push — full acceptance flow in one command." ;
    chorus:implementedIn "~/.claude/skills/acp/SKILL.md" .

chorus:skill-close a chorus:Skill ;
    rdfs:label "/close" ;
    rdfs:comment "Session close-out — Hard 5 (journal, board audit, activity log, next-session, commit)." ;
    chorus:implementedIn "~/.claude/skills/close/SKILL.md" .

chorus:skill-reboot a chorus:Skill ;
    rdfs:label "/reboot" ;
    rdfs:comment "Save memory, write next-session.md, commit, exit cleanly. Fires on context-rising alert." ;
    chorus:implementedIn "~/.claude/skills/reboot/SKILL.md" .

chorus:skill-jdi a chorus:Skill ;
    rdfs:label "/jdi" ;
    rdfs:comment "Just do it — execute the obvious next thing, no discussion. Delegates to /pull." ;
