# =============================================================================
# SUB-SPIKE 2 — PRACTICE AUTHORIZATION (hasSkill, hasGate edges)
# =============================================================================
#
# Each existing practice in chorus.ttl gets:
#   - chorus:hasSkill → the slash-command(s) that enact it (0..N)
#   - chorus:hasGate  → the gate(s) that enforce its invariant (0..N)
#
# Practices with no skill are process-only (brief-writing, domain-first,
# product-owner-aligned). Practices with no gate are unenforced — rely on
# role discipline. Both are valid states to declare explicitly.
# -----------------------------------------------------------------------------

# --- Session lifecycle practices ---

chorus:practice-session-opening
    chorus:hasSkill chorus:skill-listen .
    # Auto-injected via SessionStart hook; no direct skill invocation.
    # Orphan flag candidate: the opening practice has no enforcement gate —
    # today we rely on role discipline to produce the 5-beat shape. #2315
    # (Opener-shape contract) is the missing gate. Add when #2315 lands.

chorus:practice-close-out
    chorus:hasSkill chorus:skill-close, chorus:skill-reboot .

chorus:practice-pull-card
    chorus:hasSkill chorus:skill-pull, chorus:skill-jdi ;
    chorus:hasGate chorus:gate-tdd, chorus:gate-icd-write .
    # /jdi delegates to /pull — inherits the gate chain.

chorus:practice-demo
    chorus:hasSkill chorus:skill-demo ;
    chorus:hasGate chorus:gate-demo, chorus:gate-product .

chorus:practice-acp
    chorus:hasSkill chorus:skill-acp .
    # policy-no-self-acp enforces the builder/accepter separation —
    # enforcement is social/procedural, not a named Gate instance yet.
    # Sub-spike 3 candidate: materialize gate-no-self-acp in chorus-hooks.

chorus:practice-reboot
    chorus:hasSkill chorus:skill-reboot .

chorus:practice-brief-writing
    chorus:hasSkill chorus:skill-nudge .
    # Brief-writing is mostly manual (write file to briefs/), but /nudge
    # is the delivery leg. No enforcement gate today — depends on role
    # discipline to actually write the brief.

# --- Cross-role coordination ---

chorus:practice-nudge
    chorus:hasSkill chorus:skill-nudge .
    # DEC-107: persist-and-deliver dual-path contract. Enforced by
    # test coverage in chorus-hooks, not by a runtime gate yet.

chorus:practice-pair
    chorus:hasSkill chorus:skill-pair .
    # 60-second heartbeat is policy-response-window-60s — not yet
    # materialized as a gate. /pair-heartbeat-check skill missing (#2317).

chorus:practice-clearing
    chorus:hasSkill chorus:skill-clearing .

chorus:practice-chat
    chorus:hasSkill chorus:skill-chat, chorus:skill-chat-tick .

# --- Observation practices ---

chorus:practice-gemba
    chorus:hasSkill chorus:skill-gemba, chorus:skill-gemba-tick .

chorus:practice-mutual-observation
    chorus:hasSkill chorus:skill-lw, chorus:skill-ls, chorus:skill-lk,
                    chorus:skill-lc, chorus:skill-lm, chorus:skill-look .
    # Resolves the orphan-family flagged in sub-spike 1:
    # /lw /ls /lk /lc /lm /look all enact mutual-observation.

chorus:practice-interaction-pattern-detection
    chorus:hasSkill chorus:skill-chorus .
    # Pattern detection uses Chorus search + the nine-pattern table
    # in CLAUDE.md. No separate skill slug; /chorus is the query tool.

# --- Gate-evaluation practices (one per gate, as expected) ---

chorus:practice-gate-product
    chorus:hasSkill chorus:skill-gate-product ;
    chorus:hasGate chorus:gate-product .

chorus:practice-gate-code
    chorus:hasSkill chorus:skill-gate-code ;
    chorus:hasGate chorus:gate-code .

chorus:practice-gate-quality
    chorus:hasSkill chorus:skill-gate-quality ;
