    sh:property [ sh:path chorus:cdhash ; sh:minCount 1 ]  .

chorus:WerkSlotShape a sh:NodeShape ;
    sh:targetClass chorus:WerkSlot ;
    sh:property [ sh:path chorus:cardId ; sh:minCount 1 ]  .

chorus:MergeEventShape a sh:NodeShape ;
    sh:targetClass chorus:MergeEvent ;
    sh:property [ sh:path chorus:cardId ; sh:minCount 1 ]  .

chorus:ConflictHoldShape a sh:NodeShape ;
    sh:targetClass chorus:ConflictHold ;
    sh:property [ sh:path chorus:cardId ; sh:minCount 1 ] ;
    sh:property [ sh:path chorus:ts ; sh:minCount 1 ]  .

chorus:RecoveryActionShape a sh:NodeShape ;
    sh:targetClass chorus:RecoveryAction ;
    sh:property [ sh:path chorus:ts ; sh:minCount 1 ]  .

chorus:CardDiffShape a sh:NodeShape ;
    sh:targetClass chorus:CardDiff ;
    sh:property [ sh:path chorus:cardId ; sh:minCount 1 ]  .

chorus:QualityFindingShape a sh:NodeShape ;
    sh:targetClass chorus:QualityFinding ;
    sh:property [ sh:path chorus:cardId ; sh:minCount 1 ] ;
    sh:property [ sh:path chorus:ts ; sh:minCount 1 ]  .

chorus:SourceFileShape a sh:NodeShape ;
    sh:targetClass chorus:SourceFile ;
    sh:property [ sh:path chorus:filePath ; sh:minCount 1 ]  .

chorus:TestShape a sh:NodeShape ;
    sh:targetClass chorus:Test ;
    # #3570 — Test's instance HOME graph. owl-api resolve_instances_graph reads this declared
    # override (lib.rs:803) → serves /tests from urn:chorus:domains:tests, not the vague
    # urn:chorus:instances bucket. The 4617 Test instances are moved there to match. ("tests not
    # instances" — Jeff, 2026-06-22; the urn becomes meaningful, owl-api dictates it.)
    chorus:instancesGraph "urn:chorus:domains:tests" ;
    sh:property [ sh:path chorus:filePath ; sh:minCount 1 ] ;
    sh:property [ sh:path chorus:testName ; sh:minCount 1 ]  .

chorus:TestSuiteRunShape a sh:NodeShape ;
    sh:targetClass chorus:TestSuiteRun ;
    sh:property [ sh:path chorus:cardId ; sh:minCount 1 ] ;
    sh:property [ sh:path chorus:ts ; sh:minCount 1 ] ;
    sh:property [ sh:path chorus:result ; sh:minCount 1 ]  .

chorus:TestResultShape a sh:NodeShape ;
    sh:targetClass chorus:TestResult ;
    sh:property [ sh:path chorus:filePath ; sh:minCount 1 ] ;
    sh:property [ sh:path chorus:testName ; sh:minCount 1 ] ;
    sh:property [ sh:path chorus:result ; sh:minCount 1 ]  .

chorus:TestEdgesShape a sh:NodeShape ;
    sh:targetClass chorus:Test ;
    sh:property [ sh:path chorus:inFile ; sh:minCount 1 ; sh:class chorus:SourceFile ] ;
    sh:property [ sh:path chorus:covers ; sh:minCount 1 ; sh:class chorus:Domain ] ;          # #2819 — covers a real Domain (was SubDomain/V1); THIS is the cross-domain join target
    sh:property [ sh:path chorus:pyramidLayer ; sh:minCount 1 ; sh:in ( "unit" "integration" "e2e" "contract" "fitness" "smoke" "bdd" ) ] ;
    # validityClass + hermeticity: enum-if-present (NO minCount — ingestion mints identity
    # before the tagging pass classifies; a freshly-crawled Test is legitimately untagged).
    sh:property [ sh:path chorus:validityClass ; sh:in ( "valid" "asserts-retired-behavior" "passes-by-definition" "integration-not-gated" ) ] ;
    sh:property [ sh:path chorus:hermeticity ; sh:in ( "hermetic" "needs-stack" ) ] ;
    # testConcern (#3540): the orthogonal CONCERN axis, optional (a test may have no concern).
    sh:property [ sh:path chorus:testConcern ; sh:in ( "api" "ui" "perf" "security" ) ] ;
    # quarantine (#2530): the three props served + carried; optional (most tests aren't held).
    # Conditional requirement (reason+until iff quarantined) lives in QuarantineShape below.
    sh:property [ sh:path chorus:quarantined ; sh:datatype xsd:boolean ] ;
    sh:property [ sh:path chorus:quarantineReason ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:quarantineUntil ; sh:datatype xsd:date ] .

# A quarantine is never silent: if quarantined=true, BOTH a reason and an expiry
# are required (#2530). SHACL conditional — either not-quarantined, or both set.
chorus:QuarantineShape a sh:NodeShape ;
    sh:targetClass chorus:Test ;
    sh:or (
        [ sh:not [ sh:path chorus:quarantined ; sh:hasValue true ] ]
        [ sh:and (
            [ sh:path chorus:quarantineReason ; sh:minCount 1 ]
            [ sh:path chorus:quarantineUntil ; sh:minCount 1 ]
        ) ]
    ) .

chorus:VerbRunEdgesShape a sh:NodeShape ;
    sh:targetClass chorus:VerbRun ;
    sh:property [ sh:path chorus:refusedWith ; sh:class chorus:TypedRefusal ] .

chorus:ScenarioVerifiedByShape a sh:NodeShape ;
    sh:targetClass chorus:Scenario ;
    sh:property [ sh:path chorus:verifiedBy ; sh:class chorus:Test ] .

chorus:TestResultEdgesShape a sh:NodeShape ;
    sh:targetClass chorus:TestResult ;
    sh:property [ sh:path chorus:ofTest ; sh:minCount 1 ; sh:class chorus:Test ] .

chorus:ofTest a owl:ObjectProperty ;
    rdfs:label "of test" ;
    rdfs:domain chorus:TestResult ; rdfs:range chorus:Test ;
    rdfs:comment "TestResult -> its Test. The FK that makes the result chain joinable; required by shape." .

