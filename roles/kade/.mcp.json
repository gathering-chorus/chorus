{
  "$schema": "https://schemas.modelcontextprotocol.io/mcp.schema.json",
  "mcpServers": {
    "chorus-api": {
      "type": "http",
      "url": "http://localhost:3341/mcp",
      "headers": {
        "X-Chorus-Role": "kade"
      }
    },
    "cclsp": {
      "command": "cclsp",
      "args": ["--config", "/Users/jeffbridwell/CascadeProjects/chorus/cclsp.json"]
    },
    "ast-grep": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/ast-grep/ast-grep-mcp",
        "ast-grep-server"
      ]
    }
  }
}
