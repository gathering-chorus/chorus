# #3619 — lock chorus/trace + chorus/index. APPLY ONLY AFTER this branch
# lands and deploys: the callers (chorus-sdk maybeFireTrace, shim-wrapper
# role-state bridge — token-wired in this branch; heartbeat-probe.sh —
# token-wired at flip time) must carry tokens BEFORE these gates flip
# (deploy-before-require, #3573).
@prefix chorus: <https://jeffbridwell.com/chorus#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

chorus:surface-trace-write a chorus:APISurface ;
    rdfs:label "chorus-api trace write (SDK + shim callers, token-wired #3619)" ;
    chorus:securedBy chorus:gate-chorus-api-mutations ;
    chorus:httpMethod "POST" ;
    chorus:pathPrefix "/api/chorus/trace" ;
    chorus:requiresScope "urn:chorus:ops" ;
    chorus:servedBy chorus:services .

chorus:surface-index-poke-write a chorus:APISurface ;
    rdfs:label "chorus-api index poke write (heartbeat-probe caller, token-wired #3619)" ;
    chorus:securedBy chorus:gate-chorus-api-mutations ;
    chorus:httpMethod "POST" ;
    chorus:pathPrefix "/api/chorus/index" ;
    chorus:requiresScope "urn:chorus:index" ;
    chorus:servedBy chorus:services .
