    chorus:ceremonyRisk false .

chorus:practice-mutual-observation a chorus:Practice ;
    rdfs:label "Mutual observation (roles watch roles)" ;
    rdfs:comment "Roles tail each other's sessions on idle cycles. Attention is commentary, not watching. Skills: /lw /ls /lk /lc /lm. If no role observes, the system is blind and Jeff becomes the eyes (Attention Contract rule 7)." ;
    chorus:expresses chorus:principle-observe-and-interact,
                     chorus:principle-focus-is-infrastructure ;
    chorus:ceremonyRisk false .

chorus:practice-interaction-pattern-detection a chorus:Practice ;
    rdfs:label "Interaction pattern detection" ;
    rdfs:comment "Wren detects which of 9 patterns Jeff is in (direction/ideation/demo/triage/swat/gemba/clearing/story/reflection) and emits spine event. Not announced to Jeff — silent instrumentation feeding Borg." ;
    chorus:expresses chorus:principle-observe-and-interact,
                     chorus:principle-interrogate-the-data ;
    chorus:operationalizes chorus:policy-interaction-pattern ;
    chorus:ceremonyRisk false .

# --- New practices — quality / rigor ---

chorus:practice-gate-product a chorus:Practice ;
    rdfs:label "Gate: product (Wren)" ;
    rdfs:comment "Verify AC complete, demo evidence, domain visibility, spine contract. Wren only. Skill: /gate-product." ;
    chorus:expresses chorus:principle-quality-at-source,
                     chorus:principle-obtain-a-yield ;
    chorus:operationalizes chorus:policy-demo-gate ;
    chorus:ceremonyRisk false .

chorus:practice-gate-code a chorus:Practice ;
    rdfs:label "Gate: code (Kade)" ;
    rdfs:comment "Verify tests green, build clean, no new warnings. Kade only. Skill: /gate-code." ;
    chorus:expresses chorus:principle-quality-at-source,
                     chorus:principle-speed-and-quality-correlate ;
    chorus:operationalizes chorus:policy-tdd-gate,
                           chorus:policy-quality-gate ;
    chorus:ceremonyRisk false .

chorus:practice-gate-quality a chorus:Practice ;
    rdfs:label "Gate: quality (Kade)" ;
    rdfs:comment "Verify hooks pass, no regression, no console.log in production code. Kade only. Skill: /gate-quality." ;
    chorus:expresses chorus:principle-quality-at-source,
                     chorus:principle-produce-no-waste ;
    chorus:operationalizes chorus:policy-quality-gate ;
    chorus:ceremonyRisk false .

chorus:practice-gate-arch a chorus:Practice ;
    rdfs:label "Gate: architecture (Silas)" ;
    rdfs:comment "Verify system fit, namespace conventions, ICD consistency, domain boundaries. Silas only. Skill: /gate-arch." ;
    chorus:expresses chorus:principle-services-reliable-bounded-idempotent,
                     chorus:principle-design-from-patterns-to-details ;
    chorus:operationalizes chorus:policy-icd-write-gate ;
    chorus:ceremonyRisk false .

chorus:practice-gate-ops a chorus:Practice ;
    rdfs:label "Gate: operations (Silas)" ;
    rdfs:comment "Verify deploy safety, health checks, log flow, rollback path. Silas only. Fires at deploy, not code-complete. Skill: /gate-ops." ;
    chorus:expresses chorus:principle-services-reliable-bounded-idempotent,
                     chorus:principle-self-healing ;
    chorus:operationalizes chorus:policy-ops-awareness ;
    chorus:ceremonyRisk false .

chorus:practice-stop-the-line a chorus:Practice ;
    rdfs:label "Stop the line" ;
    rdfs:comment "Friction triggers a fix card in the same response. Don't work around + gripe. PostToolUse hook (planned) blocks turn on tool errors, forces resolve/card/defer. Memory: feedback_stop_the_line." ;
    chorus:expresses chorus:principle-quality-at-source,
                     chorus:principle-apply-self-regulation-and-accept-feedback ;
    chorus:operationalizes chorus:policy-stop-on-error ;
    chorus:ceremonyRisk false .

# --- New practices — state / andon ---

chorus:practice-andon-state a chorus:Practice ;
    rdfs:label "Andon state declaration" ;
    rdfs:comment "Declare state at transitions via role-state: building / blocked / waiting / observing / idle. Silence ≠ idle — idle is a declared state (Attention Contract rule 3)." ;
    chorus:expresses chorus:principle-no-dark-work,
                     chorus:principle-observe-and-interact ;
    chorus:ceremonyRisk false .

chorus:practice-idle-awareness a chorus:Practice ;
    rdfs:label "Idle awareness (no poll)" ;
    rdfs:comment "Never idle-poll. If a background task runs: check seeds, update state files, read briefs. Don't auto-pull new cards." ;
    chorus:expresses chorus:principle-protect-attention,
                     chorus:principle-use-and-value-renewable-resources ;
    chorus:operationalizes chorus:policy-autonomy-guard ;
    chorus:ceremonyRisk false .

chorus:practice-signal-not-narrate a chorus:Practice ;
    rdfs:label "Signal not narrate" ;
    rdfs:comment "Narrate outcomes, not steps. Don't announce what you're about to do — execute, then report result. Terminal visual noise discipline." ;
    chorus:expresses chorus:principle-protect-attention,
                     chorus:principle-use-small-and-slow-solutions ;
    chorus:ceremonyRisk false .

chorus:practice-wall-clock-refresh a chorus:Practice ;
    rdfs:label "Wall-clock refresh per response" ;
    rdfs:comment "Refresh the Chorus-prompt timestamp every response — never cache. Stale timestamps cascade into wrong escalation decisions (#1559)." ;
    chorus:expresses chorus:principle-interrogate-the-data,
                     chorus:principle-observe-and-interact ;
    chorus:ceremonyRisk false .

# --- New practices — memory / search ---

chorus:practice-chorus-search-first a chorus:Practice ;
    rdfs:label "Chorus search before filesystem" ;
    rdfs:comment "Search order: Chorus → codebase graph → filesystem. Guard hook enforces. DEC-074. Memory: feedback_chorus_search_first." ;
    chorus:expresses chorus:principle-catch-and-store-energy,
                     chorus:principle-use-and-value-renewable-resources ;
    chorus:operationalizes chorus:policy-memory-first-search ;
    chorus:ceremonyRisk false .

chorus:practice-story-capture a chorus:Practice ;
    rdfs:label "Story capture (personal → TTL)" ;
    rdfs:comment "When Jeff shares something personal, capture as a story TTL linked to principles via rdfs:seeAlso. Stories feed Self ontology and Chorus narrative." ;
    chorus:expresses chorus:principle-catch-and-store-energy,
                     chorus:principle-use-and-value-diversity ;
    chorus:operationalizes chorus:policy-story-write-gate ;
    chorus:ceremonyRisk false .

chorus:practice-retro a chorus:Practice ;
    rdfs:label "Retro (team retrospective)" ;
    rdfs:comment "Team retrospective — surface patterns, update principles/policies/practices, retire ceremony. Skill: /retro." ;
    chorus:expresses chorus:principle-apply-self-regulation-and-accept-feedback,
                     chorus:principle-creatively-use-and-respond-to-change ;
    chorus:ceremonyRisk false .

chorus:practice-board-sweep a chorus:Practice ;
    rdfs:label "Board sweep (coherence audit)" ;
    rdfs:comment "Find and fix untagged, duplicate, and stale cards. Scheduled or on-demand. Skill: /board-sweep." ;
    chorus:expresses chorus:principle-produce-no-waste,
                     chorus:principle-creatively-use-and-respond-to-change ;
    chorus:ceremonyRisk false .

chorus:practice-werk a chorus:Practice ;
    rdfs:label "Werk dashboard (work state)" ;
    rdfs:comment "Live work-state dashboard — WIP, blocks, pending accepts, staleness. Skill: /werk." ;
    chorus:expresses chorus:principle-no-dark-work,
                     chorus:principle-observe-and-interact ;
    chorus:ceremonyRisk false .

# --- New practices — meta ---

chorus:practice-context-injection a chorus:Practice ;
    rdfs:label "Context injection (SessionStart)" ;
    rdfs:comment "SessionStart hook assembles pulse + spine + athena into envelope, injected into role's first turn. Role reads envelope, not state files. Sync-via-artifacts, not recap." ;
    chorus:expresses chorus:principle-catch-and-store-energy,
                     chorus:principle-self-healing ;
    chorus:operationalizes chorus:policy-context-inject ;
    chorus:ceremonyRisk false .

chorus:practice-2-touch-target a chorus:Practice ;
    rdfs:label "2-touch-per-card target" ;
    rdfs:comment "Jeff's coordination target: 2 touches per card (start + accept). Every re-nudge = failure of the Attention Contract." ;
    chorus:expresses chorus:principle-protect-attention ;
    chorus:operationalizes chorus:policy-working-hours ;
    chorus:ceremonyRisk false .

chorus:practice-domain-context-before-code a chorus:Practice ;
    rdfs:label "Domain context before code" ;
    rdfs:comment "Read domain state (completeness, actors, edges) before writing code. /pull step 4 enforces. No building blind." ;
    chorus:expresses chorus:principle-design-from-patterns-to-details,
                     chorus:principle-interrogate-the-data ;
    chorus:ceremonyRisk false .

chorus:practice-verify-before-asserting a chorus:Practice ;
    rdfs:label "Verify before asserting" ;
    rdfs:comment "Check the data before claiming something is fine. False assertions put Jeff in the loop. Memory: feedback_verify_before_asserting." ;
    chorus:expresses chorus:principle-interrogate-the-data,
                     chorus:principle-apply-self-regulation-and-accept-feedback ;
    chorus:ceremonyRisk false .

# --- Abstract principles flagged (no practice enacts them) ---

chorus:principle-use-edges-and-value-the-marginal
    chorus:abstract true .

# --- Expanded contains edges (additive) ---

chorus:loom-practices chorus:contains
