    # node — no verb-* nodes exist, and skill-werk is retired by #3423. Silas to add the
    # accept-verb node + re-point practice-acp in the governed practice-accept follow-on.
    chorus:expresses chorus:principle-artifacts,
                     chorus:principle-no-dark-work ;
    chorus:operationalizes chorus:policy-accept-gate ;
    chorus:ceremonyRisk false .

chorus:practice-reboot a chorus:Practice ;
    rdfs:label "Reboot (save memory, write next-session, exit)" ;
    rdfs:comment "Triggered on context-rising alert or 'reboot' directive. Writes next-session.md + commits + exits cleanly so the next session can pick up without Jeff recap. Skill: /reboot." ;
    chorus:expresses chorus:principle-catch-and-store-energy,
                     chorus:principle-self-healing ;
    chorus:ceremonyRisk false .

