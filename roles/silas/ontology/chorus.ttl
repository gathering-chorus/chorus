    chorus:practice-gemba, chorus:practice-mutual-observation, chorus:practice-interaction-pattern-detection,
    chorus:practice-gate-product, chorus:practice-gate-code, chorus:practice-gate-quality,
    chorus:practice-gate-arch, chorus:practice-gate-ops, chorus:practice-stop-the-line,
    chorus:practice-andon-state, chorus:practice-idle-awareness, chorus:practice-signal-not-narrate,
    chorus:practice-wall-clock-refresh,
    chorus:practice-chorus-search-first, chorus:practice-story-capture, chorus:practice-retro,
    chorus:practice-board-sweep, chorus:practice-werk,
    chorus:practice-context-injection, chorus:practice-2-touch-target,
    chorus:practice-domain-context-before-code, chorus:practice-verify-before-asserting .

# =============================================================================
# SKILLS, GATES, ROLE + PRACTICE EDGES
# =============================================================================
# #2348 sub-spikes 1+2 merged 2026-04-22. Wren drafted, Silas reviewed.
#
# Vocabulary:
#   chorus:Skill          — named invocable procedure (/<slug>)
#   chorus:UtilitySkill   — utility skills (not practice-owned)
#   chorus:hasSkill       — Role|Practice → Skill
#   chorus:hasGate        — Role|Practice → Gate
#   chorus:authorizedBy   — Skill|Gate → Role|Practice (inverse)
#   chorus:implementedIn  — Skill|Gate → file path (xsd:string, for now)
#
# Orphan queries:
#   Gates without authority:
#     SELECT ?g WHERE { ?g a chorus:Gate .
#                       FILTER NOT EXISTS { [] chorus:hasGate ?g } }
#   Skills without practice (excluding utilities):
#     SELECT ?s WHERE { ?s a chorus:Skill .
#                       FILTER NOT EXISTS { ?s a chorus:UtilitySkill }
#                       FILTER NOT EXISTS { [] chorus:hasSkill ?s } }
# =============================================================================

