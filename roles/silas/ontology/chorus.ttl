# =============================================================================
# 5. ARTIFACTS
# =============================================================================

chorus:ArtifactType a owl:Class ;
    rdfs:label "Artifact Type" ;
    rdfs:comment "Classification of work products by their role in the flow." .

chorus:Card a chorus:ArtifactType ;
    rdfs:label "Card" ;
    rdfs:comment "Kanban board item. Entry point for pipeline work." .

chorus:Brief a chorus:ArtifactType ;
    rdfs:label "Brief" ;
    rdfs:comment "Structured document in recipient's briefs/ directory. Carries substance." .

chorus:ADR a chorus:ArtifactType ;
    rdfs:label "ADR" ;
    rdfs:comment "Architectural Decision Record. The why behind structural choices." .

chorus:Commit a chorus:ArtifactType ;
    rdfs:label "Commit" ;
    rdfs:comment "Git commit with card reference. (#N) = Gathering, (C#N) = Chorus." .

chorus:Signal a chorus:ArtifactType ;
    rdfs:label "Signal" ;
    rdfs:comment "Slack message. Ephemeral notification." .

chorus:Screenshot a chorus:ArtifactType ;
    rdfs:label "Screenshot" ;
    rdfs:comment "Visual proof of shipped work. Required at Build Gate." .

chorus:Decision a chorus:ArtifactType ;
    rdfs:label "Decision" ;
    rdfs:comment "A recorded choice that constrains future behavior. DEC-NNN in decisions.md." .

# =============================================================================
# 6. HANDOFFS (C#43)
# =============================================================================

chorus:Handoff a owl:Class ;
    rdfs:label "Handoff" ;
    rdfs:comment "Observable evidence that work moved between roles. Three properties: sent (timestamped), received (confirmed), visible (gaps surface automatically)." .

chorus:HandoffType a owl:Class ;
    rdfs:label "Handoff Type" .

chorus:BriefHandoff a chorus:HandoffType ;
    rdfs:label "Brief (Handoff)" ;
    rdfs:comment "File written to target role's briefs/ directory." .

chorus:WorkflowHandoff a chorus:HandoffType ;
    rdfs:label "Workflow Step" ;
    rdfs:comment "workflow-ts advance — step completion routes to next role." .

chorus:DecisionHandoff a chorus:HandoffType ;
    rdfs:label "Decision (Handoff)" ;
    rdfs:comment "Decision made in Clearing or conversation, routed to affected role." .

chorus:HandoffStatus a owl:Class ;
    rdfs:label "Handoff Status" .

chorus:Sent a chorus:HandoffStatus ;
    rdfs:label "Sent" .

chorus:Received a chorus:HandoffStatus ;
    rdfs:label "Received" .

chorus:Stale a chorus:HandoffStatus ;
    rdfs:label "Stale" ;
    rdfs:comment "Sent but not received after threshold (4h during work hours)." .

# =============================================================================
# 7. GATES
# =============================================================================

chorus:Gate a owl:Class ;
    rdfs:label "Gate" ;
    rdfs:comment "Quality gate between vertebrae. Failures bounce work backward." .

chorus:GateResult a owl:Class ;
    rdfs:label "Gate Result" .

chorus:Pass a chorus:GateResult ; rdfs:label "Pass" .
chorus:Fail a chorus:GateResult ; rdfs:label "Fail" .
chorus:Override a chorus:GateResult ;
    rdfs:label "Override" ;
    rdfs:comment "Gate failed but Jeff overrode. Tracked for trust metrics." .

chorus:DirectionGate a chorus:Gate ;
    rdfs:label "Direction Gate" ;
    chorus:fromStage chorus:Directing ;
    chorus:toStage chorus:Designing ;
    chorus:gatekeeper chorus:jeff .

chorus:DesignGate a chorus:Gate ;
    rdfs:label "Design Gate" ;
    chorus:fromStage chorus:Designing ;
    chorus:toStage chorus:Building ;
    chorus:gatekeeper chorus:silas .

chorus:BuildGate a chorus:Gate ;
    rdfs:label "Build Gate" ;
    chorus:fromStage chorus:Building ;
    chorus:toStage chorus:Proving ;
    chorus:gatekeeper chorus:kade .

chorus:ProvingGate a chorus:Gate ;
    rdfs:label "Proving Gate" ;
    chorus:fromStage chorus:Proving ;
    chorus:gatekeeper chorus:jeff .

# =============================================================================
# 8. WORKFLOWS
# =============================================================================

chorus:Workflow a owl:Class ;
    rdfs:label "Workflow" ;
    rdfs:comment "Sequenced execution of a decision across roles. WF-NNN manifests." .

chorus:Step a owl:Class ;
    rdfs:label "Step" ;
    rdfs:comment "A unit of work within a workflow. Assigned to one role, produces artifacts." .

chorus:WorkItem a owl:Class ;
    rdfs:label "Work Item" ;
    rdfs:comment "A unit of work flowing through the spine. Linked to a card." .

chorus:StageTransition a owl:Class ;
    rdfs:label "Stage Transition" ;
    rdfs:comment "Record of a work item moving between vertebrae." .

chorus:BounceBack a owl:Class ;
    rdfs:subClassOf chorus:StageTransition ;
    rdfs:label "Bounce Back" ;
    rdfs:comment "Work returned to a prior stage after gate failure." .

# =============================================================================
# 9. TRUST + FITNESS
# =============================================================================

chorus:TrustMetric a owl:Class ;
    rdfs:label "Trust Metric" ;
    rdfs:comment "Emergent measure of system reliability. Computed from gate passages and handoff health." .

chorus:GatePassRate a chorus:TrustMetric ;
    rdfs:label "Gate Pass Rate" .

chorus:BounceRate a chorus:TrustMetric ;
    rdfs:label "Bounce Rate" .

chorus:OverrideRate a chorus:TrustMetric ;
    rdfs:label "Override Rate" .

chorus:HandoffReceiptRate a chorus:TrustMetric ;
    rdfs:label "Handoff Receipt Rate" ;
    rdfs:comment "Handoffs received / handoffs sent. Per role. Low rate = broken connection." .

chorus:FitnessFunction a owl:Class ;
    rdfs:label "Fitness Function" ;
    rdfs:comment "Testable assertion about team behavior. If this fails, the protocol has drifted." .

chorus:Principle a owl:Class ;
    rdfs:label "Principle" ;
    rdfs:comment "A shared value. Stable. Patterns derive from principles." .

chorus:Practice a owl:Class ;
    rdfs:label "Practice" ;
    rdfs:comment "A repeatable discipline derived from principles. How the team works." .

chorus:Policy a owl:Class ;
    rdfs:label "Policy" ;
    rdfs:comment "A binary team rule — allowed/blocked, in-bounds/out-of-bounds. Derived from principles but enforceable as yes/no (unlike practices, which are disciplines). Examples: working hours, WIP limits, response windows, touch-count targets." .

chorus:Skill a owl:Class ;
    rdfs:label "Skill" ;
    rdfs:comment "A named invocable procedure a role executes. Entry point into a pipeline of actions; contains hard gates, spine emission, and building logic. Invoked as /<slug>. Skills are attributes of roles and practices, not products. #2348." .

chorus:UtilitySkill a owl:Class ;
    rdfs:subClassOf chorus:Skill ;
    rdfs:label "Utility Skill" ;
    rdfs:comment "A skill that provides a utility action (open tab, share, listen, simplify, check-seeds, interrupt, cron-tick) and is not an enactment of a specific practice. Subclass exists so the orphan-skill query honestly excludes utilities: FILTER NOT EXISTS { ?s a chorus:UtilitySkill }. #2348 sub-spike 3A." .

# --- Security domain classes (#2659) ---

chorus:Credential a owl:Class ;
    rdfs:label "Credential" ;
    rdfs:comment "A secret value or token used to authenticate. Schema only — actual credential values never live in the graph; instances reference source location (env-var name, plist key, keychain item) and metadata. #2659." .

chorus:Permission a owl:Class ;
    rdfs:label "Permission" ;
    rdfs:comment "An authorization rule binding a subject (role or domain) to an action on a resource. Explicit-grant true = whitelist (allow); false = denial (blacklist). Conditions narrow the rule (env, time-of-day, resource pattern). #2659." .

chorus:SecurityProbe a owl:Class ;
    rdfs:label "Security Probe" ;
    rdfs:comment "A health or monitoring signal scoped to security posture — credential expiry, port exposure, hook bypass count, write-scrubber match rate. Framing class names whether the probe reports a symptom, a cause, or a steady-state status. #2659." .

chorus:AuthBoundary a owl:Class ;
    rdfs:label "Auth Boundary" ;
    rdfs:comment "A trust edge between two domains where authentication or integrity is verified. Captures check type, env vars that disable the check (bypass), and whether a bypass emits a spine audit event. #2659." .

# --- Security domain properties (#2659) ---

chorus:scope a owl:DatatypeProperty ;
    rdfs:label "scope" ;
    rdfs:comment "Credential scope: 'session' | 'service' | 'system' | 'external'. Drives rotation cadence and blast radius assessment." ;
    rdfs:domain chorus:Credential ;
    rdfs:range xsd:string .

chorus:rotationPolicy a owl:DatatypeProperty ;
    rdfs:label "rotation policy" ;
    rdfs:comment "Free-text rotation cadence and trigger (e.g., '90d', 'on-leak', 'manual', 'launchd-restart')." ;
    rdfs:domain chorus:Credential ;
    rdfs:range xsd:string .

chorus:severityIfLeaked a owl:DatatypeProperty ;
    rdfs:label "severity if leaked" ;
    rdfs:comment "Blast radius if credential is exposed: 'low' | 'medium' | 'high' | 'critical'." ;
    rdfs:domain chorus:Credential ;
    rdfs:range xsd:string .

chorus:source a owl:DatatypeProperty ;
    rdfs:label "source" ;
    rdfs:comment "Where the credential lives at runtime: 'env-var' | 'plist' | 'keychain' | 'fuseki' | 'external'. Names the surface, not the value." ;
    rdfs:domain chorus:Credential ;
    rdfs:range xsd:string .

chorus:ownerRole a owl:ObjectProperty ;
    rdfs:label "owner role" ;
    rdfs:comment "The role accountable for the security artifact (credential rotation, probe response, boundary integrity). Distinct from chorus:ownedBy on SubDomains." ;
    rdfs:domain [ owl:unionOf ( chorus:Credential chorus:SecurityProbe ) ] ;
    rdfs:range chorus:Role .

chorus:subject a owl:ObjectProperty ;
    rdfs:label "subject" ;
    rdfs:comment "The actor (role or sub-domain) the permission applies to." ;
    rdfs:domain chorus:Permission ;
    rdfs:range [ owl:unionOf ( chorus:Role chorus:SubDomain ) ] .

chorus:action a owl:DatatypeProperty ;
    rdfs:label "action" ;
    rdfs:comment "The verb the permission grants or denies (e.g., 'read', 'write', 'deploy', 'kickstart', 'commit-to-main')." ;
    rdfs:domain chorus:Permission ;
    rdfs:range xsd:string .

chorus:resource a owl:DatatypeProperty ;
    rdfs:label "resource" ;
    rdfs:comment "The object the permission binds to. URI when graph-resolvable (a SubDomain, Service); string when a path glob, env name, or external resource." ;
    rdfs:domain chorus:Permission ;
    rdfs:range xsd:string .

chorus:conditions a owl:DatatypeProperty ;
    rdfs:label "conditions" ;
    rdfs:comment "Free-text predicates that narrow the rule (env=='prod', requires-mfa, branch=='main')." ;
    rdfs:domain chorus:Permission ;
    rdfs:range xsd:string .

chorus:explicitGrant a owl:DatatypeProperty ;
    rdfs:label "explicit grant" ;
    rdfs:comment "Boolean. true = whitelist (rule allows); false = blacklist (rule denies). Default closed-world: absence of an explicit grant denies." ;
    rdfs:domain chorus:Permission ;
    rdfs:range xsd:boolean .

chorus:target a owl:DatatypeProperty ;
    rdfs:label "target" ;
    rdfs:comment "What the security probe observes (port, file path, env var name, service URL)." ;
    rdfs:domain chorus:SecurityProbe ;
    rdfs:range xsd:string .

chorus:signalType a owl:DatatypeProperty ;
    rdfs:label "signal type" ;
    rdfs:comment "How the signal arrives (e.g., 'expiry-check', 'log-pattern', 'http-probe', 'fs-watch')." ;
    rdfs:domain chorus:SecurityProbe ;
    rdfs:range xsd:string .

chorus:framingClass a owl:DatatypeProperty ;
    rdfs:label "framing class" ;
    rdfs:comment "Whether the probe reports a 'symptom' (downstream effect), 'cause' (root condition), or 'status' (steady-state posture). Forces probes to declare their layer; mirrors the alert-ladder discipline." ;
    rdfs:domain chorus:SecurityProbe ;
    rdfs:range xsd:string .

chorus:severity a owl:DatatypeProperty ;
    rdfs:label "severity" ;
    rdfs:comment "Probe severity when firing: 'info' | 'warn' | 'critical'." ;
    rdfs:domain chorus:SecurityProbe ;
    rdfs:range xsd:string .

chorus:sourceAlert a owl:ObjectProperty ;
    rdfs:label "source alert" ;
    rdfs:comment "If the security probe is materialized from an alert rule, this links to the alert. Optional." ;
    rdfs:domain chorus:SecurityProbe .

chorus:betweenDomainA a owl:ObjectProperty ;
    rdfs:label "between domain a" ;
    rdfs:comment "One side of the auth boundary. The boundary is symmetric in declaration but the direction of trust may not be — see chorus:checkType." ;
    rdfs:domain chorus:AuthBoundary ;
    rdfs:range chorus:SubDomain .

chorus:betweenDomainB a owl:ObjectProperty ;
    rdfs:label "between domain b" ;
    rdfs:comment "The other side of the auth boundary." ;
    rdfs:domain chorus:AuthBoundary ;
    rdfs:range chorus:SubDomain .

chorus:checkType a owl:DatatypeProperty ;
    rdfs:label "check type" ;
    rdfs:comment "Verification mechanism at the boundary: 'header' | 'signature' | 'ledger' | 'ad-hoc'. 'ad-hoc' is a smell — boundaries with ad-hoc checks are migration candidates." ;
    rdfs:domain chorus:AuthBoundary ;
    rdfs:range xsd:string .

chorus:bypassEnvs a owl:DatatypeProperty ;
    rdfs:label "bypass envs" ;
    rdfs:comment "Env var names (comma-separated) that, when set, disable the check. Empty string = no bypass. Listing them in the graph forces them to be visible." ;
    rdfs:domain chorus:AuthBoundary ;
    rdfs:range xsd:string .

chorus:bypassAudit a owl:DatatypeProperty ;
    rdfs:label "bypass audit" ;
    rdfs:comment "Boolean. true = bypass emits a spine event (auditable); false = bypass is silent (a debt to repay). Mirrors ADR-028 §schema-write hook bypass discipline." ;
    rdfs:domain chorus:AuthBoundary ;
    rdfs:range xsd:boolean .

# --- Security domain SHACL (#2659) ---

chorus:CredentialShape a sh:NodeShape ;
    sh:targetClass chorus:Credential ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path chorus:scope ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path chorus:source ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] .

chorus:PermissionShape a sh:NodeShape ;
    sh:targetClass chorus:Permission ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path chorus:subject ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path chorus:action ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path chorus:resource ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path chorus:explicitGrant ;
        sh:minCount 1 ;
        sh:datatype xsd:boolean ;
    ] .

chorus:SecurityProbeShape a sh:NodeShape ;
    sh:targetClass chorus:SecurityProbe ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path chorus:target ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path chorus:framingClass ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] .

chorus:AuthBoundaryShape a sh:NodeShape ;
    sh:targetClass chorus:AuthBoundary ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path chorus:betweenDomainA ;
        sh:minCount 1 ;
        sh:class chorus:SubDomain ;
    ] ;
    sh:property [
        sh:path chorus:betweenDomainB ;
        sh:minCount 1 ;
        sh:class chorus:SubDomain ;
    ] ;
    sh:property [
        sh:path chorus:checkType ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] .

# --- Properties domain — config-as-data (#3433) ---
# A Property is a single config datum (key/value) attached to ANY structural
# node via chorus:hasProperty, read by generic engines so a config change is a
# MODEL WRITE, not a code change. Only VARYING config is a Property; invariant
# logic stays code. Effective config resolves by specificity (Service > Domain
# > Product > ValueStream/Step), nearest override wins. owl-api generate("Property")
# mints the read/write surface via the same generic generator as Domain.

chorus:Property a owl:Class ;
    rdfs:label "Property" ;
    rdfs:comment "A single configuration datum (key/value) attached to a structural node. Config-as-data: changing behavior is a model write, not a code change. #3433." .

chorus:hasProperty a owl:ObjectProperty ;
    rdfs:label "has property" ;
    rdfs:comment "Attaches a config Property to any structural node it configures — uniform across the model. Effective value resolves by specificity (Service > Domain > Product > ValueStream/Step), nearest override wins. #3433." ;
    rdfs:domain [ owl:unionOf ( chorus:ValueStream chorus:ValueStreamStep chorus:Product chorus:Domain chorus:SubDomain chorus:Service ) ] ;
    rdfs:range chorus:Property .

chorus:propertyKey a owl:DatatypeProperty ;
    rdfs:label "key" ;
    rdfs:comment "Dotted config key, e.g. 'alert.threshold', 'deploy.units'. #3433." ;
    rdfs:domain chorus:Property ;
    rdfs:range xsd:string .

chorus:propertyValue a owl:DatatypeProperty ;
    rdfs:label "value" ;
    rdfs:comment "String-encoded value; propertyValueType says how to read it. #3433." ;
    rdfs:domain chorus:Property ;
    rdfs:range xsd:string .

chorus:propertyValueType a owl:DatatypeProperty ;
    rdfs:label "value type" ;
    rdfs:comment "How to interpret value: string | int | bool | json | list. #3433." ;
    rdfs:domain chorus:Property ;
    rdfs:range xsd:string .

chorus:propertyScope a owl:DatatypeProperty ;
    rdfs:label "property scope" ;
    rdfs:comment "Resolution specificity of this config datum: 'global' | 'machine' | 'role' | 'instance'. The cascade resolves nearest-wins (Service > Domain > Product > ValueStream/Step). Property-OWN scope — distinct from chorus:scope, which is credential-rotation scope (a different concept on a different class). #3433." ;
    rdfs:domain chorus:Property ;
    rdfs:range xsd:string .

# ownedBy (the role responsible) MAY cross-cut onto a Property; it is not required
# by PropertyShape. chorus:scope and chorus:source are NOT reused — they are
# credential-specific (domain chorus:Credential); a Property uses propertyScope.

chorus:PropertyShape a sh:NodeShape ;
    sh:targetClass chorus:Property ;
    sh:property [
        sh:path chorus:propertyKey ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path chorus:propertyValue ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path chorus:propertyScope ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] .

chorus:derivedFrom a owl:ObjectProperty ;
    rdfs:label "derived from" ;
    rdfs:comment "A practice or policy traces back to the principle(s) that motivate it." ;
    rdfs:domain chorus:Practice, chorus:Policy ;
    rdfs:range chorus:Principle .

chorus:dependsOn a owl:ObjectProperty ;
    rdfs:label "depends on" ;
    rdfs:comment "A sub-product or sub-domain depends on another for its function — if the target is unavailable or broken, the source is degraded. Distinct from chorus:consumes (read-only data flow). Dependency implies lifecycle coupling." .

chorus:reads a owl:ObjectProperty ;
    rdfs:label "reads" ;
    rdfs:comment "A service reads state from a persistence or another service. Read-only, no mutation. #2178 — turns the Athena envelope from labels into a graph an agent can traverse." .

chorus:writes a owl:ObjectProperty ;
    rdfs:label "writes" ;
    rdfs:comment "A service writes state to a persistence or emits events consumed by another service. Distinguishes data production from data consumption at the service level. #2178." .

chorus:hasSkill a owl:ObjectProperty ;
    rdfs:label "has skill" ;
    rdfs:comment "A role or practice has a skill in its repertoire. Role hasSkill = the role's toolkit; Practice hasSkill = the named entry point that enacts the practice. #2348." ;
    rdfs:domain [ owl:unionOf ( chorus:Role chorus:Practice ) ] ;
    rdfs:range chorus:Skill .

chorus:hasGate a owl:ObjectProperty ;
    rdfs:label "has gate" ;
    rdfs:comment "A role or practice has a gate it runs or enforces. Role hasGate = gate the role is authorized to evaluate; Practice hasGate = gate that enforces the practice's invariant. #2348." ;
    rdfs:domain [ owl:unionOf ( chorus:Role chorus:Practice ) ] ;
    rdfs:range chorus:Gate .

chorus:authorizedBy a owl:ObjectProperty ;
    rdfs:label "authorized by" ;
    rdfs:comment "A skill or gate is authorized by a role or practice. Inverse of hasSkill / hasGate. Makes orphan queries cheap: Skill or Gate without authorizedBy = orphan. #2348." ;
    rdfs:domain [ owl:unionOf ( chorus:Skill chorus:Gate ) ] ;
    rdfs:range [ owl:unionOf ( chorus:Role chorus:Practice ) ] .

chorus:implementedIn a owl:ObjectProperty ;
    rdfs:label "implemented in" ;
    rdfs:comment "A skill or gate is implemented in a file (path relative to chorus repo root, e.g., platform/services/chorus-hooks/src/gates/demo_gate.rs). Concrete Loom→Werk trace. Range is xsd:string today; future: resource pointing at a code node. #2348." ;
    rdfs:domain [ owl:unionOf ( chorus:Skill chorus:Gate ) ] ;
    rdfs:range xsd:string .

# --- Policies (5 from existing CLAUDE.md + team-architecture.md rules; binary, operationally enforced) ---

chorus:policy-working-hours a chorus:Policy ;
    rdfs:label "Working window 6am–8pm Boston" ;
    rdfs:comment "Default working window is 6am–8pm Boston time. Jeff's direction always overrides: do not question off-hour requests, do not ask Jeff about working-hour boundaries. The window is for self-initiated agent work when no direction has been given; when direction exists, execute it regardless of clock." ;
    chorus:derivedFrom chorus:principle-protect-attention .

chorus:policy-no-raw-process-kill a chorus:Policy ;
    rdfs:label "No raw process killing" ;
    rdfs:comment "Never `kill` PIDs directly, local or remote. Use launchctl kickstart for LaunchAgents, app-state.sh for the Gathering app lifecycle. LaunchAgent changes route through Silas." ;
    chorus:derivedFrom chorus:principle-services-reliable-bounded-idempotent .

chorus:policy-response-window-60s a chorus:Policy ;
    rdfs:label "60-second pair heartbeat" ;
    rdfs:comment "If your pair partner completes an AC item, you respond within 60 seconds. If you can't, emit a status (thinking, blocked on X). Silence = stall. DEC-1571 Attention Contract." ;
    chorus:derivedFrom chorus:principle-protect-attention .

chorus:policy-no-self-acp a chorus:Policy ;
    rdfs:label "No self-accept on code cards" ;
    rdfs:comment "Only Wren or Jeff can accept. The builder CANNOT mark their own code card Done. DEC-048 Proving Gate." ;
    chorus:derivedFrom chorus:principle-services-reliable-bounded-idempotent .

chorus:policy-chorus-search-first a chorus:Policy ;
    rdfs:label "Chorus search before filesystem" ;
    rdfs:comment "Search order: Chorus (/chorus search) → codebase graph → filesystem (Grep/Glob). Guard hook enforces. DEC-074." ;
    chorus:derivedFrom chorus:principle-services-reliable-bounded-idempotent .

# --- Policies (9 materialized 2026-04-22 for dangling practice→policy refs; #2348 sub-spike 3C) ---

chorus:policy-tdd-gate a chorus:Policy ;
    rdfs:label "TDD required before code" ;
    rdfs:comment "Every code card must have failing tests (red) before production code is written. Enforced by tdd_gate.rs PreToolUse hook. DEC-1674." ;
    chorus:derivedFrom chorus:principle-quality-at-source,
                       chorus:principle-speed-and-quality-correlate .

chorus:policy-demo-gate a chorus:Policy ;
    rdfs:label "No accept without demo" ;
    rdfs:comment "A code card cannot be marked Done without demo evidence. Builder cannot self-accept. DEC-048 Proving Gate. Enforced by demo_gate.rs hook and werk-accept (the GO step of chorus_werk)." ;
    chorus:derivedFrom chorus:principle-apply-self-regulation-and-accept-feedback,
                       chorus:principle-no-dark-work .

chorus:policy-accept-gate a chorus:Policy ;
    rdfs:label "Accept = Done + spine + commit + push" ;
    rdfs:comment "An acceptance must complete all four: move card to Done, emit card.accepted spine event, commit changes via git-queue, push. Partial acceptance is not acceptance. Enforced by werk-accept (the GO step of chorus_werk; GO=accept, #3311)." ;
    chorus:derivedFrom chorus:principle-artifacts,
                       chorus:principle-no-dark-work .

chorus:policy-handoff-logger a chorus:Policy ;
    rdfs:label "Every cross-role handoff logged" ;
    rdfs:comment "Briefs, nudges, gate-passes, and acceptances across roles must log to activity.md. If it's a handoff, it's traceable. Enforced by role discipline + future handoff-gate hook (not yet materialized)." ;
    chorus:derivedFrom chorus:principle-artifacts,
                       chorus:principle-no-dark-work .

chorus:policy-demo-provenance a chorus:Policy ;
    rdfs:label "Demo evidence is an artifact" ;
    rdfs:comment "Every demo produces a durable artifact (brief file or card comment) identifying what was shown, by whom, when. Verbal-only demos do not satisfy the demo gate. Enforced by demo_gate.rs hook reading comments/briefs — #2177 migrates fully to card comments." ;
    chorus:derivedFrom chorus:principle-artifacts,
                       chorus:principle-no-dark-work .

chorus:policy-nudge-blast-radius a chorus:Policy ;
    rdfs:label "Nudge requires WIP context" ;
    rdfs:comment "A nudge targeting a role carries the card context (WIP id if present, reason for interruption). Cross-domain nudges surface a warning. DEC-107 dual-path persist+deliver is the mechanism; blast-radius is the discipline around when it fires." ;
    chorus:derivedFrom chorus:principle-protect-attention,
                       chorus:principle-focus-is-infrastructure .

chorus:policy-pair-enforcement a chorus:Policy ;
    rdfs:label "Pair has navigator + driver, not spectators" ;
    rdfs:comment "A /pair session has exactly one navigator and one driver. Navigator scopes; driver implements. Rotation checkpoints enforce turn-taking. Partner silence > 60s = stall signal (see policy-response-window-60s for the heartbeat). Enforced by /pair skill state + future pair-heartbeat-check skill (#2317)." ;
    chorus:derivedFrom chorus:principle-comprehension-is-the-rate-limit,
                       chorus:principle-integrate-rather-than-segregate .

chorus:policy-icd-write-gate a chorus:Policy ;
    rdfs:label "No harvester without ICD provider" ;
    rdfs:comment "A harvester service file (harvest-*.sh, *-harvester.service.ts) cannot be written if the domain has no ICD provider section in urn:gathering:icd/current. Populate the ICD first, then code. DEC-095. Enforced by icd-gate-hook.sh PreToolUse hook." ;
    chorus:derivedFrom chorus:principle-services-reliable-bounded-idempotent,
                       chorus:principle-no-dark-work .

chorus:policy-quality-gate a chorus:Policy ;
    rdfs:label "Quality gate required before demo" ;
    rdfs:comment "Quality gate (hooks pass, no regression, no console.log in production code) must pass before /demo is called on a code card. Kade-owned. Enforced by /gate-quality skill + quality_gate.rs hook integration." ;
    chorus:derivedFrom chorus:principle-quality-at-source,
                       chorus:principle-produce-no-waste .

# --- 12 Principles (7 from team-architecture.md + 5 from 2026-04-17 session) ---

chorus:principle-protect-attention a chorus:Principle ;
    rdfs:label "Protect Jeff's attention" ;
    rdfs:comment "Jeff's attention is the scarcest resource. Every protocol, gate, and automation exists to keep coordination off his desk. Target: 2 touches per card." .

chorus:principle-services-reliable-bounded-idempotent a chorus:Principle ;
    rdfs:label "Services are reliable, bounded, and idempotent" ;
    rdfs:comment "Every Chorus service works every time (reliable), declares its edges (bounded), and behaves the same until deliberately versioned (idempotent unless changed). Enforcement — gates, hooks, contracts, tests, types — exists in service of these properties, not as an end in itself." .

chorus:principle-no-dark-work a chorus:Principle ;
    rdfs:label "No dark work" ;
    rdfs:comment "Everything must be visible — board, domain graph, API. If the system can't see it, it doesn't exist." .

chorus:principle-artifacts a chorus:Principle ;
    rdfs:label "Artifacts are the source of truth" ;
    rdfs:comment "When conversation and a file disagree, the file wins. If it matters next week, it's a file." .

chorus:principle-owner-sets-direction a chorus:Principle ;
    rdfs:label "The owner sets direction, the system does the relay" ;
    rdfs:comment "Jeff sets direction. Roles maintain shared context directly. The system is the router." .

chorus:principle-ship-small a chorus:Principle ;
    rdfs:label "Ship small, learn fast" ;
    rdfs:comment "Small cards, fast cycles, real demos. The demo is the learning moment." .

chorus:principle-self-healing a chorus:Principle ;
    rdfs:label "The system should be self-healing" ;
    rdfs:comment "Synchronization brings roles current without Jeff recapping. Any role should reconstruct state from artifacts alone." .

chorus:principle-focus-is-infrastructure a chorus:Principle ;
    rdfs:label "Focus is infrastructure" ;
    rdfs:comment "Focus windows are infrastructure, not preference. Every interruption has a cost; make the cost visible. Interruption is a last resort, not a default." .

chorus:principle-quality-at-source a chorus:Principle ;
    rdfs:label "Quality at the source" ;
    rdfs:comment "Build quality in at construction, not at inspection. No staging means the shortcut that skips thinking is the bug that costs more than the thinking would have." .

chorus:principle-speed-and-quality-correlate a chorus:Principle ;
    rdfs:label "Speed and quality correlate" ;
    rdfs:comment "Speed and quality both come from uninterrupted thinking — they are not a trade-off. Skipping review does not produce speed; it produces rework plus the interruption load that rework generates." .

chorus:principle-comprehension-is-the-rate-limit a chorus:Principle ;
    rdfs:label "Comprehension is the rate limit" ;
    rdfs:comment "The team's real throughput is set by what can be understood, not what can be generated. Output beyond the rate of comprehension is debt disguised as speed. You own what you understand, not what you produced." .

chorus:principle-interrogate-the-data a chorus:Principle ;
    rdfs:label "Give a fuck about data quality" ;
    rdfs:comment "Interrogate the data you touch before repeating or acting on it. Every claim you relay is a claim you own. Check provenance, verify fossils, refuse to narrate over gaps. The failure mode is storytelling — coherent-sounding prose that papers over what the data actually shows." .

chorus:principle-no-competing-implementations a chorus:Principle ;
    rdfs:label "No competing implementations" ;
    rdfs:comment "One concept, one implementation. When the same idea lives in multiple surfaces — two version sources, three drift detectors, three boot-enforcement attempts — they drift out of phase and nobody knows which is load-bearing. Root cause is weak APIs: when the contract is prose or convention instead of a callable surface, every new attempt adds a parallel implementation rather than replacing the prior one. Every new implementation must retire its predecessor; if you cannot retire it, the contract is not strong enough — fix the API first. The #2311 jenga pattern (5+ prior attempts at drift detection, none removed) is this principle's canonical violation." .

# --- #2447: Hemenway permaculture parents + specialization edges ---
# Source: /book/principles-reconstructed.html (2026-04-24), transcribed from Jeff's book
# photos IMG_2601/IMG_2602/IMG_2603 of Hemenway, Gaia's Garden 2nd ed., Chelsea Green 2009,
# pp. 5–7. Chapter "Introducing the Ecological Garden."

chorus:specializes a owl:ObjectProperty ;
    rdfs:label "specializes" ;
    rdfs:comment "A Chorus-specific principle specializes a more general (permaculture) parent principle. The child inherits the parent's intent and applies it to team/tech context. Distinct from derivedFrom (practice/policy→principle); specializes is principle→principle. #2447." ;
    rdfs:domain chorus:Principle ;
    rdfs:range chorus:Principle .

chorus:techReading a owl:DatatypeProperty ;
    rdfs:label "tech/chorus reading" ;
    rdfs:comment "The Tech/Chorus lens reading of a principle as rendered on /book/principles-reconstructed.html. Free-text prose that operationalizes the principle for team + engineering context. #2447." ;
    rdfs:domain chorus:Principle ;
    rdfs:range xsd:string .

chorus:jeffReading a owl:DatatypeProperty ;
    rdfs:label "jeff reading" ;
    rdfs:comment "The Jeff lens reading of a principle as rendered on /book/principles-reconstructed.html. Free-text prose showing how Jeff models or demonstrates the principle in practice. #2447." ;
    rdfs:domain chorus:Principle ;
    rdfs:range xsd:string .

chorus:dctermsSource a owl:AnnotationProperty ;
    rdfs:label "dcterms:source" ;
    rdfs:comment "Bibliographic source citation for an imported principle. Used to trace a chorus:Principle instance back to its canonical external reference (e.g., Hemenway). #2447." .

# --- 14 Hemenway parents ---

chorus:hemenway-observe a chorus:Principle ;
    rdfs:label "Observe" ;
    rdfs:comment "Use protracted and thoughtful observation rather than prolonged and thoughtless action. In the garden, this may mean noting where the sun and its shade fall during the day, where water collects, and in which direction the winds blow. Think over seasons, years." ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed. (Chelsea Green, 2009), p. 6." ;
    chorus:techReading "Gemba, dashboards, mutual attention. Watch a role work before directing it. Read the board before acting on it. Loom principles → architecture → code: pattern cards before implementation cards; composition before primitives." ;
    chorus:jeffReading "Jeff reads the board, looks at the screenshare, listens to stories before committing to a move. Decision-making starts with watching. Resists 'give me the first step' when the shape isn't clear yet." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-connect a chorus:Principle ;
    rdfs:label "Connect" ;
    rdfs:comment "Use relative location — place the elements of your design in ways that create useful relationships and time-saving connections among all parts. The number of connections among useful elements makes a healthy, diverse ecosystem, not the number of elements." ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 6." ;
    chorus:techReading "Roles compose, not isolate. Gates stay in-role (not in subagents). The Clearing. Pair work. Briefs move between roles directly." ;
    chorus:jeffReading "Jeff uses the team as a thinking partner, not as executors. Asks all three roles and composes the answers rather than directing one." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-catch-and-store a chorus:Principle ;
    rdfs:label "Catch and store energy and materials" ;
    rdfs:comment "Identify, collect, and hold useful flows. Every cycle is an opportunity for yield; every gradient (in slope, charge, temperature, or otherwise) is an opportunity for energy." ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 6." ;
    chorus:techReading "Capture events, insights, and decisions while warm — Chorus index, spine events, memory records, stories. TTL. Produce-no-waste corollary: every output of one element is input to another. Retire what does not earn its place." ;
    chorus:jeffReading "When Jeff has a live insight (a thought, write, reading), he cards it or stories it. The 2-month rule: capture-while-warm, not-on-discipline. Retires things — principles, cards, protocols, names — when they stop producing." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-each-element-multiple-functions a chorus:Principle ;
    rdfs:label "Each element performs multiple functions" ;
    rdfs:comment "Choose and place each element in a design so that it performs as many functions as possible. Beneficial connections between diverse components create a stable whole. Stack elements in both space and time." ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 6." ;
    chorus:techReading "Each role carries several functions (Wren = PM + moderator + interaction-layer owner; Kade = engineer + gate-code + gate-quality; Silas = architect + ops + repo-infra). Each primitive serves multiple skills (chorus-log, git-queue.sh, nudge). Stack in time: briefs become stories become principles." ;
    chorus:jeffReading "Jeff reuses patterns he invented (briefs, demos, gates) across new problems rather than inventing new abstractions per problem. Compresses rather than proliferates." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-function-supported-by-multiple-elements a chorus:Principle ;
    rdfs:label "Each function is supported by multiple elements" ;
    rdfs:comment "Use multiple methods to achieve important functions and to create redundancy and backup. Redundancy protects when one or more elements fail." ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 6." ;
    chorus:techReading "Distinct role voices, multiple tests, multiple memory sources. Reduce-to-single is a lossy default. Three gates (product, code, arch) supporting the quality function via different lenses." ;
    chorus:jeffReading "Jeff shaped the three roles to be distinct, not interchangeable. Their different instincts are the asset; collapsing them to one voice would make the system fragile." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-least-change-greatest-effect a chorus:Principle ;
    rdfs:label "Make the least change for the greatest effect" ;
    rdfs:comment "Understand the system you are working with well enough to find its 'leverage points' and intervene there, where the least work accomplishes the most change." ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 6." ;
    chorus:techReading "Fix the invariant once, not the symptom repeatedly. One-line inventory exclude beats 2075-file front-matter prepend. Gates over sweeps." ;
    chorus:jeffReading "Jeff looks for root-cause invariants rather than surface fixes. The preference for 'fix the shape that causes the bug, not the bug.' Calls out agent-shaped solutions that mass-mutate instead of adjusting the rule." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-small-scale-intensive-systems a chorus:Principle ;
    rdfs:label "Use small-scale, intensive systems" ;
    rdfs:comment "Start at your doorstep with the smallest systems that will do the job and build on your successes. Grow by 'chunking' — that is, developing a small system or arrangement that works well — and then add it to another one." ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 6." ;
    chorus:techReading "Ship small, narrow blast radius, bounded services, deploy rings. Smallest card that teaches, not largest card that ships. Chunking: a practice that works becomes a skill; a skill that works becomes a primitive." ;
    chorus:jeffReading "Jeff cards a tiny fix rather than a big reorg when he can. Prefers a pattern learned over a pattern imposed." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-optimize-edge a chorus:Principle ;
    rdfs:label "Optimize edge" ;
    rdfs:comment "The edge — the intersection of two environments — is where resources and interactions are highest. A productive edge is where the most diversity and productivity are found." ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 7." ;
    chorus:techReading "Seams between roles generate patterns. Margin of the spec produces new cards. The Clearing IS an edge between roles. Demo seeds — Jeff's reactions to live work — are the highest-signal intake channel." ;
    chorus:jeffReading "Jeff's best ideas come in the margins — the 'what if' during a demo, the story dropped between cards, the side comment that reshapes a roadmap." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-collaborate-with-succession a chorus:Principle ;
    rdfs:label "Collaborate with succession" ;
    rdfs:comment "Living systems usually advance from immaturity to maturity, and if we accept this trend and align our designs with it instead of fighting it, we save work and energy. Mature ecosystems are more diverse and productive than young ones." ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 7." ;
    chorus:techReading "Refactor, retire, rename. Protocol versions grow up. The 10-week zero-to-self-healing Chorus delta is this principle in action. Cards move through Next → WIP → Done; principles move from practice to rule to invariant." ;
    chorus:jeffReading "Jeff rebrands things (Bridge → Clearing, multiple Werk generations, Chorus rewrites) without sentimental attachment. The name is less important than the fit." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-biological-renewable-resources a chorus:Principle ;
    rdfs:label "Use biological and renewable resources" ;
    rdfs:comment "Renewable resources — usually living beings and their products — reproduce and build up over time, store energy, assist yield, and interact with other elements. Favor these over nonrenewable resources." ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 7." ;
    chorus:techReading "Patterns, skills, hooks, memory — recurring value — over one-shot human effort. Invest in the pattern, not the individual fix. Treat Jeff's attention as the renewable-but-finite resource the whole system is designed to protect." ;
    chorus:jeffReading "'Focus is infrastructure' is this in practice — Jeff's finite attention is the resource every protocol and automation exists to conserve." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-turn-problems-into-solutions a chorus:Principle ;
    rdfs:label "Turn problems into solutions" ;
    rdfs:comment "Constraints can inspire creative design; problems usually carry not just the seeds of their own solution, but the inspiration for simultaneously solving other problems. 'You are confronted by formidable problems? Celebrate, for you have just encountered opportunities!'" ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 7." ;
    chorus:techReading "Every recurring failure becomes a gate or invariant. Today's push-bloat crisis → repo bloat card + gitignore rule + future filter-repo plan. Friction becomes structure. Creatively use and respond to change: refactor, retire, rename rather than fight decay." ;
    chorus:jeffReading "Jeff's 'bugs not character' stance — treats recurring failures as design opportunities, not discipline problems. When tone drops, fix the routing; when a skill is fragile, fix the shape." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-get-a-yield a chorus:Principle ;
    rdfs:label "Get a yield" ;
    rdfs:comment "Grow for both immediate and long-term rewards. A designer's discipline as much as a system property — listed under Hemenway's 'Principles Based on Attitudes.'" ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 7." ;
    chorus:techReading "Visible yield per card, per session. No dark work. The demo is the learning moment. Short-term: a shipped card. Long-term: a pattern the team can reuse." ;
    chorus:jeffReading "Jeff measures himself by what ships, not what he knows. The 'no dark work' principle is his." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-creativity-is-the-limit a chorus:Principle ;
    rdfs:label "The biggest limit to abundance is creativity" ;
    rdfs:comment "The designer's imagination and skill usually limit productivity and diversity before any physical limits are reached." ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 7." ;
    chorus:techReading "The hard constraint is rarely compute, lines of code, or token budget — it's the sharpness of the design question. Agent-shaped solutions fail the creativity test before they fail the engineering test." ;
    chorus:jeffReading "Jeff's friction with 'agent-shaped answers' — rejects solutions that pattern-match without imagining what a human would actually want." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

chorus:hemenway-mistakes-are-tools-for-learning a chorus:Principle ;
    rdfs:label "Mistakes are tools for learning" ;
    rdfs:comment "Evaluate your trials. Making mistakes is a sign you're trying to do things better. There is usually little penalty for mistakes if you learn from them." ;
    dcterms:source "Hemenway, T. Gaia's Garden, 2nd ed., p. 7." ;
    chorus:techReading "Gates, hooks, ceremony ROI audits, three-role interaction as mutual correction. The seams between roles generate the corrections. Self-regulation: systems correct themselves from their own signal; unwanted feedback is still information." ;
    chorus:jeffReading "Jeff models this — he will say 'I was wrong about X' and redirect without defending the prior position. Invites pushback rather than fending it off." ;
    dcterms:created "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-04-24T17:00:00Z"^^xsd:dateTime ;
    chorus:isPermacultureParent true .

# --- Specialization edges: 12 Chorus principles → Hemenway parents (per HTML nesting) ---

chorus:principle-interrogate-the-data skos:broader chorus:hemenway-observe .
chorus:principle-comprehension-is-the-rate-limit skos:broader chorus:hemenway-observe .

chorus:principle-owner-sets-direction skos:broader chorus:hemenway-connect .

chorus:principle-artifacts skos:broader chorus:hemenway-catch-and-store .
chorus:principle-quality-at-source skos:broader chorus:hemenway-catch-and-store .

chorus:principle-ship-small skos:broader chorus:hemenway-small-scale-intensive-systems .
chorus:principle-services-reliable-bounded-idempotent skos:broader chorus:hemenway-small-scale-intensive-systems .

chorus:principle-focus-is-infrastructure skos:broader chorus:hemenway-biological-renewable-resources .
chorus:principle-protect-attention skos:broader chorus:hemenway-biological-renewable-resources .
chorus:principle-speed-and-quality-correlate skos:broader chorus:hemenway-biological-renewable-resources .
chorus:principle-no-dark-work skos:broader chorus:hemenway-biological-renewable-resources .

chorus:principle-self-healing skos:broader chorus:hemenway-mistakes-are-tools-for-learning .

# principle-no-competing-implementations has no Hemenway parent yet — per HTML footer
# ('did not appear in the 2026-04-21 printout — included in the graph but not rendered
# here until its parent mapping is confirmed'). Left unedged intentionally.

# --- 7 Practices (from team-architecture.md) ---

chorus:practice-actor-bdd a chorus:Practice ;
    rdfs:label "Actor-BDD" ;
    rdfs:comment "Before code, model the actors and write the scenarios. Scenarios become the test suite." .

chorus:practice-domain-first a chorus:Practice ;
    rdfs:label "Domain first" ;
    rdfs:comment "Register the domain before building in it. The domain exists before a line of code." .

chorus:practice-service-next a chorus:Practice ;
    rdfs:label "Service next" ;
    rdfs:comment "After the domain, design the service. Ship the contract before the implementation." .

chorus:practice-product-owner-aligned a chorus:Practice ;
    rdfs:label "Product and owner aligned" ;
    rdfs:comment "Every domain has an owner. Every card has an owner. They match. Ownership is routing." .

chorus:practice-tdd a chorus:Practice ;
    rdfs:label "TDD" ;
    rdfs:comment "Tests describe Jeff's experience, not implementation details. AC → tests → code → green → demo." .

