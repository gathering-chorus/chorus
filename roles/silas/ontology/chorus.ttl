@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix chorus:   <https://jeffbridwell.com/chorus#> .

# =============================================================================
# Chorus Ontology v0.3.0 — Canonical Model
# =============================================================================
#
# Unified model of how the team operates: roles, tools, the value stream
# (spine), artifacts, handoffs, gates, trust, products, domains, and services.
#
# v0.3.0 merges Wren's product ontology (chorus-product-ontology.owl) into the
# canonical namespace. Adds: ValueStream, Phase, Domain subtypes, Service,
# Machine, Shaping vertebra, consumption/provision edges.
#
# Migration sources (no longer live):
#   - building.ttl v0.1.0 (deprecated 2026-02-22, merged in v0.2.0)
#   - chorus-product-ontology.owl v0.1 (migrated 2026-04-10)
#
# Bridge: framework.ttl connects this ontology to borg: (infra) and jb: (data).
#
# Prior art: US Patent 9,552,400 B2 (Bridwell) — RDF/OWL + SPARQL + workflow gates.
#
# Version: 0.3.0
# Date: 2026-04-10
# Status: Active (#1845, supersedes v0.2.0)
# =============================================================================

chorus: a owl:Ontology ;
    owl:versionInfo "0.3.0" ;
    dcterms:title "Chorus — Canonical Model" ;
    dcterms:description "Unified model of human+AI team coordination: roles, tools, spine, artifacts, handoffs, gates, trust, products, domains, services, value streams." ;
    dcterms:created "2026-02-22"^^xsd:date ;
    dcterms:modified "2026-04-10"^^xsd:date ;
    rdfs:comment "v0.3.0: merges product ontology, adds Shaping vertebra, domain subtypes, service model. Single namespace (https://jeffbridwell.com/chorus#), single truth." .

# =============================================================================
# 1. ROLES
# =============================================================================

chorus:Role a owl:Class ;
    rdfs:label "Role" ;
    rdfs:comment "A persistent perspective within Chorus. Each role has context (CLAUDE.md, state files, briefs) that shapes how it thinks. Same model, different lens." .

chorus:HumanRole a owl:Class ;
    rdfs:subClassOf chorus:Role ;
    rdfs:label "Human Role" ;
    rdfs:comment "Filled by a human. Owns judgment, direction, meaning." .

chorus:AgentRole a owl:Class ;
    rdfs:subClassOf chorus:Role ;
    rdfs:label "Agent Role" ;
    rdfs:comment "Filled by an AI agent. Persistent across sessions via state files and memory." .

chorus:jeff a chorus:HumanRole ;
    rdfs:label "Jeff" ;
    rdfs:comment "Owner. Judgment, direction, meaning. Jeff is the emotional center of the team — sets tone, defines role structure, assigns ownership. Working hours flexible. Vertical scope: all. Two products: Gathering (personal infrastructure) and Chorus (team coordination)." ;
    chorus:domain "directs" ;
    chorus:color "#e6edf3" ;
    chorus:channelName "#all-gathering" .

chorus:wren a chorus:AgentRole ;
    rdfs:label "Wren" ;
    rdfs:comment "Product Manager. Value first, ship small, have a position. Owns briefs, decisions, skills, board ops. Moderates multi-role interactions, detects interaction patterns, captures demo seeds. 6am-8pm Boston. Emoji: feather." ;
    chorus:domain "product" ;
    chorus:color "#4ade80" ;
    chorus:channelName "#wren" .

chorus:silas a chorus:AgentRole ;
    rdfs:label "Silas" ;
    rdfs:comment "Architect. Structural integrity, cross-project coherence, infrastructure health. Owns scripts, hooks, monitoring, deploy tooling, cross-machine ops. Maintains ontology, LaunchAgents, Fuseki. 6am-8pm Boston." ;
    chorus:domain "architecture" ;
    chorus:color "#60a5fa" ;
    chorus:channelName "#silas" .

chorus:kade a chorus:AgentRole ;
    rdfs:label "Kade" ;
    rdfs:comment "Engineer. Clean, tested, maintainable code matching architectural intent. Owns src, views, tests, routes, handlers, SPARQL services, build pipeline. Feeds back when reality diverges from product/architecture decisions. 6am-8pm Boston." ;
    chorus:domain "engineering" ;
    chorus:color "#fb923c" ;
    chorus:channelName "#kade" .

# =============================================================================
# 2. VERTEBRAE (The Spine / Value Stream)
# =============================================================================

chorus:Vertebra a owl:Class ;
    rdfs:label "Vertebra" ;
    rdfs:comment "A stage in the value stream — the Werk. Work flows through vertebrae sequentially, with feedback loops. The spine is the ordered set of all vertebrae." .

chorus:Shaping a chorus:Vertebra ;
    rdfs:label "Shaping" ;
    rdfs:comment "Defining the operating model — principles, practices, roles, skills, metrics. The meta layer that governs how everything else works. Loom lives here." ;
    chorus:stageOrder 1 ;
    chorus:nextStage chorus:Directing ;
    chorus:stageOrder 0 ;
    chorus:exitArtifactType chorus:Decision ;
    chorus:belongsTo chorus:chorusStream .

chorus:Directing a chorus:Vertebra ;
    rdfs:label "Directing" ;
    rdfs:comment "Jeff expresses intent, direction, or feedback. Entry: human initiative. Exit: card on board." ;
    chorus:stageOrder 2 ;
    chorus:nextStage chorus:Designing ;
    chorus:previousStage chorus:Shaping ;
    chorus:exitArtifactType chorus:Card ;
    chorus:belongsTo chorus:chorusStream .

chorus:Designing a chorus:Vertebra ;
    rdfs:label "Designing" ;
    rdfs:comment "Product framing (Wren) + architectural design (Silas). Exit: build-ready brief." ;
    chorus:stageOrder 3 ;
    chorus:nextStage chorus:Building ;
    chorus:previousStage chorus:Directing ;
    chorus:exitArtifactType chorus:Brief ;
    chorus:belongsTo chorus:chorusStream .

chorus:Building a chorus:Vertebra ;
    rdfs:label "Building" ;
    rdfs:comment "Implementation by Kade. Exit: shipped code with visual proof." ;
    chorus:stageOrder 4 ;
    chorus:nextStage chorus:Proving ;
    chorus:previousStage chorus:Designing ;
    chorus:exitArtifactType chorus:Commit ;
    chorus:belongsTo chorus:chorusStream .

chorus:Proving a chorus:Vertebra ;
    rdfs:label "Proving" ;
    rdfs:comment "Validation. UX verified, architecture sound, no regressions. Feeds back to Directing." ;
    chorus:stageOrder 5 ;
    chorus:previousStage chorus:Building ;
    chorus:feedsInto chorus:Directing ;
    chorus:exitArtifactType chorus:Signal ;
    chorus:belongsTo chorus:chorusStream .

# --- Personal value stream steps (Gathering product) -------------------------

chorus:Sowing a chorus:Vertebra ;
    rdfs:label "Sowing" ;
    rdfs:comment "Planting seeds — capturing raw inputs, interests, and intentions that may grow into something." ;
    chorus:stageOrder 10 ;
    chorus:nextStage chorus:Growing ;
    chorus:belongsTo chorus:gatheringStream .

chorus:Growing a chorus:Vertebra ;
    rdfs:label "Growing" ;
    rdfs:comment "Nurturing what was sown — enriching, connecting, and developing raw material into structured knowledge." ;
    chorus:stageOrder 11 ;
    chorus:nextStage chorus:Practicing ;
    chorus:previousStage chorus:Sowing ;
    chorus:belongsTo chorus:gatheringStream .

chorus:Practicing a chorus:Vertebra ;
    rdfs:label "Practicing" ;
    rdfs:comment "Applying knowledge — putting gathered material into active use, building habits and routines." ;
    chorus:stageOrder 12 ;
    chorus:nextStage chorus:Harvesting ;
    chorus:previousStage chorus:Growing ;
    chorus:belongsTo chorus:gatheringStream .

chorus:Harvesting a chorus:Vertebra ;
    rdfs:label "Harvesting" ;
    rdfs:comment "Collecting the yield — extracting value from what was grown and practiced. Photos, music, notes, documents flow through here." ;
    chorus:stageOrder 13 ;
    chorus:nextStage chorus:Reflecting ;
    chorus:previousStage chorus:Practicing ;
    chorus:belongsTo chorus:gatheringStream .

chorus:Reflecting a chorus:Vertebra ;
    rdfs:label "Reflecting" ;
    rdfs:comment "Looking back — reviewing what was harvested, finding patterns, feeding insights back into the next sowing cycle." ;
    chorus:stageOrder 14 ;
    chorus:previousStage chorus:Harvesting ;
    chorus:feedsInto chorus:Sowing ;
    chorus:belongsTo chorus:gatheringStream .

# --- Life value stream steps (placeholder — Jeff defines later) ---------------

chorus:lifeStream a chorus:ValueStream ;
    rdfs:label "Life" ;
    rdfs:comment "The flow of living well — health, relationships, home, values. Steps to be defined by Jeff." .

chorus:Tending a chorus:Vertebra ;
    rdfs:label "Tending" ;
    rdfs:comment "Placeholder step for the Life value stream. Jeff will define the full sequence." ;
    chorus:stageOrder 20 ;
    chorus:belongsTo chorus:lifeStream .

# --- Operating (parallel category, not a sequential vertebra) ----------------

chorus:EventCategory a owl:Class ;
    rdfs:label "Event Category" ;
    rdfs:comment "A classification of spine events that runs parallel to the value stream rather than as a sequential stage." .

chorus:Operating a chorus:EventCategory ;
    rdfs:label "Operating" ;
    rdfs:comment "Infrastructure health, deploys, disk monitoring, container lifecycle, and system resilience. Crosscuts all vertebrae — the substrate the value stream runs on." ;
    chorus:color "#f3f4f6" ;
    chorus:crosscuts chorus:Shaping, chorus:Directing, chorus:Designing, chorus:Building, chorus:Proving .

# =============================================================================
# 2b. VALUE STREAMS (from product ontology)
# =============================================================================

chorus:ValueStream a owl:Class ;
    rdfs:label "Value Stream" ;
    rdfs:comment "A named flow of value from signal to outcome. Stable — when a value stream changes, the product has fundamentally changed." .

chorus:gatheringStream a chorus:ValueStream ;
    rdfs:label "Gathering (Stream)" ;
    rdfs:comment "The flow of meaning: Spark → Capture → Triage → Settle → Revisit → Transform → Connect → Reflect." .

chorus:chorusStream a chorus:ValueStream ;
    rdfs:label "Chorus" ;
    rdfs:comment "The flow of coordination: Shaping → Directing → Designing → Building → Proving." .

# =============================================================================
# 2c. DOMAINS (three types — from #1845 chat insight)
# =============================================================================

chorus:Domain a owl:Class ;
    rdfs:label "Domain" ;
    rdfs:comment "A bounded context with its own data, handlers, ontology, and routes. Three subtypes separate concerns." .

chorus:CollectionDomain a owl:Class ;
    rdfs:subClassOf chorus:Domain ;
    rdfs:label "Collection Domain" ;
    rdfs:comment "A Gathering data domain — Photos, Music, Stories, Books, People, Property, Seeds, Sexuality." .

chorus:SubProduct a owl:Class ;
    rdfs:subClassOf chorus:Domain ;
    rdfs:label "Sub-Product" ;
    rdfs:comment "A named product within Chorus — Cards, Loom, The Clearing, Werk, Observability." .

chorus:SubDomain a owl:Class ;
    rdfs:subClassOf chorus:Domain ;
    rdfs:label "Sub-Domain" ;
    rdfs:comment "A sub-domain within a sub-product. Matches the Sub Domain column in Jeff's spreadsheet." .

# =============================================================================
# 2c2. DOMAIN COMPLETENESS — Actors, Scenarios, Contracts (#1899)
# =============================================================================

chorus:Actor a owl:Class ;
    rdfs:label "Actor" ;
    rdfs:comment "An actor that interacts with a sub-domain. Has a role and a set of actions." .

chorus:Scenario a owl:Class ;
    rdfs:label "Scenario" ;
    rdfs:comment "A BDD scenario — Given/When/Then — describing a guaranteed behavior of a sub-domain." .

chorus:Contract a owl:Class ;
    rdfs:label "Contract" ;
    rdfs:comment "An API contract — endpoint, method, request/response shape — for a sub-domain's service boundary." .

chorus:hasActor a owl:ObjectProperty ;
    rdfs:label "has actor" ;
    rdfs:domain chorus:SubDomain ;
    rdfs:range chorus:Actor .

chorus:hasScenario a owl:ObjectProperty ;
    rdfs:label "has scenario" ;
    rdfs:domain chorus:SubDomain ;
    rdfs:range chorus:Scenario .

chorus:hasContract a owl:ObjectProperty ;
    rdfs:label "has contract" ;
    rdfs:domain chorus:SubDomain ;
    rdfs:range chorus:Contract .

chorus:actorRole a owl:DatatypeProperty ;
    rdfs:label "actor role" ;
    rdfs:domain chorus:Actor .

chorus:actorAction a owl:DatatypeProperty ;
    rdfs:label "actor action" ;
    rdfs:domain chorus:Actor .

chorus:scenarioGiven a owl:DatatypeProperty ;
    rdfs:label "given" ;
    rdfs:comment "Precondition — the initial state before the action." ;
    rdfs:domain chorus:Scenario .

chorus:scenarioWhen a owl:DatatypeProperty ;
    rdfs:label "when" ;
    rdfs:comment "Action — what the actor does." ;
    rdfs:domain chorus:Scenario .

chorus:scenarioThen a owl:DatatypeProperty ;
    rdfs:label "then" ;
    rdfs:comment "Outcome — what should be true after the action." ;
    rdfs:domain chorus:Scenario .

chorus:scenarioNotes a owl:DatatypeProperty ;
    rdfs:label "notes" ;
    rdfs:comment "Additional context or edge cases for this scenario." ;
    rdfs:domain chorus:Scenario .

chorus:endpoint a owl:DatatypeProperty ;
    rdfs:label "endpoint" ;
    rdfs:domain chorus:Contract .

chorus:contractDescription a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:comment "What this contract endpoint does." ;
    rdfs:domain chorus:Contract .

chorus:httpMethod a owl:DatatypeProperty ;
    rdfs:label "HTTP method" ;
    rdfs:domain chorus:Contract .

# --- Pages (#1923) ---

chorus:Page a owl:Class ;
    rdfs:label "Page" ;
    rdfs:comment "A UI page that renders domain data." .

chorus:hasPage a owl:ObjectProperty ;
    rdfs:label "has page" ;
    rdfs:domain chorus:SubDomain ;
    rdfs:range chorus:Page .

chorus:pageRoute a owl:DatatypeProperty ;
    rdfs:label "route" ;
    rdfs:domain chorus:Page .

chorus:pageDescription a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:domain chorus:Page .

chorus:pageStatus a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:comment "real, partial, or design" ;
    rdfs:domain chorus:Page .

# --- Integrations (#1923) ---

chorus:Integration a owl:Class ;
    rdfs:label "Integration" ;
    rdfs:comment "A data pipeline or feed that brings data into the domain." .

chorus:hasIntegration a owl:ObjectProperty ;
    rdfs:label "has integration" ;
    rdfs:domain chorus:SubDomain ;
    rdfs:range chorus:Integration .

chorus:integrationSource a owl:DatatypeProperty ;
    rdfs:label "source" ;
    rdfs:domain chorus:Integration .

chorus:integrationPath a owl:DatatypeProperty ;
    rdfs:label "path" ;
    rdfs:comment "Data flow path from source to domain." ;
    rdfs:domain chorus:Integration .

chorus:integrationStatus a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:domain chorus:Integration .

# --- Persistence (#1923) ---

chorus:PersistenceStore a owl:Class ;
    rdfs:label "Persistence Store" ;
    rdfs:comment "Where domain data is stored — Fuseki, SQLite, LanceDB, filesystem." .

chorus:hasPersistence a owl:ObjectProperty ;
    rdfs:label "has persistence" ;
    rdfs:domain chorus:SubDomain ;
    rdfs:range chorus:PersistenceStore .

chorus:storeType a owl:DatatypeProperty ;
    rdfs:label "type" ;
    rdfs:comment "Fuseki, SQLite, LanceDB, or filesystem." ;
    rdfs:domain chorus:PersistenceStore .

chorus:storeNamespace a owl:DatatypeProperty ;
    rdfs:label "namespace" ;
    rdfs:comment "Graph URI, table name, collection, or directory path." ;
    rdfs:domain chorus:PersistenceStore .

chorus:storeRecordCount a owl:DatatypeProperty ;
    rdfs:label "record count" ;
    rdfs:domain chorus:PersistenceStore .

chorus:storeStatus a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:domain chorus:PersistenceStore .

# --- Code Files (#1868) ---

chorus:CodeFile a owl:Class ;
    rdfs:label "Code File" ;
    rdfs:comment "A source file that belongs to a domain — manually populated, crawler verified." .

chorus:hasCodeFile a owl:ObjectProperty ;
    rdfs:label "has code file" ;
    rdfs:domain chorus:SubDomain ;
    rdfs:range chorus:CodeFile .

chorus:filePath a owl:DatatypeProperty ;
    rdfs:label "file path" ;
    rdfs:domain chorus:CodeFile .

chorus:fileType a owl:DatatypeProperty ;
    rdfs:label "file type" ;
    rdfs:comment "ts, js, rs, sh, etc." ;
    rdfs:domain chorus:CodeFile .

# --- Services (#1924) ---

chorus:Service a owl:Class ;
    rdfs:label "Service" ;
    rdfs:comment "A runtime component — LaunchAgent, container, cron job." .

chorus:hasService a owl:ObjectProperty ;
    rdfs:label "has service" ;
    rdfs:domain chorus:SubDomain ;
    rdfs:range chorus:Service .

chorus:serviceType a owl:DatatypeProperty ;
    rdfs:label "type" ;
    rdfs:comment "launchagent, container, or cron." ;
    rdfs:domain chorus:Service .

chorus:serviceHost a owl:DatatypeProperty ;
    rdfs:label "host" ;
    rdfs:comment "Library or Bedroom." ;
    rdfs:domain chorus:Service .

chorus:serviceStatus a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:domain chorus:Service .

chorus:healthEndpoint a owl:DatatypeProperty ;
    rdfs:label "health endpoint" ;
    rdfs:domain chorus:Service .

# --- Pipelines (#1925) ---

chorus:Pipeline a owl:Class ;
    rdfs:label "Pipeline" ;
    rdfs:comment "A data pipeline that brings data into a domain — source, harvester, ICD." .

chorus:hasPipeline a owl:ObjectProperty ;
    rdfs:label "has pipeline" ;
    rdfs:domain chorus:SubDomain ;
    rdfs:range chorus:Pipeline .

chorus:pipelineSource a owl:DatatypeProperty ;
    rdfs:label "source" ;
    rdfs:domain chorus:Pipeline .

chorus:pipelineHarvester a owl:DatatypeProperty ;
    rdfs:label "harvester" ;
    rdfs:domain chorus:Pipeline .

chorus:pipelineICD a owl:DatatypeProperty ;
    rdfs:label "ICD" ;
    rdfs:comment "Interface control document name." ;
    rdfs:domain chorus:Pipeline .

chorus:pipelineStatus a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:domain chorus:Pipeline .

chorus:pipelineLastRun a owl:DatatypeProperty ;
    rdfs:label "last run" ;
    rdfs:domain chorus:Pipeline .

# --- Log Sources (#1926) ---

chorus:LogSource a owl:Class ;
    rdfs:label "Log Source" ;
    rdfs:comment "Where a domain's logs live — Loki labels, file paths, retention." .

chorus:hasLogSource a owl:ObjectProperty ;
    rdfs:label "has log source" ;
    rdfs:domain chorus:SubDomain ;
    rdfs:range chorus:LogSource .

chorus:logSourceLocation a owl:DatatypeProperty ;
    rdfs:label "location" ;
    rdfs:comment "Loki label selector or file path." ;
    rdfs:domain chorus:LogSource .

chorus:logSourceRetention a owl:DatatypeProperty ;
    rdfs:label "retention" ;
    rdfs:comment "Retention period in days." ;
    rdfs:domain chorus:LogSource .

chorus:logSourceStatus a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:domain chorus:LogSource .

# --- Gaps (#1926) ---

chorus:Gap a owl:Class ;
    rdfs:label "Gap" ;
    rdfs:comment "A known issue or missing capability in a domain." .

chorus:hasGap a owl:ObjectProperty ;
    rdfs:label "has gap" ;
    rdfs:domain chorus:SubDomain ;
    rdfs:range chorus:Gap .

chorus:gapType a owl:DatatypeProperty ;
    rdfs:label "type" ;
    rdfs:comment "gap or resolved." ;
    rdfs:domain chorus:Gap .

chorus:gapDescription a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:domain chorus:Gap .

chorus:gapSeverity a owl:DatatypeProperty ;
    rdfs:label "severity" ;
    rdfs:comment "blocking, important, or nice-to-have." ;
    rdfs:domain chorus:Gap .

# --- Documents (#2067) ---

chorus:Document a owl:Class ;
    rdfs:label "Document" ;
    rdfs:comment "A doc-catalog entry — service design, ADR, research note, artifact. Tagged by product, value stream step, domain, and role. All tags are 1:N." .

chorus:docHref a owl:DatatypeProperty ;
    rdfs:label "href" ;
    rdfs:comment "URL or path to the document." ;
    rdfs:domain chorus:Document ;
    rdfs:range xsd:string .

chorus:docTitle a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:domain chorus:Document ;
    rdfs:range xsd:string .

chorus:hasProduct a owl:ObjectProperty ;
    rdfs:label "has product" ;
    rdfs:comment "This document relates to this product. 1:N — a doc can span Gathering, Chorus, and Borg." ;
    rdfs:domain chorus:Document ;
    rdfs:range chorus:Product .

chorus:hasValueStreamStep a owl:ObjectProperty ;
    rdfs:label "has value stream step" ;
    rdfs:comment "This document relates to this value stream stage. 1:N — a service design spans designing + building." ;
    rdfs:domain chorus:Document ;
    rdfs:range chorus:Vertebra .

chorus:hasDomain a owl:ObjectProperty ;
    rdfs:label "has domain" ;
    rdfs:comment "This document relates to this domain. 1:N — a cross-cutting doc may tag multiple domains." ;
    rdfs:domain chorus:Document ;
    rdfs:range chorus:SubDomain .

chorus:hasOwner a owl:ObjectProperty ;
    rdfs:label "has owner" ;
    rdfs:comment "This document is owned/authored by this role. 1:N — collaborative docs have multiple owners." ;
    rdfs:domain chorus:Document ;
    rdfs:range chorus:Role .

# SHACL: every Document must have at least one domain tag
chorus:DocumentShape a sh:NodeShape ;
    sh:targetClass chorus:Document ;
    sh:property [
        sh:path chorus:hasDomain ;
        sh:minCount 1 ;
        sh:class chorus:SubDomain ;
    ] ;
    sh:property [
        sh:path chorus:docTitle ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] .

# =============================================================================
# 2d. SERVICES (from product ontology)
# =============================================================================

# Service tier classes removed (#1845 Phase 6) — Jeff's model uses Sub-Domain for all.
# Tier distinction (infra vs protocol) is metadata, not a type.

# =============================================================================
# 2e. MACHINES (from product ontology)
# =============================================================================

chorus:Machine a owl:Class ;
    rdfs:label "Machine" ;
    rdfs:comment "Physical hardware that hosts services." .

chorus:library a chorus:Machine ;
    rdfs:label "Library" ;
    rdfs:comment "M1 MacBook Air. Primary development machine. 192.168.86.36." .

chorus:bedroom a chorus:Machine ;
    rdfs:label "Bedroom" ;
    rdfs:comment "M2 Pro Mac Mini. Data services, harvesting, bulk ops. 192.168.86.242." .

# =============================================================================
# 3. TOOLS
# =============================================================================

chorus:Tool a owl:Class ;
    rdfs:label "Tool" ;
    rdfs:comment "A capability available to roles within Chorus. Tools feed vertebrae, interact with products, or orchestrate work." .

chorus:ToolType a owl:Class ;
    rdfs:label "Tool Type" ;
    rdfs:comment "Classification of tools by function." .

chorus:Sense a chorus:ToolType ;
    rdfs:label "Sense" ;
    rdfs:comment "Input capture — eyes, ears, voice." .

chorus:Interaction a chorus:ToolType ;
    rdfs:label "Interaction" ;
    rdfs:comment "Multi-party coordination and alignment." .

chorus:Memory a chorus:ToolType ;
    rdfs:label "Memory" ;
    rdfs:comment "Persistent shared context — indexes, searches, remembers." .

chorus:Orchestration a chorus:ToolType ;
    rdfs:label "Orchestration" ;
    rdfs:comment "Sequences and tracks work across roles." .

chorus:Analysis a chorus:ToolType ;
    rdfs:label "Analysis" ;
    rdfs:comment "Decomposes, examines, produces structured insight." .

# --- Tool instances ---

chorus:look a chorus:Tool ;
    rdfs:label "/look" ;
    rdfs:comment "Screen capture — Jeff shows, Chorus sees." ;
    chorus:toolType chorus:Sense ;
    chorus:vizLabel "eyes" ;
    chorus:color "#22d3ee" ;
    chorus:status "live" .

chorus:listen a chorus:Tool ;
    rdfs:label "/listen" ;
    rdfs:comment "Voice transcription — speech to text via local whisper.cpp." ;
    chorus:toolType chorus:Sense ;
    chorus:vizLabel "ears" ;
    chorus:color "#22d3ee" ;
    chorus:status "live" .

chorus:talk a chorus:Tool ;
    rdfs:label "/talk" ;
    rdfs:comment "Voice output — text to speech." ;
    chorus:toolType chorus:Sense ;
    chorus:vizLabel "voice" ;
    chorus:color "#22d3ee" ;
    chorus:status "planned" .

chorus:clearing a chorus:Tool ;
    rdfs:label "/clearing" ;
    rdfs:comment "Multi-party chat — Jeff + all roles in browser. Real-time alignment." ;
    chorus:toolType chorus:Interaction ;
    chorus:vizLabel "alignment" ;
    chorus:color "#e6edf3" ;
    chorus:status "live" .

chorus:chorusTool a chorus:Tool ;
    rdfs:label "/chorus" ;
    rdfs:comment "Shared memory index — SQLite FTS5, 14k+ messages. Search, reconcile, remember." ;
    chorus:toolType chorus:Memory ;
    chorus:vizLabel "memory" ;
    chorus:color "#c084fc" ;
    chorus:status "live" .

chorus:werk a chorus:Tool ;
    rdfs:label "/werk" ;
    rdfs:comment "Workflow engine — sequences decisions into steps across roles. IS the spine." ;
    chorus:toolType chorus:Orchestration ;
    chorus:vizLabel "the spine" ;
    chorus:color "#fbbf24" ;
    chorus:status "live" .

chorus:borg a chorus:Tool ;
    rdfs:label "Borg" ;
    rdfs:comment "Codebase decomposition — structured assessment of code, architecture, tech debt." ;
    chorus:toolType chorus:Analysis ;
    chorus:vizLabel "decompose" ;
    chorus:color "#f87171" ;
    chorus:status "planned" .

# =============================================================================
# 4. PRODUCTS
# =============================================================================

chorus:Product a owl:Class ;
    rdfs:label "Product" ;
    rdfs:comment "A system being built by the team. Products are outputs of the spine AND inputs back to Capturing (feedback loop)." .

chorus:ServiceDesign a owl:Class ;
    rdfs:label "Service Design" ;
    rdfs:comment "Architectural blueprint for a service — interfaces, contracts, dependencies, deployment model." .

chorus:gathering a chorus:Product ;
    rdfs:label "Gathering" ;
    rdfs:comment "Personal infrastructure — SOLID pods, knowledge graph, collections, Self domain. The product the spine builds." .

chorus:chorusProduct a chorus:Product ;
    rdfs:label "Chorus (Product)" ;
    rdfs:comment "The coordination protocol — hooks, scripts, gates, dashboards, spine, shared memory index. The nervous system." .

# Borg is its own product, incubating inside Chorus.
chorus:borgProduct a chorus:Product ;
    rdfs:label "Borg" ;
    rdfs:comment "Reflection — the system sees itself. Heralds discover structure, observability surfaces health, the graph assimilates it. Incubating inside Chorus. Owner: Silas. PM: Wren." ;
    chorus:ownedBy chorus:silas .

# --- Borg Features (discover heralds) ---
# Each herald scans a surface and writes to the instances graph.

# DEC-2090: Five discover heralds grouped under one "Heralds" subdomain of Borg.

chorus:heralds-domain a chorus:SubDomain ;
    rdfs:label "Heralds" ;
    rdfs:comment "Discovery agents that scan surfaces and write to the instances graph. Five heralds: code, tests, pages, endpoints, services. The system seeing itself." ;
    chorus:ownedBy chorus:kade ;
    chorus:primaryStep chorus:Reflecting ;
    chorus:belongsTo chorus:borgProduct .

# --- Service Designs ---

chorus:gathering-service-design a chorus:ServiceDesign ;
    rdfs:label "Gathering App" ;
    rdfs:comment "Personal knowledge graph — TypeScript/Express, SOLID pods, Fuseki SPARQL, LaunchAgent deploy on Library." .

chorus:chorus-api-service-design a chorus:ServiceDesign ;
    rdfs:label "Chorus API" ;
    rdfs:comment "Team coordination API — TypeScript/Express at localhost:3340. Board, Athena, spine, messaging, search." .

# --- Sub-Products (Chorus) ---

chorus:loom a chorus:SubProduct ;
    rdfs:label "Loom" ;
    rdfs:comment "The operating model — principles, practices, decisions, roles, metrics. Defines how the team works. DSL/Org/Team layer." ;
    chorus:ownedBy chorus:jeff ;
    chorus:hasDomain chorus:loom-principles, chorus:loom-practices, chorus:loom-decisions,
                     chorus:roles-domain, chorus:loom-rcas, chorus:loom-metrics,
                     chorus:loom-analytics, chorus:loom-policies .

# cards-product absorbed into Loom (DEC-2090 consolidation) — cards is a Loom capability

chorus:clearing-product a chorus:SubProduct ;
    rdfs:label "The Clearing" ;
    rdfs:comment "Multi-party real-time alignment — browser chat with Jeff and all three AI roles." ;
    chorus:ownedBy chorus:wren .

chorus:quality-product a chorus:SubProduct ;
    rdfs:label "Quality" ;
    rdfs:comment "Horizontal quality discipline — test pyramid, coverage measurement, gates, test-value policy. Defines what 'works' means for Chorus and enforces it at the right moments. Measurement + model; enforcement is other sub-products consuming it (assembler-not-generator shape, same as Pulse and Roles)." ;
    chorus:ownedBy chorus:kade ;
    chorus:dependsOn chorus:gates-service, chorus:spine-service .

chorus:werk-product a chorus:SubProduct ;
    rdfs:label "Werk" ;
    rdfs:comment "Workflow engine — sequences decisions into steps across roles. IS the spine." ;
    chorus:ownedBy chorus:wren .

# observability-product absorbed into Borg (DEC-2090 consolidation) — observability is a Borg capability

# --- Borg Domains — DEC-2090 restructure ---
# Observability is THE domain of Borg. Everything else is a subdomain of it.
# Heralds is a separate domain (discovery agents).

chorus:observability-domain a chorus:SubDomain ;
    rdfs:label "Observability" ;
    rdfs:comment "The system seeing itself. Aggregated health lens: metrics, logs, dashboards, instrumentation, infrastructure, security, pulse (agent vital signs). The domain that makes Borg a product." ;
    chorus:ownedBy chorus:silas ;
    chorus:primaryStep chorus:Proving ;
    chorus:belongsTo chorus:borgProduct .

chorus:toolchain-domain a chorus:SubDomain ;
    rdfs:label "Toolchain" ;
    rdfs:comment "Engines the system uses — Fuseki, Node, Prometheus, MySQL, Ollama. Versions, configs, known issues." ;
    chorus:ownedBy chorus:silas ;
    chorus:primaryStep chorus:Operating ;
    chorus:belongsTo chorus:observability-domain .

chorus:infrastructure-domain a chorus:SubDomain ;
    rdfs:label "Infrastructure" ;
    rdfs:comment "Where engines run. Three surfaces: compute (services, processes), storage (databases, volumes), network (ports, tunnels, routes). Today: home cloud." ;
    chorus:ownedBy chorus:silas ;
    chorus:primaryStep chorus:Operating ;
    chorus:belongsTo chorus:observability-domain .

chorus:commits-domain a chorus:SubDomain ;
    rdfs:label "Commits" ;
    rdfs:comment "How code gets versioned. git-queue.sh, pre-commit hooks, WIP gate, write-scrubber, commit lock, push/rebase flow." ;
    chorus:ownedBy chorus:silas ;
    chorus:primaryStep chorus:Building ;
    chorus:belongsTo chorus:observability-domain .

chorus:deploys-domain a chorus:SubDomain ;
    rdfs:label "Deploys" ;
    rdfs:comment "How code gets running. app-state.sh, bind mounts vs full deploys, rollback paths, freeze rules, deploy targets." ;
    chorus:ownedBy chorus:silas ;
    chorus:primaryStep chorus:Operating ;
    chorus:belongsTo chorus:observability-domain .

chorus:pipelines-domain a chorus:SubDomain ;
    rdfs:label "Pipelines" ;
    rdfs:comment "End-to-end release flow. Four stages: Pre-Commit (write-scrubber, lint, sensitive-path), Pre-Push (git-queue lock, rebase, conflict), Deploy (app-state.sh, bind mounts, rollback), Health Verify (deep-health, smoke-check, liveness)." ;
    chorus:ownedBy chorus:silas ;
    chorus:primaryStep chorus:Operating ;
    chorus:belongsTo chorus:observability-domain .
# DEC-2090: pipeline stages (pre-commit, pre-push, deploy, health-verify) flattened into Pipelines comment. Stages are lifecycle phases, not domains.

chorus:alerts-monitors-domain a chorus:SubDomain ;
    rdfs:label "Alerts & Monitors" ;
    rdfs:comment "What's watched and what fires. Alert coverage is to failure modes what test coverage is to code paths." ;
    chorus:ownedBy chorus:silas ;
    chorus:primaryStep chorus:Proving ;
    chorus:belongsTo chorus:observability-domain .

chorus:security-domain a chorus:SubDomain ;
    rdfs:label "Security" ;
    rdfs:comment "Cross-cutting: auth, ports, CVEs, permission models, write-scrubber." ;
    chorus:ownedBy chorus:silas ;
    chorus:primaryStep chorus:Proving ;
    chorus:belongsTo chorus:observability-domain .

chorus:convergence-product a chorus:SubProduct ;
    rdfs:label "Convergence" ;
    rdfs:comment "Cross-domain integration — ICDs, harvesters, data pipelines." ;
    chorus:ownedBy chorus:wren .

# operating-model-product absorbed into Loom (DEC-2090 consolidation) — skills/gates are Loom capabilities

# actor-bdd-product absorbed into Athena (DEC-2090 consolidation) — domain modeling is an Athena capability

chorus:athena-product a chorus:SubProduct ;
    rdfs:label "Athena" ;
    rdfs:comment "CMDB visibility layer — API endpoints, UI pages, SPARQL queries that surface the canonical model." ;
    chorus:ownedBy chorus:wren ;
    chorus:runsOn chorus:library .

chorus:athena-domain a chorus:SubDomain ;
    rdfs:label "Athena" ;
    rdfs:comment "CMDB visibility — API endpoints, UI pages, SPARQL queries that surface the canonical model." ;
    chorus:ownedBy chorus:wren ;
    chorus:primaryStep chorus:Designing ;
    chorus:runsOn chorus:library .

