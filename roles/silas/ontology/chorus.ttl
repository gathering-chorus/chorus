# --- Wire domains into products (hasDomain) ---

chorus:observability-product chorus:hasDomain chorus:code-domain, chorus:commits-domain,
                                              chorus:tests-domain .

chorus:operating-model-product chorus:hasDomain chorus:pipelines-domain .

chorus:chorusProduct chorus:hasDomain chorus:messages-domain, chorus:streams-domain,
                                     chorus:pulse-domain, chorus:knowledge-domain .

chorus:convergence-product chorus:hasDomain chorus:integrations-domain, chorus:convergence-domain .

chorus:chorusProduct chorus:hasDomain chorus:chorus-domain,
                                     chorus:properties-domain, chorus:security-domain,
                                     chorus:time-domain .

chorus:loom chorus:hasDomain chorus:policies-domain .

chorus:actor-bdd-product chorus:hasDomain chorus:domains-domain, chorus:services-domain .

# --- Product → Service consumption edges ---

chorus:loom chorus:consumes chorus:cards-service, chorus:skills-service,
                            chorus:gates-service, chorus:spine-service,
                            chorus:observability-service, chorus:infra-service .

chorus:werk-product chorus:consumes chorus:cards-service, chorus:spine-service,
                                    chorus:observability-service, chorus:infra-service .

chorus:clearing-product chorus:consumes chorus:cards-service, chorus:spine-service,
                                       chorus:observability-service, chorus:infra-service .

chorus:cards-product chorus:consumes chorus:observability-service, chorus:infra-service,
                                   chorus:spine-service .

chorus:observability-product chorus:consumes chorus:infra-service, chorus:logs-service,
                                             chorus:alerts-service, chorus:deploys-service .

# --- Product → Service provision edges ---

chorus:chorusProduct chorus:provides chorus:observability-service, chorus:infra-service,
                                     chorus:logs-service, chorus:alerts-service,
                                     chorus:deploys-service, chorus:cards-service,
                                     chorus:skills-service, chorus:gates-service,
                                     chorus:spine-service .

# --- Product containment ---

chorus:chorusProduct chorus:hasDomain chorus:loom, chorus:cards-product, chorus:clearing-product,
                                     chorus:werk-product, chorus:observability-product,
                                     chorus:convergence-product, chorus:operating-model-product,
                                     chorus:actor-bdd-product, chorus:athena-product .

chorus:athena-product chorus:hasDomain chorus:athena-domain .

chorus:athena-product chorus:consumes chorus:knowledge-domain, chorus:cards-service,
                                      chorus:observability-service, chorus:infra-service .

