    rdfs:comment "Bridge messaging, nudge delivery, inter-role communication." ;
    chorus:ownedBy chorus:silas ;
    chorus:primaryStep chorus:Proving .

chorus:streams-domain a chorus:SubDomain ;
    rdfs:label "Streams" ;
    rdfs:comment "Event streams, spine event flow, Loki log streams." ;
    chorus:ownedBy chorus:silas ;
    chorus:primaryStep chorus:Proving .

chorus:pulse-domain a chorus:SubDomain ;
