# --- New practices — session lifecycle ---

chorus:practice-session-opening a chorus:Practice ;
    rdfs:label "Session opening (5-beat thesis)" ;
    rdfs:comment "Role opens every session with a thesis-driven 5-beat prose opening: named shift, reframed active card, quiet friction with position, named flinch, single-question close. Not a status report. Skill: auto-injected via SessionStart hook." ;
    chorus:expresses chorus:principle-observe-and-interact,
                     chorus:principle-protect-attention,
                     chorus:principle-obtain-a-yield ;
    chorus:ceremonyRisk false .

chorus:practice-close-out a chorus:Practice ;
    rdfs:label "Close-out (Hard 5)" ;
    rdfs:comment "End-of-session discipline: journal, board audit, activity log, next-session.md, commit. Triggered on 'eod' / 'reboot' / past 5pm. Skills: /close, /reboot." ;
    chorus:expresses chorus:principle-catch-and-store-energy,
                     chorus:principle-produce-no-waste,
                     chorus:principle-artifacts ;
    chorus:ceremonyRisk false .

chorus:practice-pull-card a chorus:Practice ;
    rdfs:label "Pull card to WIP (/pull)" ;
    rdfs:comment "Single engineering entry point. Validate card → preflight → WIP check → domain context → design gate → TDD readiness → move + declare + signal. Hard gates emit spine events. Skill: /pull." ;
    chorus:expresses chorus:principle-no-dark-work,
                     chorus:principle-ship-small,
                     chorus:principle-design-from-patterns-to-details ;
    chorus:operationalizes chorus:policy-tdd-gate,
                           chorus:policy-icd-write-gate ;
    chorus:ceremonyRisk false .

chorus:practice-demo a chorus:Practice ;
    rdfs:label "Demo to Jeff (/demo)" ;
    rdfs:comment "Proving gate — smoke check, prep summary, signal to Wren, builder cannot self-accept. Skill: /demo." ;
    chorus:expresses chorus:principle-apply-self-regulation-and-accept-feedback,
                     chorus:principle-obtain-a-yield ;
    chorus:operationalizes chorus:policy-demo-gate,
                           chorus:policy-demo-provenance ;
    chorus:ceremonyRisk false .

chorus:practice-acp a chorus:Practice ;
    rdfs:label "Accept + commit + push (werk-accept — the GO step of chorus_werk, GO=accept #3311)" ;
    rdfs:comment "Full acceptance flow after gates pass. Ownership transfer recorded in spine + git. Implemented by werk-accept (the GO step of chorus_werk; GO=accept, #3311)." ;
