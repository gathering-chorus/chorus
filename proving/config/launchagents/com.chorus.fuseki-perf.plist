<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.chorus.fuseki-perf</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/jeffbridwell/CascadeProjects/jeff-bridwell-personal-site/scripts/fuseki-perf.sh</string>
