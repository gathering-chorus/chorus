<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.chorus.fuseki-compact</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/jeffbridwell/CascadeProjects/chorus/roles/silas/scripts/fuseki-maintenance.sh</string>
    <string>compact</string>
  </array>

  <!-- Saturday at 1:00 AM -->
  <key>StartCalendarInterval</key>
