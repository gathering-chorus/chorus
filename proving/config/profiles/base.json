{
  "_comment": "Base permission profile — operations ALL roles need. Applied globally via ~/.claude/settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch(*)",
      "WebSearch",
      "Skill(*)",
      "NotebookEdit(*)",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git -C *)",
      "Bash(git stash*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(git merge*)",

      "Bash(ls *)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(diff *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(date*)",
      "Bash(pwd*)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln *)",
      "Bash(chmod *)",
      "Bash(touch *)",
      "Bash(sleep *)",
      "Bash(source *)",

      "Bash(*/board.sh*)",
      "Bash(*/board-ts*)",
      "Bash(*/chorus-board.sh*)",
      "Bash(bash */slack-read*)",
      "Bash(bash */slack-post*)",
      "Bash(*/slack-read.sh*)",
      "Bash(*/slack-post.sh*)",
      "Bash(*/chorus-log*)",
      "Bash(*/chorus-query.sh*)",
      "Bash(*/chorus-index*)",
      "Bash(*/chorus-audit*)",
      "Bash(*/team-scan.sh*)",
      "Bash(*/cost-report.sh*)",
      "Bash(*/system-state.sh*)",

      "Bash(open -a*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git reset --hard*)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(killall *)"
    ]
  }
}
