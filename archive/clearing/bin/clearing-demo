#!/usr/bin/env bash
# clearing-demo — launch a Clearing session pre-loaded with demo context
#
# Usage:
#   clearing-demo <card-id>           Demo a specific card
#   clearing-demo <card-id> --guest   Include guest access info (future)
#
# What it does:
#   1. Fetches card details (title, AC, owner, commits, briefs)
#   2. Determines which roles to involve (builder + PM + Jeff)
#   3. Assembles a demo-shaped context block
#   4. Launches Clearing with --context-file
#
# The session template enforces demo flow:
#   Builder presents → PM verifies AC → Jeff reacts → accept/reject/iterate

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
BOARD_TS="$REPO_ROOT/messages/scripts/board-ts"

# Parse args
CARD_ID=""
GUEST_MODE=false
for arg in "$@"; do
  case "$arg" in
    --guest) GUEST_MODE=true ;;
    --help|-h)
      echo "clearing-demo — demo a card in The Clearing"
      echo ""
      echo "Usage: clearing-demo <card-id> [--guest]"
      echo ""
      echo "Fetches card context, determines roles, launches Clearing"
      echo "with demo meeting template injected."
      exit 0
      ;;
    *) [[ -z "$CARD_ID" ]] && CARD_ID="$arg" ;;
  esac
done

if [[ -z "$CARD_ID" ]]; then
  echo "Usage: clearing-demo <card-id>"
  exit 1
fi

# Strip leading # if present
CARD_ID="${CARD_ID#\#}"

echo "Assembling demo context for #${CARD_ID}..."

# 1. Fetch card details
CARD_VIEW=$("$BOARD_TS" view "$CARD_ID" 2>&1) || {
  echo "Error: could not fetch card #${CARD_ID}"
  echo "$CARD_VIEW"
  exit 1
}

# Extract fields
CARD_TITLE=$(echo "$CARD_VIEW" | head -1 | sed 's/^#[0-9]* //')
CARD_OWNER=$(echo "$CARD_VIEW" | grep -i "Owner:" | head -1 | sed 's/.*Owner:\s*//' | tr -d '[:space:]')
CARD_STATUS=$(echo "$CARD_VIEW" | grep -i "Status:" | head -1 | sed 's/.*Status:\s*//' | tr -d '[:space:]')
CARD_PRIORITY=$(echo "$CARD_VIEW" | grep -i "Priority:" | head -1 | sed 's/.*Priority:\s*//' | tr -d '[:space:]')

# 2. Fetch recent commits referencing this card + diffs
COMMITS_TEAM=$(git -C "$REPO_ROOT" log --oneline -10 --all 2>/dev/null | grep -i "#${CARD_ID}\b\|($CARD_ID)\|(C#${CARD_ID})" | head -5 || true)
COMMITS_APP=""
COMMIT_DIFFS=""
if [[ -d "$REPO_ROOT/jeff-bridwell-personal-site/.git" ]]; then
  COMMITS_APP=$(git -C "$REPO_ROOT/jeff-bridwell-personal-site" log --oneline -10 --all 2>/dev/null | grep -i "#${CARD_ID}\b\|($CARD_ID)\|(C#${CARD_ID})" | head -5 || true)
fi

# Fetch actual diffs for proof (team repo commits)
if [[ -n "$COMMITS_TEAM" ]]; then
  while IFS= read -r line; do
    SHA=$(echo "$line" | awk '{print $1}')
    DIFF=$(git -C "$REPO_ROOT" diff "${SHA}^..${SHA}" --stat 2>/dev/null | head -15 || true)
    COMMIT_DIFFS="${COMMIT_DIFFS}#### ${line}\n\`\`\`\n${DIFF}\n\`\`\`\n\n"
  done <<< "$COMMITS_TEAM"
fi
# App repo commits
if [[ -n "$COMMITS_APP" ]]; then
  while IFS= read -r line; do
    SHA=$(echo "$line" | awk '{print $1}')
    DIFF=$(git -C "$REPO_ROOT/jeff-bridwell-personal-site" diff "${SHA}^..${SHA}" --stat 2>/dev/null | head -15 || true)
    COMMIT_DIFFS="${COMMIT_DIFFS}#### ${line} (app)\n\`\`\`\n${DIFF}\n\`\`\`\n\n"
  done <<< "$COMMITS_APP"
fi

# 3. Check for briefs mentioning this card
BRIEFS=""
for dir in "$REPO_ROOT/architect/briefs" "$REPO_ROOT/engineer/briefs" "$REPO_ROOT/product-manager/briefs"; do
  if [[ -d "$dir" ]]; then
    found=$(grep -rl "#${CARD_ID}\b\|card.*${CARD_ID}" "$dir"/*.md 2>/dev/null | head -3 || true)
    if [[ -n "$found" ]]; then
      for f in $found; do
        BRIEFS="${BRIEFS}- $(basename "$f")\n"
      done
    fi
  fi
done

# 3b. Extract AC from card description (lines after "acceptance criteria" or "AC:" header)
CARD_AC=$(echo "$CARD_VIEW" | sed -n '/[Aa]cceptance [Cc]riteria\|^AC:/,/^$/p' | head -20 || true)
if [[ -z "$CARD_AC" ]]; then
  # Fallback: grab the description section
  CARD_AC=$(echo "$CARD_VIEW" | sed -n '/Description:/,/^$/p' | head -20 || true)
fi

# 3c. Check for builder's pre-staged demo brief
# Convention: briefs/<date>-demo-<card-id>.md in the builder's role directory
DEMO_BRIEF=""
DEMO_BRIEF_CONTENT=""
TODAY=$(date +%Y-%m-%d)
for dir in "$REPO_ROOT/architect/briefs" "$REPO_ROOT/engineer/briefs" "$REPO_ROOT/product-manager/briefs"; do
  for pattern in "$dir"/*-demo-${CARD_ID}.md "$dir"/*-demo-${CARD_ID}-*.md; do
    if [[ -f "$pattern" ]]; then
      DEMO_BRIEF="$pattern"
      DEMO_BRIEF_CONTENT=$(cat "$pattern")
      break 2
    fi
  done
done

if [[ -n "$DEMO_BRIEF" ]]; then
  echo "  Demo brief: $(basename "$DEMO_BRIEF") (builder pre-staged evidence)"
else
  echo "  Demo brief: (none — builder will present from commit diffs only)"
  echo "  Tip: builder can stage evidence at <role>/briefs/${TODAY}-demo-${CARD_ID}.md"
fi

# 4. Determine builder role
BUILDER="unknown"
CARD_OWNER_LC=$(echo "$CARD_OWNER" | tr '[:upper:]' '[:lower:]')
case "$CARD_OWNER_LC" in
  silas|architect) BUILDER="Silas" ;;
  kade|engineer)   BUILDER="Kade" ;;
  wren|product*)   BUILDER="Wren" ;;
  *)
    # Try to infer from commits
    if echo "$COMMITS_TEAM$COMMITS_APP" | grep -qi "silas"; then
      BUILDER="Silas"
    elif echo "$COMMITS_TEAM$COMMITS_APP" | grep -qi "kade"; then
      BUILDER="Kade"
    elif echo "$COMMITS_TEAM$COMMITS_APP" | grep -qi "wren"; then
      BUILDER="Wren"
    fi
    ;;
esac

# 5. Assemble context file
CONTEXT_FILE=$(mktemp /tmp/clearing-demo-XXXXXXXXXXXX)

cat > "$CONTEXT_FILE" << CONTEXT_EOF
## Demo Session: #${CARD_ID}

**This is a demo meeting.** Follow the demo protocol — not open-ended conversation.

### CRITICAL: You Have NO Tool Access

You are running as a lightweight Haiku model in a group chat. You CANNOT:
- Run commands, scripts, or queries of any kind
- Read files, logs, or code
- Access the board, Loki, Fuseki, or any system
- Verify anything at runtime — you can only reason from the context below

Do NOT claim to have checked, verified, or looked at anything. Do NOT offer to "run" or "capture" anything. If proof is missing from the context below, say "that evidence is not in the demo context" — do not hallucinate having access.

### Card
${CARD_VIEW}

### Acceptance Criteria
$(echo -e "${CARD_AC:-(no AC found — builder must state AC explicitly before proceeding)}")

### Builder's Demo Evidence (pre-staged)
$(if [[ -n "$DEMO_BRIEF_CONTENT" ]]; then echo "$DEMO_BRIEF_CONTENT"; else echo "(no demo brief staged — builder will present from commit diffs only)"; fi)

### Commit Evidence (pre-staged)
$(echo -e "${COMMIT_DIFFS:-(no commit diffs found)}")

### Commit Summary
${COMMITS_TEAM:-(none in team repo)}
${COMMITS_APP:+(app repo:)
$COMMITS_APP}

### Briefs Exchanged
$(echo -e "${BRIEFS:-(none found)}")

### Demo Protocol

**Builder: ${BUILDER}** — you are presenting. Your job is to walk through each AC item and point to specific evidence from the commit diffs above. If evidence is missing from the context, say so honestly — do not claim it exists.

**Meeting shape:** Builder presents with evidence → PM verifies AC line by line → Jeff reacts → accept/reject/iterate.

**Flow:**
1. **${BUILDER} speaks first.** For EACH AC item: state the criterion, point to the specific commit diff or file change that proves it, and state whether it's met. If you can't prove it from the context above, say "AC N: not provable from staged evidence — needs runtime verification."
2. **Wren verifies.** Check each AC item against the commit diffs. Be specific — "AC 1: met, evidence in promtail-config.yaml change" or "AC 2: not demonstrated, no diff shows this change." Do not accept claims without evidence.
3. **Jeff reacts.** Questions, concerns, or acceptance.
4. **Iterate if needed.** If Jeff asks questions, the relevant role answers. Stay tight.

**Rules:**
- 3 sentences max per turn unless Jeff asks to elaborate.
- Don't restate what another role said.
- If Jeff says "accept" — ${BUILDER} should NOT mark Done themselves. Wren confirms.
- If Jeff says "reject" — ${BUILDER} takes notes on what needs fixing. Wren writes the rejection brief.
- No tangents. This is about #${CARD_ID} and nothing else.
- NEVER claim to be able to run commands, check logs, or access any system. You are in a chat. That's it.
CONTEXT_EOF

echo "Context assembled:"
echo "  Card:    #${CARD_ID} — ${CARD_TITLE}"
echo "  Builder: ${BUILDER}"
echo "  Status:  ${CARD_STATUS}"
echo "  Commits: $(echo "$COMMITS_TEAM$COMMITS_APP" | grep -c . || echo 0) found"
echo ""

# 6. Launch Clearing with context
exec "$SCRIPT_DIR/clearing" --context-file "$CONTEXT_FILE"
