# EXTRACTED 2026-06-11 (#3350) from athena-product-design.html — the canonical
# v2 schema per ADR-040 (class vocabulary of record). This file is the landing
# source for urn:chorus:ontology; the design doc remains the narrative home.
# conformance: ADR-040-manual
# shapes.ttl — SHACL enforcement (invariant-rendering: every stored required)
@prefix chorus: <https://jeffbridwell.com/chorus#> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

chorus:ProductShape a sh:NodeShape ;
    sh:targetClass chorus:Product ;
    sh:property [ sh:path chorus:label            ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:comment          ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:ownedBy          ; sh:minCount 1 ; sh:class chorus:Role ] ;
    sh:property [ sh:path chorus:vision           ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:valueProposition ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:audience         ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:status           ; sh:minCount 1 ; sh:in ( "exploring" "building" "operating" "retiring" ) ] ;
    sh:property [ sh:path chorus:gaps             ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:atStep           ; sh:minCount 1 ; sh:class chorus:ValueStreamStep ] ;
    sh:property [ sh:path chorus:hasDesignDoc     ; sh:minCount 1 ; sh:class chorus:Document ] ;
    sh:property [ sh:path chorus:hasDomain        ; sh:minCount 1 ; sh:class chorus:Domain ] .
    # consumes / hasChild — structurally optional; ranges enforced where present.

chorus:DomainShape a sh:NodeShape ;
    sh:targetClass chorus:Domain ;
    sh:property [ sh:path chorus:label        ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:comment      ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:ownedBy      ; sh:minCount 1 ; sh:class chorus:Role ] ;
    sh:property [ sh:path chorus:atStep       ; sh:minCount 1 ; sh:class chorus:ValueStreamStep ] ;
    sh:property [ sh:path chorus:status       ; sh:minCount 1 ; sh:in ( "exploring" "building" "operating" "retiring" ) ] ;
    sh:property [ sh:path chorus:gaps         ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:hasDesignDoc ; sh:minCount 1 ; sh:class chorus:Document ] ;
    sh:property [ sh:path chorus:contains ] ;  # AMENDED #3350: minCount dropped — unsatisfiable at bootstrap (no records exist pre-population); emptiness is render-visible (ADR-028 read-side), not write-forbidden
    sh:property [ sh:path [ sh:inversePath chorus:hasDomain ] ; sh:minCount 1 ; sh:maxCount 1 ; sh:class chorus:Product ] .  # every Domain belongs to exactly one Product
    # hosts / hasChild — structurally optional.

chorus:ServiceShape a sh:NodeShape ;
    sh:targetClass chorus:Service ;
    sh:property [ sh:path chorus:label              ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:overview           ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:ownedBy            ; sh:minCount 1 ; sh:class chorus:Role ] ;
    sh:property [ sh:path [ sh:inversePath chorus:hosts ] ; sh:minCount 1 ; sh:maxCount 1 ; sh:class chorus:Domain ] ;  # exactly one hosting Domain
    sh:property [ sh:path chorus:atStep             ; sh:minCount 1 ; sh:class chorus:ValueStreamStep ] ;
    sh:property [ sh:path chorus:status             ; sh:minCount 1 ; sh:in ( "exploring" "building" "operating" "retiring" ) ] ;
    sh:property [ sh:path chorus:asIs               ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:toBe               ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:implementationPlan ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:pathToClose        ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:gaps               ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:notInScope         ; sh:minCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path chorus:hasDesignDoc       ; sh:minCount 1 ; sh:class chorus:Document ] .
