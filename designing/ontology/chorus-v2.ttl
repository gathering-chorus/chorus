# EXTRACTED 2026-06-11 (#3350) from athena-product-design.html — the canonical
# v2 schema per ADR-040 (class vocabulary of record). This file is the landing
# source for urn:chorus:ontology; the design doc remains the narrative home.
# conformance: ADR-040-manual
# chorus.ttl — Athena v2 (additive; coexists with AS-IS during migration)
@prefix chorus: <https://jeffbridwell.com/chorus#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# ── Structural classes ──────────────────────────────────────────────
chorus:Product          a owl:Class .
chorus:Domain           a owl:Class .
chorus:Service          a owl:Class .
chorus:Role             a owl:Class .
chorus:ValueStream      a owl:Class .
chorus:ValueStreamStep  a owl:Class .
chorus:Document         a owl:Class .
chorus:Principle        a owl:Class .
chorus:Practice         a owl:Class .
chorus:Infrastructure   a owl:Class .
chorus:Store            a owl:Class .

# ── Containment edges (stored on parent / containment side) ─────────
chorus:hasChild   a owl:ObjectProperty .   # Product→Product OR Domain→Domain (recursive)
chorus:hasDomain  a owl:ObjectProperty ;
    rdfs:domain chorus:Product ;
    rdfs:range  chorus:Domain .
chorus:hosts      a owl:ObjectProperty ;
    rdfs:domain chorus:Domain ;
    rdfs:range  chorus:Service .            # Domain hosts Service (1:* from Domain)
chorus:consumes   a owl:ObjectProperty ;
    rdfs:domain chorus:Product ;
    rdfs:range  chorus:Service .            # cross-cutting; structurally optional

# ── Placement / ownership / design link ─────────────────────────────
chorus:atStep        a owl:ObjectProperty ;
    rdfs:range chorus:ValueStreamStep .     # subject ∈ {Product, Domain, Service}
chorus:ownedBy       a owl:ObjectProperty ;
    rdfs:range chorus:Role .
chorus:hasDesignDoc  a owl:ObjectProperty ;
    rdfs:range chorus:Document .
chorus:inStream      a owl:ObjectProperty ;
    rdfs:domain chorus:ValueStreamStep ;
    rdfs:range  chorus:ValueStream .

# ── Service-side edges ──────────────────────────────────────────────
chorus:dependsOn      a owl:ObjectProperty ;
    rdfs:domain chorus:Service ; rdfs:range chorus:Service .
chorus:commitsTo      a owl:ObjectProperty ;
    rdfs:domain chorus:Service .            # range: Principle ∨ Practice
chorus:integratesWith a owl:ObjectProperty ;
    rdfs:domain chorus:Domain ; rdfs:range chorus:Domain .
chorus:runsOn         a owl:ObjectProperty ;
    rdfs:domain chorus:Domain ; rdfs:range chorus:Infrastructure .
chorus:persistsIn     a owl:ObjectProperty ;
    rdfs:domain chorus:Domain ; rdfs:range chorus:Store .

# ── Membership (ADR-028 req-1: subdomain links to its records) ──────
chorus:contains a owl:ObjectProperty .       # Domain → Record OR Service → Record (union of content classes)

# ── External reference (entities that point AT a Service, not contained) ──
chorus:atService a owl:ObjectProperty ;
    rdfs:range chorus:Service .              # Card / SpineEvent / … → Service (reference, not containment)

# ── Dropped (collapsed into containment-direction predicates) ───────
# chorus:inParent, chorus:inProduct, chorus:hostedBy — DO NOT WRITE.
# chorus:domain, chorus:service (back-pointers) — replaced by chorus:contains (Domain/Service → Record).
# chorus:belongsTo, chorus:partOf — retired (AS-IS).

# ── Stored narrative attributes (xsd:string, invariant-rendered) ────
chorus:label              a owl:DatatypeProperty ; rdfs:range xsd:string .
chorus:comment            a owl:DatatypeProperty ; rdfs:range xsd:string .
chorus:overview           a owl:DatatypeProperty ; rdfs:range xsd:string .
chorus:vision             a owl:DatatypeProperty ; rdfs:range xsd:string .
chorus:valueProposition   a owl:DatatypeProperty ; rdfs:range xsd:string .
chorus:audience           a owl:DatatypeProperty ; rdfs:range xsd:string .
chorus:status             a owl:DatatypeProperty ; rdfs:range xsd:string .
chorus:asIs               a owl:DatatypeProperty ; rdfs:range xsd:string .
chorus:toBe               a owl:DatatypeProperty ; rdfs:range xsd:string .
chorus:implementationPlan a owl:DatatypeProperty ; rdfs:range xsd:string .
chorus:pathToClose        a owl:DatatypeProperty ; rdfs:range xsd:string .
chorus:gaps               a owl:DatatypeProperty ; rdfs:range xsd:string .
chorus:notInScope         a owl:DatatypeProperty ; rdfs:range xsd:string .
