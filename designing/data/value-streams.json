        { "name": "value-stream-step-demo",   "label": "Demo",   "stageOrder": 7 },
        { "name": "value-stream-step-merge",  "label": "Merge",  "stageOrder": 8 },
        { "name": "value-stream-step-accept", "label": "Accept", "stageOrder": 9 }
