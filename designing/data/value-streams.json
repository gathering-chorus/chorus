        { "name": "value-stream-step-proving",    "label": "Proving",    "stageOrder": 5, "hasValueStream": "value-stream-borg" },
        { "name": "value-stream-step-reflecting", "label": "Reflecting", "stageOrder": 6, "hasValueStream": "value-stream-borg" }
