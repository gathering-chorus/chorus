{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spine Event Contract",
  "description": "Interface contract for all structured events flowing through the Chorus spine. Single source of truth for event types, fields, and vertebra mapping.",
  "version": "2.0.0",
  "schema_version": "2.0.0",
  "envelope": {
    "description": "Required fields on every spine event",
    "fields": {
      "timestamp": {
        "type": "string",
        "format": "ISO 8601 UTC",
        "required": true,
        "description": "Event timestamp"
      },
      "level": {
        "type": "string",
        "default": "info",
        "required": true,
        "description": "Log level (info, warn, error)"
      },
      "appName": {
        "type": "string",
        "enum": [
          "chorus-events",
          "cards"
        ],
        "required": true,
        "description": "Source system identifier"
      },
      "component": {
        "type": "string",
        "default": "lifecycle",
        "required": true,
        "description": "Component identifier"
      },
      "event": {
        "type": "string",
        "required": true,
        "description": "Event type name \u2014 domain.noun.verb_past format (must match an entry in events)"
      },
      "role": {
        "type": "string",
        "enum": [
          "wren",
          "silas",
          "kade",
          "jeff",
          "system"
        ],
        "required": true,
        "description": "Role that triggered the event"
      }
    }
  },
  "vertebrae": {
    "capturing": {
      "description": "Card creation \u2014 Jeff pulls work into the flow",
      "color": "#ede9fe"
    },
    "directing": {
      "description": "Card sequencing \u2014 moving cards through the board",
      "color": "#fef3c7"
    },
    "building": {
      "description": "Engineering work \u2014 commits, tests, builds",
      "color": "#d1fae5"
    },
    "proving": {
      "description": "Deploy pipeline \u2014 verification and release",
      "color": "#fce7f3"
    },
    "operations": {
      "description": "Operating \u2014 infrastructure health, deploys, and system lifecycle",
      "color": "#f3f4f6"
    }
  },
  "aliases": {
    "card_created": "card.item.created",
    "quality_gate_warn": "card.quality.warned",
    "card_moved": "card.item.moved",
    "card_blocked": "card.item.blocked",
    "card_unblocked": "card.item.unblocked",
    "card_updated": "card.item.updated",
    "card_commented": "card.item.commented",
    "card_tagged": "card.item.tagged",
    "card_done": "card.item.completed",
    "stale_card_detected": "card.stale.detected",
    "board_snapshot": "board.snapshot.taken",
    "board_audit_start": "board.audit.started",
    "board_audit_close": "board.audit.closed",
    "bucket_limit_set": "board.limit.set",
    "workflow_created": "workflow.manifest.created",
    "workflow_complete": "workflow.manifest.completed",
    "brief_written": "brief.handoff.written",
    "brief_read": "brief.handoff.read",
    "decision": "decision.record.created",
    "commit": "build.commit.created",
    "commit_linked": "build.commit.linked",
    "commit_queue_waiting": "build.queue.waiting",
    "commit_queue_acquired": "build.queue.acquired",
    "commit_queue_released": "build.queue.released",
    "commit_queue_timeout": "build.queue.timedout",
    "tsc_compile": "build.tsc.completed",
    "pre_commit": "build.precommit.completed",
    "pre_commit_timed": "build.precommit.timed",
    "pre_push_start": "build.prepush.started",
    "pre_push_timed": "build.prepush.timed",
    "test_run": "build.test.completed",
    "git_push": "build.push.completed",
    "memory_write": "build.memory.written",
    "app_start": "app.service.started",
    "app_start_fail": "app.service.startfailed",
    "app_stop": "app.service.stopped",
    "app_restart": "app.service.restarted",
    "app_restart_fail": "app.service.restartfailed",
    "app_rollback": "app.service.rolledback",
    "app_rollback_fail": "app.service.rollbackfailed",
    "deploy_start": "deploy.pipeline.started",
    "deploy_phase": "deploy.phase.completed",
    "deploy_complete": "deploy.pipeline.completed",
    "deploy_success": "deploy.pipeline.succeeded",
    "deploy_fail": "deploy.pipeline.failed",
    "deploy_freeze": "deploy.freeze.activated",
    "deploy_unfreeze": "deploy.freeze.deactivated",
    "health_check": "deploy.health.checked",
    "verification_complete": "deploy.verification.completed",
    "session_start": "session.role.started",
    "session_end": "session.role.ended",
    "session_turn": "session.turn.completed",
    "session_tool": "session.tool.used",
    "session_compact": "session.context.compacted",
    "doc_scan": "session.docscan.completed",
    "ops_agent_run": "ops.agent.completed",
    "defect_detected": "ops.defect.detected",
    "alert_firing": "ops.alert.fired",
