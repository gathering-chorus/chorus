    "harvest_notify": "harvest.notify.sent",
    "cost_report": "ops.cost.reported",
    "guardrail_decision": "guard.rule.decided",
    "write_scrub": "guard.scrub.blocked",
    "data_classification": "guard.classify.decided",
    "audit_check": "ops.audit.checked",
    "transposition_rate": "self.biometric.transposition_rate",
    "card_pulled": "card.pulled",
    "seed_received": "seed.received",
    "seed_captured": "seed.captured",
    "seed_routed": "seed.routed",
    "seed_recovered": "seed.recovered",
    "nudge_sent": "role.nudge.sent",
    "nudge_delivered": "role.nudge.delivered",
    "chat_started": "chat.session.started",
    "chat.started": "chat.session.started",
    "chat_ended": "chat.session.ended",
    "chat.ended": "chat.session.ended",
    "pair_started": "pair.session.started",
    "pair.started": "pair.session.started",
    "pair_ended": "pair.session.ended",
    "pair.ended": "pair.session.ended",
    "pair_swapped": "pair.roles.swapped",
    "pair.swapped": "pair.roles.swapped",
    "protocol_boot_start": "protocol.boot.started",
    "protocol_boot_complete": "protocol.boot.completed",
    "protocol_close_start": "protocol.close.started",
    "protocol_close_complete": "protocol.close.completed",
    "protocol_step": "protocol.step.completed",
    "role.nudge.consumed": "role.nudge.consumed"
  },
