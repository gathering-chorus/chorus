  "services": [
    {
      "iri": "chorus:service-crawler",
      "label": "crawler",
      "comment": "Monolithic snapshot crawler — index-crawler-snapshots.sh (11 collectors x 27 domains) + crawler-hydrate-graph.sh (RDF). VERIFIED dependency map via subagent traces against the running system (#3071), not inference. One monolith, four owners; pending decomposition into per-collector instances (#3069/ADR-033). Full map: designing/docs/crawler-dependency-map.html.",
      "ownedBy": "chorus:role-silas",
      "atStep": "chorus:value-stream-step-directing",
      "status": "operating",
      "produces": [
        { "output": "messages source=crawler", "store": "sqlite:messages", "writer": "index-crawler-snapshots.sh", "domain": "chorus:messages", "verdict": "load-bearing" },
        { "output": "spine events crawler.*", "store": "spine:chorus.log", "writer": "index-crawler-snapshots.sh", "domain": "chorus:spine", "verdict": "load-bearing" },
        { "output": "chorus:File RDF triples", "store": "fuseki:urn:chorus:instances", "writer": "crawler-hydrate-graph.sh", "domain": "chorus:knowledge", "verdict": "load-bearing" },
        { "output": "LanceDB vectors", "store": "lancedb", "writer": "embedDelta", "domain": "chorus:search", "verdict": "load-bearing" },
        { "output": "/tmp/crawler-domain-status.json", "store": "tmpfile", "writer": "index-crawler-snapshots.sh", "domain": "chorus:alerts-monitors", "verdict": "load-bearing" },
        { "output": "traces", "store": "sqlite:traces", "writer": "trace_hop", "domain": "chorus:spine", "verdict": "waste", "note": "108 rows/min, 144K of 301K total, NO load-bearing consumer found — cut/sample candidate, verify first" },
        { "output": "chorus_files", "store": "sqlite:chorus_files", "writer": "crawler-hydrate-graph.sh", "domain": "chorus:code", "verdict": "low", "note": "internal reconciliation; no external load-bearing reader found" }
      ],
      "consumedBy": [
        { "consumer": "context_inject (EVERY prompt)", "domain": "chorus:policies", "reads": ["messages source=crawler", "spine events crawler.*", "LanceDB vectors"] },
        { "consumer": "/api/chorus/search FTS+hybrid", "domain": "chorus:search", "reads": ["messages source=crawler", "LanceDB vectors"] },
        { "consumer": "crawler-stale.yml / hydration-divergence.yml / crawler-error.yml / crawler-domain-failure.yml", "domain": "chorus:alerts-monitors", "reads": ["spine events crawler.*", "/tmp/crawler-domain-status.json"] },
        { "consumer": "pain rollup", "domain": "chorus:analytics", "reads": ["spine events crawler.*"] },
        { "consumer": "indexSpine (re-index)", "domain": "chorus:memory", "reads": ["spine events crawler.*"] },
        { "consumer": "/crawl collectRdf + collectOwl", "domain": "chorus:knowledge", "reads": ["chorus:File RDF triples"] }
      ],
      "gaps": [
        "traces table has no load-bearing consumer — first to cut/sample (#3069)",
        "circular: collectMentions reads messages_fts then writes back a crawler row, re-indexed, read again (#2323)",
        "monolith spans 4 owners — ownership violation pending decomposition #3069/ADR-033"
      ]
    }
  ],
