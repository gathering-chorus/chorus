C4Component
    title Chorus Hooks — Component Diagram (Level 3)

    Container_Ext(claude, "Claude Code", "AI role session")
    Container_Ext(api, "Chorus API :3340", "Search, domain queries")
    Container_Ext(clearing, "Clearing :3470", "Bridge chat")
    Container_Ext(spine, "Spine Log", "chorus.log")
    Container_Ext(file_state, "File State", "/tmp/ state files")

    Container_Boundary(hooks, "Chorus Hooks — Rust, Axum, Unix socket /tmp/chorus-hooks.sock") {

        Component(dispatch, "Hook Dispatcher", "main.rs", "Routes pre/post/prompt hooks to guard chains by tool type")

        Component(session_init, "Session Init Gate", "session_init_gate.rs", "Block tool calls before session boot completes")
        Component(search_hierarchy, "Search Hierarchy", "search_hierarchy.rs", "DEC-074: Chorus search before filesystem grep")
        Component(memory_first, "Memory First", "memory_first.rs", "Block grep without prior Chorus query")
        Component(tdd_gate, "TDD Gate", "tdd_gate.rs", "DEC-1674: Require tests before code on demo/done")
        Component(demo_gate, "Demo Gate", "demo_gate.rs", "DEC-048: Require demo evidence before done")
        Component(log_first, "Log First Gate", "log_first_gate.rs", "Require log inspection before fix edits")
        Component(sensitive, "Sensitive Paths", "sensitive_paths.rs", "Block writes to .env, credentials, secrets")
        Component(write_scrub, "Write Scrubber", "write_scrubber.rs", "Redact credentials from shared file writes")
        Component(icd_gate, "ICD Write Gate", "icd_write_gate.rs", "DEC-095: Block harvester code without ICD provider")
        Component(autonomy, "Autonomy Guard", "autonomy_guard.rs", "Classify user intent, prevent unprompted action")
        Component(pair_gate, "Pair Gate", "pair_gate.rs", "Enforce pair protocol when pair is active")
        Component(quality_gate, "Quality Gate", "quality_gate.rs", "Pre-commit quality checks")
        Component(accept_gate, "Accept Gate", "accept_gate.rs", "Builder cannot self-accept code cards")
        Component(ops_aware, "Ops Awareness", "ops_awareness.rs", "Non-blocking ops context injection")
        Component(observer, "Observer", "observer.rs", "Structured hook decision logging")
        Component(telemetry, "Tool Telemetry", "tool_telemetry.rs", "Duration, frequency, pattern tracking")
        Component(context_inject, "Context Inject", "context_inject.rs", "Compound context synthesis on search")

        Component(nudge_cmd, "Nudge Subcommand", "nudge.rs", "Queue + inject + Bridge post + spine event")
        Component(log_cmd, "Log Subcommand", "chorus_log.rs", "Spine event emission from event schema")
        Component(role_state_cmd, "Role State Subcommand", "role_state.rs", "Read/write /tmp/claude-team-scan/{role}.json")
        Component(session_cmd, "Session Subcommand", "commands/session.rs", "Boot context, bridge-subscriber launch, crash recovery")
        Component(health_cmd, "Health Subcommand", "commands/health.rs", "Deep health, daily review, Pulse generation")
    }

    Rel(claude, dispatch, "POST /pre-tool-use, /post-tool-use, /user-prompt-submit")

    Rel(dispatch, session_init, "All tools — session boot check")
    Rel(dispatch, search_hierarchy, "Grep/Glob — enforce search order")
    Rel(dispatch, memory_first, "Grep — require prior Chorus query")
    Rel(dispatch, tdd_gate, "Write/Edit — test-first enforcement")
    Rel(dispatch, demo_gate, "cards move Done — demo evidence")
    Rel(dispatch, log_first, "Edit — log inspection before fix")
    Rel(dispatch, sensitive, "Write/Edit — block credential paths")
    Rel(dispatch, write_scrub, "Write/Edit — redact secrets")
    Rel(dispatch, icd_gate, "Write — harvester code needs ICD")
    Rel(dispatch, autonomy, "UserPromptSubmit — intent classification")
    Rel(dispatch, pair_gate, "All tools — pair protocol enforcement")
    Rel(dispatch, quality_gate, "Bash git commit — quality checks")
    Rel(dispatch, accept_gate, "cards done — self-accept block")
    Rel(dispatch, ops_aware, "All tools — ops context")
    Rel(dispatch, context_inject, "Grep — compound context synthesis")

    Rel(observer, spine, "Hook decision log")
    Rel(telemetry, spine, "Tool usage metrics")
    Rel(nudge_cmd, file_state, "Write /tmp/voice-inbox/{role}/")
    Rel(nudge_cmd, clearing, "POST consumed nudge to Bridge")
    Rel(log_cmd, spine, "Append spine event")
    Rel(role_state_cmd, file_state, "Write /tmp/claude-team-scan/{role}.json")
    Rel(session_cmd, api, "Context cache queries")
    Rel(search_hierarchy, api, "Enforce Chorus search first")
