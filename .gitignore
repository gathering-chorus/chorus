# Chorus repo — ignore generated/runtime files
node_modules
node_modules/
dist/
target/
coverage/
*.js.map

# Compiled TS artifacts shadowing source (#2201, #2209)
# ts-jest instruments .js first when a .ts sibling exists — stale compiled
# output causes silent test failures and miscounted coverage.
platform/api/src/**/*.js
platform/api/src/**/*.d.ts
platform/chorus-sdk/src/**/*.js
platform/chorus-sdk/src/**/*.d.ts
platform/pulse/src/**/*.js
platform/pulse/src/**/*.d.ts
platform/workflow-engine/src/**/*.js
platform/workflow-engine/src/**/*.d.ts
directing/clearing/src/**/*.js
directing/clearing/src/**/*.d.ts
directing/products/cards/src/**/*.js
directing/products/cards/src/**/*.d.ts
.env
.env.*
*.tsbuildinfo

# Runtime data
*.db
*.db-wal
*.db-shm

# #2881 — Python bytecode (never tracked)
__pycache__/

# #2881 — auto-generated session screenshots accumulating untracked. The 200
# screenshots already committed in proving/screenshots/ (Silas March-April
# instrumentation runs) stay tracked — gitignore only affects new untracked
# files. Cleanup of the historical set is intentionally out of scope here.
proving/screenshots/*.png

# OS
.DS_Store

# Logs (indexed by Loki, not source)
ops/logs/chorus.log
ops/logs/permission-prompts.log
ops/logs/command-errors.log
ops/logs/*.log.*.gz
ops/logs/board-snapshot-*.json
platform/logs/chorus.log
platform/logs/permission-prompts.log
platform/logs/command-errors.log
platform/logs/board-snapshot-*.json

# Clearing transcripts (runtime, not source)
archive/clearing/transcripts/
directing/clearing/transcripts/

# Hook-generated brief files (#2777) — written by session-close hooks on every
# card move/done/shipped/reassigned. Pile up in canonical `git status` and
# drown real edits in noise. Roles work from werks; canonical is shared view.
directing/products/roles/*/briefs/*-card-*-moved-to-*.md
directing/products/roles/*/briefs/*-card-*-done.md
directing/products/roles/*/briefs/*-card-*-shipped.md
directing/products/roles/*/briefs/*-card-*-reassigned-to-*.md

# Runtime logs from cards/products domains
directing/products/logs/

# claudemd-gen runtime artifacts (CLAUDE.md is derived; so is its checksum
# manifest and versioned snapshots). Source of truth lives in fragments.
designing/claudemd/.checksums.json
designing/claudemd/versions/*.json

# Per-role scheduler lock (runtime, not source)
roles/*/.claude/scheduled_tasks.lock

# Vikunja data
vikunja/db/
vikunja/files/
directing/vikunja/db/

# Rust build artifacts
*.rlib

# Logs and snapshots in proving/ (runtime, not source)
proving/logs/*.log
proving/logs/*.log.*
proving/logs/*.json

# Stale config backups
*.json.bak

# Temp files
/tmp/
*.swp
*~
.git-commit.meta

# #2458 — book photos never belong in git (each 9-18MB, push-bloat incident 2026-04-24)
platform/api/public/book/images*
roles/*/artifacts/book-images*
roles/*/artifacts/book-images-v*

# #2731 — CLAUDE.md is a derived artifact, not a snapshot. Generated from
# fragments by platform/scripts/claudemd-gen at the moment of need (PostToolUse
# on fragment edit, defensive regen at SessionStart). Tracking the file in git
# was the source of the role-fragment-staleness deadlock that paged Jeff 12+
# times in a week (2026-04-28 → 2026-05-04). On a fresh clone, run
# `platform/scripts/claudemd-gen` once to materialize all three.
roles/*/CLAUDE.md
