{
  "name": "chorus-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Chorus workspace root — hosts shared lint config for all packages (#2284)",
  "scripts": {
    "lint": "eslint 'platform/**/src/**/*.ts' 'directing/**/src/**/*.ts' 'platform/**/tests/**/*.ts' 'directing/**/tests/**/*.ts'",
    "lint:fix": "eslint --fix 'platform/**/src/**/*.ts' 'directing/**/src/**/*.ts' 'platform/**/tests/**/*.ts' 'directing/**/tests/**/*.ts'",
    "lint:ratchet": "node platform/scripts/lint-ratchet.js",
    "lint:baseline": "node platform/scripts/lint-ratchet.js --regenerate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^15.0.0"
  }
}
