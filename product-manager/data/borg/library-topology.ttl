@prefix borg:    <urn:borg:ontology/> .
@prefix sosa:    <http://www.w3.org/ns/sosa/> .
@prefix ssn:     <http://www.w3.org/ns/ssn/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# ---- Borg Ontology (TOSCA-inspired topology + K8s state pattern) ----

borg:Service a rdfs:Class ;
    rdfs:label "Managed Service" ;
    rdfs:comment "A service in the infrastructure topology. Inspired by TOSCA NodeTemplate." .

borg:Host a rdfs:Class ;
    rdfs:label "Host Machine" ;
    rdfs:comment "A physical or virtual machine hosting services." .

borg:hostedOn a rdf:Property ;
    rdfs:label "hosted on" ;
    rdfs:domain borg:Service ;
    rdfs:range borg:Host .

borg:dependsOn a rdf:Property ;
    rdfs:label "depends on" ;
    rdfs:domain borg:Service ;
    rdfs:range borg:Service .

borg:port a rdf:Property ;
    rdfs:label "port" ;
    rdfs:domain borg:Service ;
    rdfs:range xsd:integer .

borg:desiredState a rdf:Property ;
    rdfs:label "desired state" ;
    rdfs:comment "K8s spec pattern — what should be true." .

borg:observedState a rdf:Property ;
    rdfs:label "observed state" ;
    rdfs:comment "K8s status pattern — what is actually true." .

# ---- Hosts ----

<urn:borg:host/library> a borg:Host ;
    rdfs:label "Library Mac" ;
    borg:ip "192.168.86.36" ;
    borg:model "Mac mini M1" ;
    borg:memory "16GB" ;
    borg:storage "2TB SSD" .

<urn:borg:host/bedroom> a borg:Host ;
    rdfs:label "Bedroom Mac" ;
    borg:ip "192.168.86.242" ;
    borg:model "Mac mini M2 Pro" ;
    borg:memory "32GB" ;
    borg:storage "178TB external" .

# ---- Services: Library Mac ----

<urn:borg:service/fuseki> a borg:Service ;
    rdfs:label "Apache Fuseki" ;
    borg:hostedOn <urn:borg:host/library> ;
    borg:port 3030 ;
    borg:desiredState "running" ;
    borg:observedState "running" ;
    borg:lifecycle "LaunchAgent" .

<urn:borg:service/gathering-app> a borg:Service ;
    rdfs:label "Gathering App" ;
    borg:hostedOn <urn:borg:host/library> ;
    borg:port 3000 ;
    borg:dependsOn <urn:borg:service/fuseki> ;
    borg:desiredState "running" ;
    borg:observedState "running" ;
    borg:lifecycle "LaunchAgent" .

<urn:borg:service/chorus-api> a borg:Service ;
    rdfs:label "Chorus API" ;
    borg:hostedOn <urn:borg:host/library> ;
    borg:port 3340 ;
    borg:desiredState "running" ;
    borg:observedState "running" ;
    borg:lifecycle "LaunchAgent" .

<urn:borg:service/bridge> a borg:Service ;
    rdfs:label "Bridge" ;
    borg:hostedOn <urn:borg:host/library> ;
    borg:port 3470 ;
    borg:dependsOn <urn:borg:service/gathering-app> ;
    borg:desiredState "running" ;
    borg:observedState "running" ;
    borg:lifecycle "LaunchAgent" .

<urn:borg:service/grafana> a borg:Service ;
    rdfs:label "Grafana" ;
    borg:hostedOn <urn:borg:host/library> ;
    borg:port 3100 ;
    borg:dependsOn <urn:borg:service/loki> ;
    borg:desiredState "running" ;
    borg:observedState "running" ;
    borg:lifecycle "Docker" .

<urn:borg:service/loki> a borg:Service ;
    rdfs:label "Loki" ;
    borg:hostedOn <urn:borg:host/library> ;
    borg:port 3102 ;
    borg:desiredState "running" ;
    borg:observedState "running" ;
    borg:lifecycle "Docker" .

<urn:borg:service/vikunja> a borg:Service ;
    rdfs:label "Vikunja" ;
    borg:hostedOn <urn:borg:host/library> ;
    borg:port 3456 ;
    borg:desiredState "running" ;
    borg:observedState "running" ;
    borg:lifecycle "Docker" .

# ---- Services: Bedroom Mac ----

<urn:borg:service/nifi> a borg:Service ;
    rdfs:label "Apache NiFi" ;
    borg:hostedOn <urn:borg:host/bedroom> ;
    borg:port 8443 ;
    borg:desiredState "running" ;
    borg:observedState "running" ;
    borg:lifecycle "LaunchAgent" .
